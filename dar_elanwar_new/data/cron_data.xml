            <field name="name">Education: Auto-generate Invoices</field>
            <field name="model_id" ref="model_education_student_subscription"/>
            <field name="state">code</field>
            <field name="code">model._cron_auto_generate_invoices()</field>
            <field name="interval_number">1</field>
