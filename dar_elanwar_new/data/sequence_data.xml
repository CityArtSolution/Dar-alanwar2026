<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- Student Sequence -->
        <record id="seq_education_student" model="ir.sequence">
            <field name="name">Education Student</field>
            <field name="code">education.student</field>
            <field name="prefix">STD</field>
            <field name="padding">5</field>
            <field name="company_id" eval="False"/>
        </record>

        <!-- Employee Sequence -->
        <record id="seq_education_employee" model="ir.sequence">
            <field name="name">Education Employee</field>
            <field name="code">education.employee</field>
            <field name="prefix">EMP</field>
            <field name="padding">5</field>
            <field name="company_id" eval="False"/>
        </record>

        <!-- Admission Application Sequence -->
        <record id="seq_education_admission_application" model="ir.sequence">
            <field name="name">Admission Application</field>
            <field name="code">education.admission.application</field>
            <field name="prefix">ADM</field>
            <field name="padding">5</field>
            <field name="company_id" eval="False"/>
        </record>

        <!-- Payment Receipt Sequence -->
        <record id="seq_education_payment_receipt" model="ir.sequence">
            <field name="name">Payment Receipt</field>
            <field name="code">education.payment.receipt</field>
            <field name="prefix">RCP</field>
            <field name="padding">5</field>
            <field name="company_id" eval="False"/>
        </record>

        <!-- Support Ticket Sequence -->
        <record id="seq_education_support_ticket" model="ir.sequence">
            <field name="name">Support Ticket</field>
            <field name="code">education.support.ticket</field>
            <field name="prefix">TKT</field>
            <field name="padding">5</field>
            <field name="company_id" eval="False"/>
        </record>

    </data>
</odoo>
