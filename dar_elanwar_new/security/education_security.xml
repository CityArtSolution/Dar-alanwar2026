<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data noupdate="0">

        <!-- ============================================================ -->
        <!-- Education Module Category                                     -->
        <!-- ============================================================ -->
        <record id="module_category_education" model="ir.module.category">
            <field name="name">Education</field>
            <field name="description">Education Management System for Dar Al-Anwar Academy</field>
            <field name="sequence">10</field>
        </record>

        <!-- ============================================================ -->
        <!-- Security Groups                                               -->
        <!-- ============================================================ -->

        <!-- Education User -->
        <record id="education_group_user" model="res.groups">
            <field name="name">Education User</field>
            <field name="category_id" ref="module_category_education"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
            <field name="comment">Basic read access to education records. Suitable for parents, front-desk staff, and general viewers.</field>
        </record>

        <!-- Teacher (implies User) -->
        <record id="education_group_teacher" model="res.groups">
            <field name="name">Teacher</field>
            <field name="category_id" ref="module_category_education"/>
            <field name="implied_ids" eval="[(4, ref('education_group_user'))]"/>
            <field name="comment">Read, create, and write access. Teachers can manage attendance, grades, homework, and evaluations.</field>
        </record>

        <!-- Education Manager (implies Teacher) -->
        <record id="education_group_manager" model="res.groups">
            <field name="name">Education Manager</field>
            <field name="category_id" ref="module_category_education"/>
            <field name="implied_ids" eval="[(4, ref('education_group_teacher'))]"/>
            <field name="comment">Full CRUD access including delete. Managers oversee departments, billing, admissions, and reporting.</field>
        </record>

        <!-- Education Administrator (implies Manager) -->
        <record id="education_group_admin" model="res.groups">
            <field name="name">Education Administrator</field>
            <field name="category_id" ref="module_category_education"/>
            <field name="implied_ids" eval="[(4, ref('education_group_manager'))]"/>
            <field name="comment">Unrestricted access to all education records across all branches. Can configure system settings, security, and master data.</field>
        </record>

    </data>

