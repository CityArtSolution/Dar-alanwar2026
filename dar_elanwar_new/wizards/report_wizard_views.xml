<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ==================== -->
    <!-- Report Wizard         -->
    <!-- ==================== -->

    <record id="view_education_report_wizard_form" model="ir.ui.view">
        <field name="name">education.report.wizard.form</field>
        <field name="model">education.report.wizard</field>
        <field name="arch" type="xml">
            <form string="Report Wizard">
                <group>
                    <group>
                        <field name="report_type"/>
                        <field name="date_from"/>
                        <field name="date_to"/>
                        <field name="branch_id"/>
                        <field name="department_id"/>
                    </group>
                    <group>
                        <field name="class_id"/>
                        <field name="academic_year_id"/>
                        <field name="student_id"/>
                        <field name="employee_id"/>
                    </group>
                </group>
                <footer>
                    <button name="action_print" string="Print" type="object"
                            class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_report_wizard" model="ir.actions.act_window">
        <field name="name">Report Wizard</field>
        <field name="res_model">education.report.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

</odoo>
