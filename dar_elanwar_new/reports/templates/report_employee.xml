<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================ -->
    <!--  Employee Report - Dar Al-Anwar Academy                      -->
    <!--  Bilingual Arabic + English | RTL-Aware                      -->
    <!-- ============================================================ -->

    <template id="report_employee_document">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="web.external_layout">
                    <div class="page" dir="rtl" style="font-family: 'Arial', 'Tahoma', sans-serif;">

                        <!-- ===== CSS ===== -->
                        <style>
                            .page {
                                direction: rtl;
                                text-align: right;
                                font-size: 10pt;
                                color: #333;
                            }
                            .academy-header {
                                text-align: center;
                                border-bottom: 3px solid #1a5276;
                                padding-bottom: 12px;
                                margin-bottom: 20px;
                            }
                            .academy-header .ar-name {
                                font-size: 18pt;
                                font-weight: bold;
                                color: #1a5276;
                            }
                            .academy-header .en-name {
                                font-size: 12pt;
                                color: #555;
                                direction: ltr;
                            }
                            .section-title {
                                background-color: #1a5276;
                                color: #fff;
                                padding: 6px 14px;
                                font-size: 12pt;
                                font-weight: bold;
                                margin: 18px 0 10px 0;
                                border-radius: 3px;
                            }
                            .section-title .en {
                                font-weight: normal;
                                font-size: 10pt;
                                margin-right: 10px;
                                direction: ltr;
                                display: inline;
                            }
                            .emp-table {
                                width: 100%;
                                border-collapse: collapse;
                                margin-bottom: 14px;
                            }
                            .emp-table th,
                            .emp-table td {
                                border: 1px solid #ccc;
                                padding: 5px 8px;
                                vertical-align: middle;
                            }
                            .emp-table thead th {
                                background-color: #1a5276;
                                color: #fff;
                                font-weight: bold;
                                text-align: center;
                                font-size: 9pt;
                            }
                            .emp-table tbody td {
                                text-align: center;
                                font-size: 9pt;
                            }
                            .emp-table tbody tr:nth-child(even) {
                                background-color: #f7f9fb;
                            }
                            .emp-table tfoot td {
                                background-color: #eaf2f8;
                                font-weight: bold;
                            }
                            .amount {
                                direction: ltr;
                                text-align: left;
                                font-family: 'Courier New', monospace;
                                white-space: nowrap;
                            }
                            .summary-cards {
                                display: flex;
                                gap: 10px;
                                margin-bottom: 16px;
                            }
                            .s-card {
                                flex: 1;
                                border: 1px solid #ccc;
                                border-radius: 4px;
                                padding: 12px;
                                text-align: center;
                            }
                            .s-card .val {
                                font-size: 18pt;
                                font-weight: bold;
                                color: #1a5276;
                            }
                            .s-card .lbl {
                                font-size: 8pt;
                                color: #666;
                                margin-top: 4px;
                            }
                            @media print {
                                .page { page-break-after: always; }
                                .section-title,
                                .emp-table thead th,
                                .emp-table tfoot td {
                                    -webkit-print-color-adjust: exact;
                                    print-color-adjust: exact;
                                }
                            }
                        </style>

                        <!-- ===== Header ===== -->
                        <div class="academy-header">
                            <div class="ar-name">&#1583;&#1575;&#1585; &#1575;&#1604;&#1571;&#1606;&#1608;&#1575;&#1585; &#1575;&#1604;&#1571;&#1603;&#1575;&#1583;&#1610;&#1605;&#1610;&#1577;</div>
                            <div class="en-name">Dar Al-Anwar Academy</div>
                        </div>

                        <h3 style="text-align:center; margin-bottom:4px;">
                            &#1578;&#1602;&#1585;&#1610;&#1585; &#1575;&#1604;&#1605;&#1608;&#1592;&#1601;&#1610;&#1606;
                        </h3>
                        <p style="text-align:center; font-size:10pt; color:#555; direction:ltr; margin-bottom:16px;">
                            Employee Report
                        </p>

                        <!-- ===== Summary Cards ===== -->
                        <div class="summary-cards">
                            <div class="s-card">
                                <div class="val"><t t-esc="doc.total_employees or 0"/></div>
                                <div class="lbl">&#1573;&#1580;&#1605;&#1575;&#1604;&#1610; &#1575;&#1604;&#1605;&#1608;&#1592;&#1601;&#1610;&#1606;<br/>Total Employees</div>
                            </div>
                            <div class="s-card">
                                <div class="val" style="color:#27ae60;">
                                    <t t-esc="doc.active_employees or 0"/>
                                </div>
                                <div class="lbl">&#1606;&#1588;&#1591;<br/>Active</div>
                            </div>
                            <div class="s-card">
                                <div class="val" style="color:#2980b9;">
                                    <t t-esc="doc.teacher_count or 0"/>
                                </div>
                                <div class="lbl">&#1605;&#1593;&#1604;&#1605;&#1610;&#1606;<br/>Teachers</div>
                            </div>
                            <div class="s-card">
                                <div class="val" style="color:#8e44ad;">
                                    <t t-esc="doc.admin_count or 0"/>
                                </div>
                                <div class="lbl">&#1573;&#1583;&#1575;&#1585;&#1610;&#1610;&#1606;<br/>Admin Staff</div>
                            </div>
                        </div>

                        <!-- ===== Employee Directory ===== -->
                        <div class="section-title">
                            &#1583;&#1604;&#1610;&#1604; &#1575;&#1604;&#1605;&#1608;&#1592;&#1601;&#1610;&#1606;
                            <span class="en">Employee Directory</span>
                        </div>
                        <table class="emp-table">
                            <thead>
                                <tr>
                                    <th>#</th>
                                    <th>&#1575;&#1604;&#1603;&#1608;&#1583; / Code</th>
                                    <th>&#1575;&#1604;&#1575;&#1587;&#1605; / Name</th>
                                    <th>&#1575;&#1604;&#1602;&#1587;&#1605; / Dept.</th>
                                    <th>&#1575;&#1604;&#1605;&#1587;&#1605;&#1609; &#1575;&#1604;&#1608;&#1592;&#1610;&#1601;&#1610; / Job Title</th>
                                    <th>&#1575;&#1604;&#1607;&#1575;&#1578;&#1601; / Phone</th>
                                    <th>&#1578;&#1575;&#1585;&#1610;&#1582; &#1575;&#1604;&#1578;&#1593;&#1610;&#1610;&#1606; / Hire Date</th>
                                    <th>&#1606;&#1608;&#1593; &#1575;&#1604;&#1608;&#1585;&#1583;&#1610;&#1577; / Shift</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="doc.employee_lines" t-as="emp">
                                    <tr>
                                        <td><t t-esc="emp_index + 1"/></td>
                                        <td><t t-esc="emp.employee_code or '-'"/></td>
                                        <td style="text-align:right;"><t t-esc="emp.name or '-'"/></td>
                                        <td style="text-align:right;"><t t-esc="emp.department_name or '-'"/></td>
                                        <td style="text-align:right;"><t t-esc="emp.job_title or '-'"/></td>
                                        <td style="direction:ltr; text-align:left;">
                                            <t t-esc="emp.phone or '-'"/>
                                        </td>
                                        <td><t t-esc="emp.hire_date" t-options="{'widget': 'date'}"/></td>
                                        <td><t t-esc="emp.shift_type or '-'"/></td>
                                    </tr>
                                </t>
                            </tbody>
                        </table>

                        <!-- ===== Payroll Summary ===== -->
                        <div class="section-title">
                            &#1605;&#1604;&#1582;&#1589; &#1575;&#1604;&#1585;&#1608;&#1575;&#1578;&#1576;
                            <span class="en">Payroll Summary</span>
                        </div>
                        <div class="summary-cards">
                            <div class="s-card">
                                <div class="val" style="color:#1a5276;">
                                    <t t-esc="'%.2f' % (doc.total_salary_cost or 0)"/>
                                </div>
                                <div class="lbl">&#1573;&#1580;&#1605;&#1575;&#1604;&#1610; &#1578;&#1603;&#1575;&#1604;&#1610;&#1601; &#1575;&#1604;&#1585;&#1608;&#1575;&#1578;&#1576;<br/>Total Salary Costs</div>
                            </div>
                        </div>

                        <!-- Department-wise Payroll -->
                        <table class="emp-table">
                            <thead>
                                <tr>
                                    <th>#</th>
                                    <th>&#1575;&#1604;&#1602;&#1587;&#1605; / Department</th>
                                    <th>&#1593;&#1583;&#1583; &#1575;&#1604;&#1605;&#1608;&#1592;&#1601;&#1610;&#1606; / Headcount</th>
                                    <th>&#1573;&#1580;&#1605;&#1575;&#1604;&#1610; &#1575;&#1604;&#1585;&#1608;&#1575;&#1578;&#1576; / Total Salary</th>
                                    <th>&#1605;&#1578;&#1608;&#1587;&#1591; &#1575;&#1604;&#1585;&#1575;&#1578;&#1576; / Avg. Salary</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="doc.payroll_lines" t-as="pl">
                                    <tr>
                                        <td><t t-esc="pl_index + 1"/></td>
                                        <td style="text-align:right;"><t t-esc="pl.department_name or '-'"/></td>
                                        <td><t t-esc="pl.headcount or 0"/></td>
                                        <td class="amount">
                                            <t t-esc="'%.2f' % (pl.total_salary or 0)"/>
                                            <t t-esc="doc.currency_symbol or ''"/>
                                        </td>
                                        <td class="amount">
                                            <t t-esc="'%.2f' % (pl.avg_salary or 0)"/>
                                            <t t-esc="doc.currency_symbol or ''"/>
                                        </td>
                                    </tr>
                                </t>
                            </tbody>
                            <tfoot>
                                <tr>
                                    <td colspan="2" style="text-align:right;">
                                        &#1575;&#1604;&#1573;&#1580;&#1605;&#1575;&#1604;&#1610; / Total
                                    </td>
                                    <td><t t-esc="doc.total_employees or 0"/></td>
                                    <td class="amount">
                                        <t t-esc="'%.2f' % (doc.total_salary_cost or 0)"/>
                                        <t t-esc="doc.currency_symbol or ''"/>
                                    </td>
                                    <td></td>
                                </tr>
                            </tfoot>
                        </table>

                        <!-- ===== Teacher Class Assignments ===== -->
                        <div class="section-title">
                            &#1575;&#1604;&#1605;&#1593;&#1604;&#1605;&#1610;&#1606; &#1608;&#1575;&#1604;&#1601;&#1589;&#1608;&#1604; &#1575;&#1604;&#1605;&#1587;&#1606;&#1583;&#1577;
                            <span class="en">Teachers &amp; Assigned Classes</span>
                        </div>
                        <table class="emp-table">
                            <thead>
                                <tr>
                                    <th>#</th>
                                    <th>&#1575;&#1587;&#1605; &#1575;&#1604;&#1605;&#1593;&#1604;&#1605; / Teacher</th>
                                    <th>&#1575;&#1604;&#1602;&#1587;&#1605; / Department</th>
                                    <th>&#1575;&#1604;&#1601;&#1589;&#1608;&#1604; &#1575;&#1604;&#1605;&#1587;&#1606;&#1583;&#1577; / Assigned Classes</th>
                                    <th>&#1593;&#1583;&#1583; &#1575;&#1604;&#1591;&#1604;&#1575;&#1576; / Student Count</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="doc.teacher_lines" t-as="tch">
                                    <tr>
                                        <td><t t-esc="tch_index + 1"/></td>
                                        <td style="text-align:right;"><t t-esc="tch.teacher_name or '-'"/></td>
                                        <td style="text-align:right;"><t t-esc="tch.department_name or '-'"/></td>
                                        <td style="text-align:right;">
                                            <t t-esc="tch.assigned_classes or '-'"/>
                                        </td>
                                        <td><t t-esc="tch.student_count or 0"/></td>
                                    </tr>
                                </t>
                            </tbody>
                        </table>

                        <!-- ===== Footer ===== -->
                        <div style="margin-top:20px; text-align:center; font-size:8pt; color:#999; border-top:1px solid #ddd; padding-top:8px;">
                            &#1578;&#1605; &#1573;&#1606;&#1588;&#1575;&#1569; &#1607;&#1584;&#1575; &#1575;&#1604;&#1578;&#1602;&#1585;&#1610;&#1585; &#1570;&#1604;&#1610;&#1575;&#1611; &#1576;&#1608;&#1575;&#1587;&#1591;&#1577; &#1606;&#1592;&#1575;&#1605; &#1583;&#1575;&#1585; &#1575;&#1604;&#1571;&#1606;&#1608;&#1575;&#1585;
                            |
                            <span style="direction:ltr;">Auto-generated by Dar Al-Anwar System</span>
                        </div>

                    </div>
                </t>
            </t>
        </t>
    </template>

</odoo>
