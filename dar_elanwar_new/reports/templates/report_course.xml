<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================ -->
    <!--  Course Report - Dar Al-Anwar Academy                        -->
    <!--  Bilingual Arabic + English | RTL-Aware                      -->
    <!-- ============================================================ -->

    <template id="report_course_document">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="web.external_layout">
                    <div class="page" dir="rtl" style="font-family: 'Arial', 'Tahoma', sans-serif;">

                        <!-- ===== CSS ===== -->
                        <style>
                            .page {
                                direction: rtl;
                                text-align: right;
                                font-size: 10pt;
                                color: #333;
                            }
                            .academy-header {
                                text-align: center;
                                border-bottom: 3px solid #1a5276;
                                padding-bottom: 12px;
                                margin-bottom: 20px;
                            }
                            .academy-header .ar-name {
                                font-size: 18pt;
                                font-weight: bold;
                                color: #1a5276;
                            }
                            .academy-header .en-name {
                                font-size: 12pt;
                                color: #555;
                                direction: ltr;
                            }
                            .section-title {
                                background-color: #1a5276;
                                color: #fff;
                                padding: 6px 14px;
                                font-size: 12pt;
                                font-weight: bold;
                                margin: 18px 0 10px 0;
                                border-radius: 3px;
                            }
                            .section-title .en {
                                font-weight: normal;
                                font-size: 10pt;
                                margin-right: 10px;
                                direction: ltr;
                                display: inline;
                            }
                            .course-table {
                                width: 100%;
                                border-collapse: collapse;
                                margin-bottom: 14px;
                            }
                            .course-table th,
                            .course-table td {
                                border: 1px solid #ccc;
                                padding: 6px 10px;
                                vertical-align: middle;
                            }
                            .course-table thead th {
                                background-color: #1a5276;
                                color: #fff;
                                font-weight: bold;
                                text-align: center;
                            }
                            .course-table tbody td {
                                text-align: center;
                            }
                            .course-table tbody tr:nth-child(even) {
                                background-color: #f7f9fb;
                            }
                            .course-table tfoot td {
                                background-color: #eaf2f8;
                                font-weight: bold;
                            }
                            .summary-cards {
                                display: flex;
                                gap: 10px;
                                margin-bottom: 16px;
                            }
                            .s-card {
                                flex: 1;
                                border: 1px solid #ccc;
                                border-radius: 4px;
                                padding: 12px;
                                text-align: center;
                            }
                            .s-card .val {
                                font-size: 18pt;
                                font-weight: bold;
                            }
                            .s-card .lbl {
                                font-size: 8pt;
                                color: #666;
                                margin-top: 4px;
                            }
                            .green { color: #27ae60; }
                            .blue { color: #1a5276; }
                            .orange { color: #e67e22; }
                            .red { color: #e74c3c; }
                            .filter-box {
                                background-color: #f0f4f8;
                                border: 1px solid #d5dce4;
                                border-radius: 4px;
                                padding: 8px 14px;
                                margin-bottom: 16px;
                                font-size: 10pt;
                            }
                            @media print {
                                .page { page-break-after: always; }
                                .section-title,
                                .course-table thead th,
                                .course-table tfoot td {
                                    -webkit-print-color-adjust: exact;
                                    print-color-adjust: exact;
                                }
                            }
                        </style>

                        <!-- ===== Header ===== -->
                        <div class="academy-header">
                            <div class="ar-name">&#1583;&#1575;&#1585; &#1575;&#1604;&#1571;&#1606;&#1608;&#1575;&#1585; &#1575;&#1604;&#1571;&#1603;&#1575;&#1583;&#1610;&#1605;&#1610;&#1577;</div>
                            <div class="en-name">Dar Al-Anwar Academy</div>
                        </div>

                        <h3 style="text-align:center; margin-bottom:4px;">
                            &#1578;&#1602;&#1585;&#1610;&#1585; &#1575;&#1604;&#1583;&#1608;&#1585;&#1575;&#1578;
                        </h3>
                        <p style="text-align:center; font-size:10pt; color:#555; direction:ltr; margin-bottom:16px;">
                            Course Report
                        </p>

                        <!-- ===== Filter Info ===== -->
                        <div class="filter-box">
                            <strong>&#1575;&#1604;&#1601;&#1578;&#1585;&#1577; / Period:</strong>
                            <t t-if="doc.date_from">
                                &#1605;&#1606;: <t t-esc="doc.date_from" t-options="{'widget': 'date'}"/>
                            </t>
                            <t t-if="doc.date_to">
                                &#1573;&#1604;&#1609;: <t t-esc="doc.date_to" t-options="{'widget': 'date'}"/>
                            </t>
                        </div>

                        <!-- ===== Summary Cards ===== -->
                        <div class="section-title">
                            &#1605;&#1604;&#1582;&#1589; &#1575;&#1604;&#1583;&#1608;&#1585;&#1575;&#1578;
                            <span class="en">Course Summary</span>
                        </div>
                        <div class="summary-cards">
                            <div class="s-card">
                                <div class="val blue"><t t-esc="doc.total_content_items or 0"/></div>
                                <div class="lbl">&#1573;&#1580;&#1605;&#1575;&#1604;&#1610; &#1575;&#1604;&#1605;&#1581;&#1578;&#1608;&#1609;<br/>Total Content Items</div>
                            </div>
                            <div class="s-card">
                                <div class="val green"><t t-esc="doc.total_categories or 0"/></div>
                                <div class="lbl">&#1573;&#1580;&#1605;&#1575;&#1604;&#1610; &#1575;&#1604;&#1578;&#1589;&#1606;&#1610;&#1601;&#1575;&#1578;<br/>Total Categories</div>
                            </div>
                            <div class="s-card">
                                <div class="val orange"><t t-esc="doc.active_access_grants or 0"/></div>
                                <div class="lbl">&#1589;&#1604;&#1575;&#1581;&#1610;&#1575;&#1578; &#1575;&#1604;&#1608;&#1589;&#1608;&#1604; &#1575;&#1604;&#1606;&#1588;&#1591;&#1577;<br/>Active Access Grants</div>
                            </div>
                            <div class="s-card">
                                <div class="val" style="color:#1a5276;">
                                    <t t-esc="'%.1f' % (doc.total_usage_hours or 0)"/>
                                </div>
                                <div class="lbl">&#1573;&#1580;&#1605;&#1575;&#1604;&#1610; &#1587;&#1575;&#1593;&#1575;&#1578; &#1575;&#1604;&#1575;&#1587;&#1578;&#1582;&#1583;&#1575;&#1605;<br/>Total Usage Hours</div>
                            </div>
                        </div>

                        <!-- ===== Content by Category Table ===== -->
                        <div class="section-title">
                            &#1575;&#1604;&#1605;&#1581;&#1578;&#1608;&#1609; &#1581;&#1587;&#1576; &#1575;&#1604;&#1578;&#1589;&#1606;&#1610;&#1601;
                            <span class="en">Content by Category</span>
                        </div>
                        <table class="course-table">
                            <thead>
                                <tr>
                                    <th>#</th>
                                    <th>&#1575;&#1604;&#1578;&#1589;&#1606;&#1610;&#1601; / Category</th>
                                    <th>&#1593;&#1583;&#1583; &#1575;&#1604;&#1593;&#1606;&#1575;&#1589;&#1585; / Item Count</th>
                                    <th>&#1593;&#1583;&#1583; &#1605;&#1585;&#1575;&#1578; &#1575;&#1604;&#1608;&#1589;&#1608;&#1604; / Access Count</th>
                                    <th>&#1587;&#1575;&#1593;&#1575;&#1578; &#1575;&#1604;&#1575;&#1587;&#1578;&#1582;&#1583;&#1575;&#1605; / Usage Hours</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="doc.category_lines" t-as="cat">
                                    <tr>
                                        <td><t t-esc="cat_index + 1"/></td>
                                        <td style="text-align:right;"><t t-esc="cat.category_name or '-'"/></td>
                                        <td><t t-esc="cat.item_count or 0"/></td>
                                        <td><t t-esc="cat.access_count or 0"/></td>
                                        <td><t t-esc="'%.1f' % (cat.usage_hours or 0)"/></td>
                                    </tr>
                                </t>
                            </tbody>
                            <tfoot>
                                <tr>
                                    <td colspan="2" style="text-align:right;">
                                        &#1575;&#1604;&#1573;&#1580;&#1605;&#1575;&#1604;&#1610; / Total
                                    </td>
                                    <td><strong><t t-esc="doc.total_content_items or 0"/></strong></td>
                                    <td><strong><t t-esc="doc.total_access_count or 0"/></strong></td>
                                    <td><strong><t t-esc="'%.1f' % (doc.total_usage_hours or 0)"/></strong></td>
                                </tr>
                            </tfoot>
                        </table>

                        <!-- ===== Most Popular Content Table ===== -->
                        <div class="section-title">
                            &#1575;&#1604;&#1605;&#1581;&#1578;&#1608;&#1609; &#1575;&#1604;&#1571;&#1603;&#1579;&#1585; &#1588;&#1610;&#1608;&#1593;&#1575;&#1611;
                            <span class="en">Most Popular Content</span>
                        </div>
                        <table class="course-table">
                            <thead>
                                <tr>
                                    <th>#</th>
                                    <th>&#1575;&#1587;&#1605; &#1575;&#1604;&#1593;&#1606;&#1589;&#1585; / Item Name</th>
                                    <th>&#1575;&#1604;&#1578;&#1589;&#1606;&#1610;&#1601; / Category</th>
                                    <th>&#1593;&#1583;&#1583; &#1605;&#1585;&#1575;&#1578; &#1575;&#1604;&#1608;&#1589;&#1608;&#1604; / Access Count</th>
                                    <th>&#1605;&#1578;&#1608;&#1587;&#1591; &#1575;&#1604;&#1605;&#1583;&#1577; / Avg Duration</th>
                                    <th>&#1606;&#1587;&#1576;&#1577; &#1575;&#1604;&#1573;&#1603;&#1605;&#1575;&#1604; / Completion Rate</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="doc.popular_content_lines" t-as="pc">
                                    <tr>
                                        <td><t t-esc="pc_index + 1"/></td>
                                        <td style="text-align:right;"><t t-esc="pc.item_name or '-'"/></td>
                                        <td style="text-align:right;"><t t-esc="pc.category_name or '-'"/></td>
                                        <td><t t-esc="pc.access_count or 0"/></td>
                                        <td style="direction:ltr;">
                                            <t t-esc="'%.1f' % (pc.avg_duration or 0)"/>
                                            &#1587;&#1575;&#1593;&#1577; / hr
                                        </td>
                                        <td>
                                            <strong t-attf-style="color: {{ '#27ae60' if (pc.completion_rate or 0) >= 75 else '#e67e22' if (pc.completion_rate or 0) >= 50 else '#e74c3c' }};">
                                                <t t-esc="'%.1f%%' % (pc.completion_rate or 0)"/>
                                            </strong>
                                        </td>
                                    </tr>
                                </t>
                            </tbody>
                        </table>

                        <!-- ===== Student Engagement Table ===== -->
                        <div class="section-title">
                            &#1578;&#1601;&#1575;&#1593;&#1604; &#1575;&#1604;&#1591;&#1604;&#1575;&#1576;
                            <span class="en">Student Engagement</span>
                        </div>
                        <table class="course-table">
                            <thead>
                                <tr>
                                    <th>#</th>
                                    <th>&#1575;&#1604;&#1591;&#1575;&#1604;&#1576; / Student</th>
                                    <th>&#1575;&#1604;&#1593;&#1606;&#1575;&#1589;&#1585; &#1575;&#1604;&#1605;&#1601;&#1578;&#1608;&#1581;&#1577; / Items Accessed</th>
                                    <th>&#1573;&#1580;&#1605;&#1575;&#1604;&#1610; &#1575;&#1604;&#1587;&#1575;&#1593;&#1575;&#1578; / Total Hours</th>
                                    <th>&#1578;&#1575;&#1585;&#1610;&#1582; &#1570;&#1582;&#1585; &#1608;&#1589;&#1608;&#1604; / Last Access Date</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="doc.engagement_lines" t-as="eng">
                                    <tr>
                                        <td><t t-esc="eng_index + 1"/></td>
                                        <td style="text-align:right;"><t t-esc="eng.student_name or '-'"/></td>
                                        <td><t t-esc="eng.items_accessed or 0"/></td>
                                        <td><t t-esc="'%.1f' % (eng.total_hours or 0)"/></td>
                                        <td><t t-esc="eng.last_access_date" t-options="{'widget': 'date'}"/></td>
                                    </tr>
                                </t>
                            </tbody>
                            <tfoot>
                                <tr>
                                    <td colspan="3" style="text-align:right;">
                                        &#1573;&#1580;&#1605;&#1575;&#1604;&#1610; &#1587;&#1575;&#1593;&#1575;&#1578; &#1575;&#1604;&#1578;&#1601;&#1575;&#1593;&#1604; / Total Engagement Hours
                                    </td>
                                    <td><strong><t t-esc="'%.1f' % (doc.total_usage_hours or 0)"/></strong></td>
                                    <td></td>
                                </tr>
                            </tfoot>
                        </table>

                        <!-- ===== Footer ===== -->
                        <div style="margin-top:20px; text-align:center; font-size:8pt; color:#999; border-top:1px solid #ddd; padding-top:8px;">
                            &#1578;&#1605; &#1573;&#1606;&#1588;&#1575;&#1569; &#1607;&#1584;&#1575; &#1575;&#1604;&#1578;&#1602;&#1585;&#1610;&#1585; &#1570;&#1604;&#1610;&#1575;&#1611; &#1576;&#1608;&#1575;&#1587;&#1591;&#1577; &#1606;&#1592;&#1575;&#1605; &#1583;&#1575;&#1585; &#1575;&#1604;&#1571;&#1606;&#1608;&#1575;&#1585;
                            |
                            <span style="direction:ltr;">Auto-generated by Dar Al-Anwar System</span>
                        </div>

                    </div>
                </t>
            </t>
        </t>
    </template>

</odoo>
