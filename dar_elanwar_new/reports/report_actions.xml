<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- 1. Student Details Report -->
    <record id="action_report_student_details" model="ir.actions.report">
        <field name="name">Student Details</field>
        <field name="model">education.student</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">dar_elanwar.report_student_details_document</field>
        <field name="print_report_name">'Student Details - %s' % object.name</field>
        <field name="paperformat_id" ref="paperformat_dar_elanwar"/>
        <field name="binding_model_id" ref="model_education_student"/>
        <field name="binding_type">report</field>
    </record>

