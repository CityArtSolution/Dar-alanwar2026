<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================ -->
    <!-- education.student.subscription : Form View                   -->
    <!-- ============================================================ -->
    <record id="view_education_student_subscription_form" model="ir.ui.view">
        <field name="name">education.student.subscription.form</field>
        <field name="model">education.student.subscription</field>
        <field name="arch" type="xml">
            <form string="Student Subscription">
                <header>
                    <button name="action_activate"
                            string="Activate"
                            type="object"
                            class="btn-primary"
                            invisible="status != 'draft'"/>
                    <button name="action_complete"
                            string="Complete"
                            type="object"
                            class="btn-primary"
                            invisible="status != 'active'"/>
                    <button name="action_cancel"
                            string="Cancel"
                            type="object"
                            class="btn-danger"
                            invisible="status in ('cancelled', 'completed')"/>
                    <field name="status"
                           widget="statusbar"
                           statusbar_visible="draft,active,completed"/>
                </header>
                <sheet>
                    <group>
                        <group string="Subscription Info">
                            <field name="student_id"/>
                            <field name="type_id"/>
                            <field name="plan_id"/>
                            <field name="academic_year_id"/>
                        </group>
                        <group string="Financial Details">
                            <field name="total_amount"/>
                            <field name="discount_id"/>
                            <field name="discount_amount"/>
                            <field name="net_amount"/>
                            <field name="paid_amount"/>
                            <field name="remaining_amount"/>
                        </group>
                    </group>
                    <separator/>
                    <button name="action_generate_installments"
                            string="Generate Installments"
                            type="object"
                            class="btn-secondary"
                            icon="fa-calendar"
                            invisible="status != 'draft'"/>
                    <notebook>
                        <page string="Installments" name="installments">
                            <field name="installment_ids">
                                <tree editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="due_date"/>
                                    <field name="amount"/>
                                    <field name="paid_amount"/>
                                    <field name="is_paid"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- ============================================================ -->
    <!-- education.student.subscription : Tree View                   -->
    <!-- ============================================================ -->
    <record id="view_education_student_subscription_tree" model="ir.ui.view">
        <field name="name">education.student.subscription.tree</field>
        <field name="model">education.student.subscription</field>
        <field name="arch" type="xml">
            <tree string="Student Subscriptions"
                  decoration-success="status == 'active'"
                  decoration-muted="status == 'cancelled'"
                  decoration-info="status == 'completed'">
                <field name="student_id"/>
                <field name="type_id"/>
                <field name="total_amount" sum="Total"/>
                <field name="net_amount" sum="Net Total"/>
                <field name="paid_amount" sum="Paid Total"/>
                <field name="remaining_amount" sum="Remaining Total"/>
                <field name="status"
                       widget="badge"
                       decoration-success="status == 'active'"
                       decoration-info="status == 'completed'"
                       decoration-danger="status == 'cancelled'"/>
            </tree>
        </field>
    </record>

    <!-- ============================================================ -->
    <!-- education.student.subscription : Search View                 -->
    <!-- ============================================================ -->
    <record id="view_education_student_subscription_search" model="ir.ui.view">
        <field name="name">education.student.subscription.search</field>
        <field name="model">education.student.subscription</field>
        <field name="arch" type="xml">
            <search string="Search Subscriptions">
                <field name="student_id"/>
                <field name="type_id"/>
                <separator/>
                <filter string="Draft"
                        name="filter_draft"
                        domain="[('status', '=', 'draft')]"/>
                <filter string="Active"
                        name="filter_active"
                        domain="[('status', '=', 'active')]"/>
                <filter string="Completed"
                        name="filter_completed"
                        domain="[('status', '=', 'completed')]"/>
                <filter string="Cancelled"
                        name="filter_cancelled"
                        domain="[('status', '=', 'cancelled')]"/>
                <separator/>
                <group expand="0" string="Group By">
                    <filter string="Student"
                            name="group_student"
                            context="{'group_by': 'student_id'}"/>
                    <filter string="Type"
                            name="group_type"
                            context="{'group_by': 'type_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ============================================================ -->
    <!-- education.student.subscription : Action                      -->
    <!-- ============================================================ -->
    <record id="action_education_subscription" model="ir.actions.act_window">
        <field name="name">Student Subscriptions</field>
        <field name="res_model">education.student.subscription</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_education_student_subscription_search"/>
        <field name="context">{'search_default_filter_active': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a new student subscription
            </p>
            <p>
                Manage student subscriptions, installments, and payments.
            </p>
        </field>
    </record>

</odoo>
