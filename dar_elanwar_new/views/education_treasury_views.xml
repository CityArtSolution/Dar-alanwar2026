<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================ -->
    <!-- education.treasury : Form View                               -->
    <!-- ============================================================ -->
    <record id="view_education_treasury_form" model="ir.ui.view">
        <field name="name">education.treasury.form</field>
        <field name="model">education.treasury</field>
        <field name="arch" type="xml">
            <form string="Treasury">
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="code"/>
                            <field name="branch_id"/>
                        </group>
                        <group>
                            <field name="balance" widget="monetary"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Transactions" name="transactions">
                            <field name="transaction_ids">
                                <tree editable="bottom"
                                      decoration-success="transaction_type == 'income'"
                                      decoration-danger="transaction_type == 'expense'">
                                    <field name="date"/>
                                    <field name="description"/>
                                    <field name="transaction_type"/>
                                    <field name="amount"/>
                                    <field name="category"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ============================================================ -->
    <!-- education.treasury : Tree View                               -->
    <!-- ============================================================ -->
    <record id="view_education_treasury_tree" model="ir.ui.view">
        <field name="name">education.treasury.tree</field>
        <field name="model">education.treasury</field>
        <field name="arch" type="xml">
            <tree string="Treasuries">
                <field name="name"/>
                <field name="code"/>
                <field name="branch_id"/>
                <field name="balance" widget="monetary" sum="Total Balance"/>
            </tree>
        </field>
    </record>

    <!-- ============================================================ -->
    <!-- education.treasury : Action                                  -->
    <!-- ============================================================ -->
    <record id="action_education_treasury" model="ir.actions.act_window">
        <field name="name">Treasuries</field>
        <field name="res_model">education.treasury</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a new treasury
            </p>
            <p>
                Manage treasury accounts and track financial transactions.
            </p>
        </field>
    </record>

    <!-- ============================================================ -->
    <!-- education.expense : Form View                                -->
    <!-- ============================================================ -->
    <record id="view_education_expense_form" model="ir.ui.view">
        <field name="name">education.expense.form</field>
        <field name="model">education.expense</field>
        <field name="arch" type="xml">
            <form string="Expense">
                <header>
                    <button name="action_approve"
                            string="Approve"
                            type="object"
                            class="btn-primary"
                            invisible="state != 'draft'"/>
                    <button name="action_pay"
                            string="Pay"
                            type="object"
                            class="btn-success"
                            invisible="state != 'approved'"/>
                    <button name="action_cancel"
                            string="Cancel"
                            type="object"
                            class="btn-danger"
                            invisible="state in ('paid', 'cancelled')"/>
                    <field name="state"
                           widget="statusbar"
                           statusbar_visible="draft,approved,paid"/>
                </header>
                <sheet>
                    <group>
                        <group string="Expense Details">
                            <field name="name"/>
                            <field name="date"/>
                            <field name="amount"/>
                            <field name="category"/>
                        </group>
                        <group string="Payment Info">
                            <field name="branch_id"/>
                            <field name="treasury_id"/>
                        </group>
                    </group>
                    <separator/>
                    <group>
                        <field name="notes" placeholder="Additional notes..."/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ============================================================ -->
    <!-- education.expense : Tree View                                -->
    <!-- ============================================================ -->
    <record id="view_education_expense_tree" model="ir.ui.view">
        <field name="name">education.expense.tree</field>
        <field name="model">education.expense</field>
        <field name="arch" type="xml">
            <tree string="Expenses"
                  decoration-success="state == 'paid'"
                  decoration-muted="state == 'cancelled'"
                  decoration-info="state == 'approved'">
                <field name="name"/>
                <field name="date"/>
                <field name="amount" sum="Total"/>
                <field name="category"/>
                <field name="state"
                       widget="badge"
                       decoration-success="state == 'paid'"
                       decoration-info="state == 'approved'"
                       decoration-danger="state == 'cancelled'"/>
            </tree>
        </field>
    </record>

    <!-- ============================================================ -->
    <!-- education.expense : Action                                   -->
    <!-- ============================================================ -->
    <record id="action_education_expense" model="ir.actions.act_window">
        <field name="name">Expenses</field>
        <field name="res_model">education.expense</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Record a new expense
            </p>
            <p>
                Track and manage school expenses with approval workflow.
            </p>
        </field>
    </record>

</odoo>
