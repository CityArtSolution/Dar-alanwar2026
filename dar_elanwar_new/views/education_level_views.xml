<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ==================== Form View ==================== -->
    <record id="view_education_level_form" model="ir.ui.view">
        <field name="name">education.level.form</field>
        <field name="model">education.level</field>
        <field name="arch" type="xml">
            <form string="Level">
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" placeholder="Level Name"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="code"/>
                            <field name="sequence"/>
                        </group>
                        <group>
                            <field name="department_id"/>
                            <field name="active" invisible="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Classes" name="classes">
                            <field name="class_ids">
                                <tree>
                                    <field name="name"/>
                                    <field name="code"/>
                                    <field name="teacher_id"/>
                                    <field name="student_count"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ==================== Tree View ==================== -->
    <record id="view_education_level_tree" model="ir.ui.view">
        <field name="name">education.level.tree</field>
        <field name="model">education.level</field>
        <field name="arch" type="xml">
            <tree string="Levels">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="code"/>
                <field name="department_id"/>
            </tree>
        </field>
    </record>

    <!-- ==================== Action ==================== -->
    <record id="action_education_level" model="ir.actions.act_window">
        <field name="name">Levels</field>
        <field name="res_model">education.level</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a new level
            </p>
            <p>
                Levels define the educational stages within a department,
                such as Grade 1, Grade 2, etc.
            </p>
        </field>
    </record>

</odoo>
