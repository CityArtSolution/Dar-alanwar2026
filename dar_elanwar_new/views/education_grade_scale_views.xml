<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ==================== Form View ==================== -->
    <record id="view_education_grade_scale_form" model="ir.ui.view">
        <field name="name">education.grade.scale.form</field>
        <field name="model">education.grade.scale</field>
        <field name="arch" type="xml">
            <form string="Grade Scale">
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" placeholder="Scale Name"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="code"/>
                        </group>
                        <group>
                            <field name="active" invisible="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Scale Values" name="values">
                            <field name="value_ids">
                                <tree editable="bottom">
                                    <field name="name"/>
                                    <field name="numeric_value"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ==================== Tree View ==================== -->
    <record id="view_education_grade_scale_tree" model="ir.ui.view">
        <field name="name">education.grade.scale.tree</field>
        <field name="model">education.grade.scale</field>
        <field name="arch" type="xml">
            <tree string="Grade Scales">
                <field name="name"/>
                <field name="code"/>
            </tree>
        </field>
    </record>

    <!-- ==================== Action ==================== -->
    <record id="action_education_grade_scale" model="ir.actions.act_window">
        <field name="name">Grade Scales</field>
        <field name="res_model">education.grade.scale</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a new grade scale
            </p>
            <p>
                Grade scales define how student performance is measured,
                e.g. A/B/C/D/F or numeric scales.
            </p>
        </field>
    </record>

</odoo>
