<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ==================== Form View ==================== -->
    <record id="view_education_schedule_form" model="ir.ui.view">
        <field name="name">education.schedule.form</field>
        <field name="model">education.schedule</field>
        <field name="arch" type="xml">
            <form string="Schedule">
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" placeholder="Schedule Name"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="time_from" widget="float_time"/>
                            <field name="time_to" widget="float_time"/>
                        </group>
                        <group>
                            <field name="period"/>
                            <field name="active" invisible="1"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ==================== Tree View ==================== -->
    <record id="view_education_schedule_tree" model="ir.ui.view">
        <field name="name">education.schedule.tree</field>
        <field name="model">education.schedule</field>
        <field name="arch" type="xml">
            <tree string="Schedules">
                <field name="name"/>
                <field name="time_from" widget="float_time"/>
                <field name="time_to" widget="float_time"/>
                <field name="period"/>
            </tree>
        </field>
    </record>

    <!-- ==================== Action ==================== -->
    <record id="action_education_schedule" model="ir.actions.act_window">
        <field name="name">Schedules</field>
        <field name="res_model">education.schedule</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a new schedule
            </p>
            <p>
                Schedules define the time periods for classes, such as
                morning, afternoon, or evening sessions.
            </p>
        </field>
    </record>

</odoo>
