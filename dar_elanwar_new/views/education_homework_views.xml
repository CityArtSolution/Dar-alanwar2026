<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ==================== -->
    <!-- Homework              -->
    <!-- ==================== -->

    <record id="view_education_homework_form" model="ir.ui.view">
        <field name="name">education.homework.form</field>
        <field name="model">education.homework</field>
        <field name="arch" type="xml">
            <form string="Homework">
                <header>
                    <button name="action_publish" string="Publish" type="object"
                            class="btn-primary"
                            invisible="state != 'draft'"/>
                    <button name="action_close" string="Close" type="object"
                            class="btn-warning"
                            invisible="state != 'published'"/>
                    <button name="action_draft" string="Reset to Draft" type="object"
                            invisible="state != 'closed'"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,published,closed"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" placeholder="Homework Title"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="class_id"/>
                            <field name="subject_id"/>
                            <field name="teacher_id"/>
                        </group>
                        <group>
                            <field name="assign_date"/>
                            <field name="due_date"/>
                            <field name="attachment" filename="name"/>
                            <field name="submission_count"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Description">
                            <field name="description" widget="html"/>
                        </page>
                        <page string="Submissions">
                            <field name="submission_ids">
                                <tree string="Submissions">
                                    <field name="student_id"/>
                                    <field name="submission_date"/>
                                    <field name="state" optional="show"/>
                                    <field name="grade" optional="show"/>
                                    <field name="remarks" optional="hide"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_education_homework_tree" model="ir.ui.view">
        <field name="name">education.homework.tree</field>
        <field name="model">education.homework</field>
        <field name="arch" type="xml">
            <tree string="Homework">
                <field name="name"/>
                <field name="class_id"/>
                <field name="subject_id"/>
                <field name="due_date"/>
                <field name="state"/>
                <field name="submission_count"/>
            </tree>
        </field>
    </record>

    <record id="action_education_homework" model="ir.actions.act_window">
        <field name="name">Homework</field>
        <field name="res_model">education.homework</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Assign your first homework!
            </p>
        </field>
    </record>

</odoo>
