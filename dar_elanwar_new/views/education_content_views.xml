<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ==================== -->
    <!-- Content Category      -->
    <!-- ==================== -->

    <record id="view_content_category_form" model="ir.ui.view">
        <field name="name">education.content.category.form</field>
        <field name="model">education.content.category</field>
        <field name="arch" type="xml">
            <form string="Content Category">
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" placeholder="Category Name"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="code"/>
                            <field name="content_type"/>
                        </group>
                        <group>
                            <field name="icon"/>
                            <field name="item_count"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_content_category_tree" model="ir.ui.view">
        <field name="name">education.content.category.tree</field>
        <field name="model">education.content.category</field>
        <field name="arch" type="xml">
            <tree string="Content Categories">
                <field name="name"/>
                <field name="code"/>
                <field name="content_type"/>
                <field name="item_count"/>
            </tree>
        </field>
    </record>

    <record id="action_content_category" model="ir.actions.act_window">
        <field name="name">Content Categories</field>
        <field name="res_model">education.content.category</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first content category!
            </p>
        </field>
    </record>

    <!-- ==================== -->
    <!-- Content Item          -->
    <!-- ==================== -->

    <record id="view_content_item_form" model="ir.ui.view">
        <field name="name">education.content.item.form</field>
        <field name="model">education.content.item</field>
        <field name="arch" type="xml">
            <form string="Content Item">
                <sheet>
                    <field name="thumbnail" widget="image" class="oe_avatar"/>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" placeholder="Content Item Name"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="category_id"/>
                            <field name="content_type"/>
                            <field name="file_url" widget="url"/>
                            <field name="file" filename="name"/>
                        </group>
                        <group>
                            <field name="grade_level_ids" widget="many2many_tags"/>
                            <field name="target_age_min"/>
                            <field name="target_age_max"/>
                            <field name="is_drm_protected"/>
                            <field name="access_count"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Description">
                            <field name="description"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_content_item_tree" model="ir.ui.view">
        <field name="name">education.content.item.tree</field>
        <field name="model">education.content.item</field>
        <field name="arch" type="xml">
            <tree string="Content Items">
                <field name="name"/>
                <field name="category_id"/>
                <field name="content_type"/>
                <field name="access_count"/>
            </tree>
        </field>
    </record>

    <record id="action_content_item" model="ir.actions.act_window">
        <field name="name">Content Items</field>
        <field name="res_model">education.content.item</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Add your first content item!
            </p>
        </field>
    </record>

    <!-- ==================== -->
    <!-- Content Access         -->
    <!-- ==================== -->

    <record id="view_content_access_form" model="ir.ui.view">
        <field name="name">education.content.access.form</field>
        <field name="model">education.content.access</field>
        <field name="arch" type="xml">
            <form string="Content Access">
                <header>
                    <button name="action_revoke" string="Revoke Access" type="object"
                            class="btn-danger"
                            invisible="not is_active"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="student_id"/>
                            <field name="content_item_id"/>
                            <field name="granted_by"/>
                        </group>
                        <group>
                            <field name="granted_date"/>
                            <field name="expiry_date"/>
                            <field name="is_active"/>
                            <field name="revoked_date" invisible="is_active"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_content_access_tree" model="ir.ui.view">
        <field name="name">education.content.access.tree</field>
        <field name="model">education.content.access</field>
        <field name="arch" type="xml">
            <tree string="Content Access">
                <field name="student_id"/>
                <field name="content_item_id"/>
                <field name="granted_date"/>
                <field name="expiry_date"/>
                <field name="is_active"/>
            </tree>
        </field>
    </record>

    <record id="action_content_access" model="ir.actions.act_window">
        <field name="name">Content Access</field>
        <field name="res_model">education.content.access</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Grant content access to a student!
            </p>
        </field>
    </record>

</odoo>
