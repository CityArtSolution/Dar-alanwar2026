<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================ -->
    <!-- education.discount : Form View                               -->
    <!-- ============================================================ -->
    <record id="view_education_discount_form" model="ir.ui.view">
        <field name="name">education.discount.form</field>
        <field name="model">education.discount</field>
        <field name="arch" type="xml">
            <form string="Discount">
                <sheet>
                    <group>
                        <group string="Discount Details">
                            <field name="name"/>
                            <field name="discount_type"/>
                            <field name="value_type"/>
                            <field name="value"/>
                            <field name="department_id"/>
                        </group>
                        <group string="Auto Apply Settings">
                            <field name="auto_apply"/>
                            <field name="min_siblings"
                                   invisible="discount_type != 'sibling'"/>
                            <field name="early_days"
                                   invisible="discount_type != 'early_payment'"/>
                        </group>
                    </group>
                    <separator/>
                    <group>
                        <field name="description" placeholder="Optional description..."/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ============================================================ -->
    <!-- education.discount : Tree View                               -->
    <!-- ============================================================ -->
    <record id="view_education_discount_tree" model="ir.ui.view">
        <field name="name">education.discount.tree</field>
        <field name="model">education.discount</field>
        <field name="arch" type="xml">
            <tree string="Discounts">
                <field name="name"/>
                <field name="discount_type"/>
                <field name="value_type"/>
                <field name="value"/>
                <field name="auto_apply"/>
            </tree>
        </field>
    </record>

    <!-- ============================================================ -->
    <!-- education.discount : Action                                  -->
    <!-- ============================================================ -->
    <record id="action_education_discount" model="ir.actions.act_window">
        <field name="name">Discounts</field>
        <field name="res_model">education.discount</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a new discount
            </p>
            <p>
                Define discount rules for student subscriptions.
            </p>
        </field>
    </record>

</odoo>
