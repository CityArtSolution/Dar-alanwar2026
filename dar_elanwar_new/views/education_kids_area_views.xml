<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ==================== -->
    <!-- Kids Area Service     -->
    <!-- ==================== -->

    <record id="view_kids_area_service_form" model="ir.ui.view">
        <field name="name">education.kids.area.service.form</field>
        <field name="model">education.kids.area.service</field>
        <field name="arch" type="xml">
            <form string="Kids Area Service">
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" placeholder="Service Name"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="activity_type"/>
                            <field name="pricing_type"/>
                            <field name="price"/>
                            <field name="capacity"/>
                        </group>
                        <group>
                            <field name="min_age"/>
                            <field name="max_age"/>
                            <field name="duration_minutes"/>
                            <field name="image" widget="image" class="oe_avatar"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Description">
                            <field name="description" placeholder="Describe this service..."/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_kids_area_service_tree" model="ir.ui.view">
        <field name="name">education.kids.area.service.tree</field>
        <field name="model">education.kids.area.service</field>
        <field name="arch" type="xml">
            <tree string="Kids Area Services">
                <field name="name"/>
                <field name="activity_type"/>
                <field name="pricing_type"/>
                <field name="price"/>
                <field name="capacity"/>
            </tree>
        </field>
    </record>

    <record id="action_kids_area_service" model="ir.actions.act_window">
        <field name="name">Kids Area Services</field>
        <field name="res_model">education.kids.area.service</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first kids area service!
            </p>
        </field>
    </record>

    <!-- ==================== -->
    <!-- Kids Area Slot        -->
    <!-- ==================== -->

    <record id="view_kids_area_slot_form" model="ir.ui.view">
        <field name="name">education.kids.area.slot.form</field>
        <field name="model">education.kids.area.slot</field>
        <field name="arch" type="xml">
            <form string="Kids Area Slot">
                <header>
                    <field name="state" widget="statusbar" statusbar_visible="draft,open,full,closed"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="service_id"/>
                            <field name="date"/>
                            <field name="time_from" widget="float_time"/>
                            <field name="time_to" widget="float_time"/>
                        </group>
                        <group>
                            <field name="supervisor_id"/>
                            <field name="booked_count"/>
                            <field name="available_count"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Bookings">
                            <field name="booking_ids">
                                <tree string="Bookings">
                                    <field name="student_id"/>
                                    <field name="parent_id"/>
                                    <field name="booking_date"/>
                                    <field name="state"/>
                                    <field name="payment_status"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_kids_area_slot_tree" model="ir.ui.view">
        <field name="name">education.kids.area.slot.tree</field>
        <field name="model">education.kids.area.slot</field>
        <field name="arch" type="xml">
            <tree string="Kids Area Slots"
                  decoration-danger="state == 'full'"
                  decoration-success="state == 'available'">
                <field name="service_id"/>
                <field name="date"/>
                <field name="time_from" widget="float_time"/>
                <field name="time_to" widget="float_time"/>
                <field name="booked_count"/>
                <field name="available_count"/>
                <field name="state"/>
            </tree>
        </field>
    </record>

    <record id="action_kids_area_slot" model="ir.actions.act_window">
        <field name="name">Kids Area Slots</field>
        <field name="res_model">education.kids.area.slot</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first kids area slot!
            </p>
        </field>
    </record>

    <!-- ==================== -->
    <!-- Kids Area Booking     -->
    <!-- ==================== -->

    <record id="view_kids_area_booking_form" model="ir.ui.view">
        <field name="name">education.kids.area.booking.form</field>
        <field name="model">education.kids.area.booking</field>
        <field name="arch" type="xml">
            <form string="Kids Area Booking">
                <header>
                    <button name="action_confirm" string="Confirm" type="object"
                            class="btn-primary"
                            invisible="state != 'draft'"/>
                    <button name="action_check_in" string="Check In" type="object"
                            class="btn-primary"
                            invisible="state != 'confirmed'"/>
                    <button name="action_check_out" string="Check Out" type="object"
                            class="btn-primary"
                            invisible="state != 'checked_in'"/>
                    <button name="action_cancel" string="Cancel" type="object"
                            invisible="state in ('checked_out', 'cancelled', 'no_show')"/>
                    <button name="action_no_show" string="No Show" type="object"
                            invisible="state != 'confirmed'"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,confirmed,checked_in,checked_out"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="slot_id"/>
                            <field name="student_id"/>
                            <field name="parent_id"/>
                            <field name="booking_date"/>
                        </group>
                        <group>
                            <field name="amount"/>
                            <field name="payment_status"/>
                            <field name="qr_code" widget="image" class="oe_avatar"/>
                        </group>
                    </group>
                    <group>
                        <field name="notes"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_kids_area_booking_tree" model="ir.ui.view">
        <field name="name">education.kids.area.booking.tree</field>
        <field name="model">education.kids.area.booking</field>
        <field name="arch" type="xml">
            <tree string="Kids Area Bookings">
                <field name="slot_id"/>
                <field name="student_id"/>
                <field name="booking_date"/>
                <field name="state"/>
                <field name="payment_status"/>
            </tree>
        </field>
    </record>

    <record id="action_kids_area_booking" model="ir.actions.act_window">
        <field name="name">Kids Area Bookings</field>
        <field name="res_model">education.kids.area.booking</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first kids area booking!
            </p>
        </field>
    </record>

    <!-- ==================== -->
    <!-- Kids Area Package     -->
    <!-- ==================== -->

    <record id="view_kids_area_package_form" model="ir.ui.view">
        <field name="name">education.kids.area.package.form</field>
        <field name="model">education.kids.area.package</field>
        <field name="arch" type="xml">
            <form string="Kids Area Package">
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" placeholder="Package Name"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="service_ids" widget="many2many_tags"/>
                            <field name="session_count"/>
                        </group>
                        <group>
                            <field name="price"/>
                            <field name="validity_days"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Description">
                            <field name="description" placeholder="Describe this package..."/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_kids_area_package_tree" model="ir.ui.view">
        <field name="name">education.kids.area.package.tree</field>
        <field name="model">education.kids.area.package</field>
        <field name="arch" type="xml">
            <tree string="Kids Area Packages">
                <field name="name"/>
                <field name="session_count"/>
                <field name="price"/>
                <field name="validity_days"/>
            </tree>
        </field>
    </record>

    <record id="action_kids_area_package" model="ir.actions.act_window">
        <field name="name">Kids Area Packages</field>
        <field name="res_model">education.kids.area.package</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first kids area package!
            </p>
        </field>
    </record>

</odoo>
