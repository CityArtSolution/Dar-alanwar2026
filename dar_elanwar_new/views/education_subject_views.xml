<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ==================== Form View ==================== -->
    <record id="view_education_subject_form" model="ir.ui.view">
        <field name="name">education.subject.form</field>
        <field name="model">education.subject</field>
        <field name="arch" type="xml">
            <form string="Subject">
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" placeholder="Subject Name"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="code"/>
                        </group>
                        <group>
                            <field name="department_id"/>
                            <field name="active" invisible="1"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ==================== Tree View ==================== -->
    <record id="view_education_subject_tree" model="ir.ui.view">
        <field name="name">education.subject.tree</field>
        <field name="model">education.subject</field>
        <field name="arch" type="xml">
            <tree string="Subjects">
                <field name="name"/>
                <field name="code"/>
                <field name="department_id"/>
            </tree>
        </field>
    </record>

    <!-- ==================== Action ==================== -->
    <record id="action_education_subject" model="ir.actions.act_window">
        <field name="name">Subjects</field>
        <field name="res_model">education.subject</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a new subject
            </p>
            <p>
                Subjects represent the courses taught within a department.
            </p>
        </field>
    </record>

</odoo>
