<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ==================== -->
    <!-- Leave Reason          -->
    <!-- ==================== -->

    <record id="view_education_leave_reason_form" model="ir.ui.view">
        <field name="name">education.leave.reason.form</field>
        <field name="model">education.leave.reason</field>
        <field name="arch" type="xml">
            <form string="Leave Reason">
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" placeholder="Leave Reason"/>
                        </h1>
                    </div>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_education_leave_reason_tree" model="ir.ui.view">
        <field name="name">education.leave.reason.tree</field>
        <field name="model">education.leave.reason</field>
        <field name="arch" type="xml">
            <tree string="Leave Reasons">
                <field name="name"/>
            </tree>
        </field>
    </record>

    <record id="action_education_leave_reason" model="ir.actions.act_window">
        <field name="name">Leave Reasons</field>
        <field name="res_model">education.leave.reason</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Define your first leave reason!
            </p>
        </field>
    </record>

</odoo>
