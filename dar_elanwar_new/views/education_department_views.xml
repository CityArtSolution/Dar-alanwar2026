<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ==================== Form View ==================== -->
    <record id="view_education_department_form" model="ir.ui.view">
        <field name="name">education.department.form</field>
        <field name="model">education.department</field>
        <field name="arch" type="xml">
            <form string="Department">
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" placeholder="Department Name"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="code"/>
                            <field name="type"/>
                        </group>
                        <group>
                            <field name="branch_id"/>
                            <field name="active" invisible="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Levels" name="levels">
                            <field name="level_ids">
                                <tree editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="name"/>
                                    <field name="code"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Classes" name="classes">
                            <field name="class_ids">
                                <tree>
                                    <field name="name"/>
                                    <field name="code"/>
                                    <field name="level_id"/>
                                    <field name="teacher_id"/>
                                    <field name="student_count"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Subjects" name="subjects">
                            <field name="subject_ids">
                                <tree editable="bottom">
                                    <field name="name"/>
                                    <field name="code"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- ==================== Tree View ==================== -->
    <record id="view_education_department_tree" model="ir.ui.view">
        <field name="name">education.department.tree</field>
        <field name="model">education.department</field>
        <field name="arch" type="xml">
            <tree string="Departments">
                <field name="name"/>
                <field name="code"/>
                <field name="type"/>
                <field name="branch_id"/>
                <field name="student_count"/>
            </tree>
        </field>
    </record>

    <!-- ==================== Search View ==================== -->
    <record id="view_education_department_search" model="ir.ui.view">
        <field name="name">education.department.search</field>
        <field name="model">education.department</field>
        <field name="arch" type="xml">
            <search string="Search Departments">
                <field name="name"/>
                <field name="code"/>
                <field name="branch_id"/>
                <separator/>
                <filter string="Archived" name="inactive" domain="[('active', '=', False)]"/>
                <group expand="0" string="Group By">
                    <filter string="Type" name="group_type" context="{'group_by': 'type'}"/>
                    <filter string="Branch" name="group_branch" context="{'group_by': 'branch_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ==================== Action ==================== -->
    <record id="action_education_department" model="ir.actions.act_window">
        <field name="name">Departments</field>
        <field name="res_model">education.department</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_education_department_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a new department
            </p>
            <p>
                Departments organize your educational institution into sections
                such as Kindergarten, Primary, Quran Memorization, etc.
            </p>
        </field>
    </record>

</odoo>
