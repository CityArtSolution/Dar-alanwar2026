<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================ -->
    <!--               STUDENT ATTENDANCE FORM VIEW                   -->
    <!-- ============================================================ -->

    <record id="view_education_attendance_form" model="ir.ui.view">
        <field name="name">education.attendance.form</field>
        <field name="model">education.attendance</field>
        <field name="arch" type="xml">
            <form string="Student Attendance">
                <header>
                    <button name="action_confirm" type="object" string="Confirm"
                            class="oe_highlight"
                            invisible="state != 'draft'"/>
                    <button name="action_lock" type="object" string="Lock"
                            invisible="state != 'confirmed'"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,confirmed,locked"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box"/>
                    <group>
                        <group string="Session Details">
                            <field name="date"/>
                            <field name="department_id"/>
                            <field name="class_id"/>
                            <field name="branch_id"/>
                        </group>
                        <group string="Statistics">
                            <field name="present_count"/>
                            <field name="absent_count"/>
                            <field name="late_count"/>
                        </group>
                    </group>
                    <div class="oe_right">
                        <button name="action_populate_students" type="object"
                                string="Populate Students"
                                class="btn-primary"
                                invisible="state != 'draft'"
                                icon="fa-users"/>
                    </div>
                    <field name="line_ids">
                        <tree editable="bottom">
                            <field name="student_id"/>
                            <field name="status" widget="selection"/>
                            <field name="check_in_time" widget="float_time"/>
                            <field name="check_out_time" widget="float_time"/>
                            <field name="hours_present" widget="float_time"/>
                            <field name="late_minutes"/>
                        </tree>
                    </field>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ============================================================ -->
    <!--               STUDENT ATTENDANCE TREE VIEW                   -->
    <!-- ============================================================ -->

    <record id="view_education_attendance_tree" model="ir.ui.view">
        <field name="name">education.attendance.tree</field>
        <field name="model">education.attendance</field>
        <field name="arch" type="xml">
            <tree string="Student Attendance">
                <field name="date"/>
                <field name="department_id"/>
                <field name="class_id"/>
                <field name="present_count"/>
                <field name="absent_count"/>
                <field name="state" widget="badge"
                       decoration-info="state == 'draft'"
                       decoration-success="state == 'confirmed'"
                       decoration-muted="state == 'locked'"/>
            </tree>
        </field>
    </record>

    <!-- ============================================================ -->
    <!--              STUDENT ATTENDANCE SEARCH VIEW                  -->
    <!-- ============================================================ -->

    <record id="view_education_attendance_search" model="ir.ui.view">
        <field name="name">education.attendance.search</field>
        <field name="model">education.attendance</field>
        <field name="arch" type="xml">
            <search string="Search Attendance">
                <field name="date"/>
                <field name="department_id"/>
                <field name="class_id"/>
                <separator/>
                <filter name="filter_draft" string="Draft"
                        domain="[('state', '=', 'draft')]"/>
                <filter name="filter_confirmed" string="Confirmed"
                        domain="[('state', '=', 'confirmed')]"/>
                <filter name="filter_locked" string="Locked"
                        domain="[('state', '=', 'locked')]"/>
                <separator/>
                <filter name="filter_today" string="Today"
                        domain="[('date', '=', context_today().strftime('%Y-%m-%d'))]"/>
                <filter name="filter_this_week" string="This Week"
                        domain="[('date', '>=', (context_today() - datetime.timedelta(days=context_today().weekday())).strftime('%Y-%m-%d'))]"/>
                <filter name="filter_this_month" string="This Month"
                        domain="[('date', '>=', context_today().strftime('%Y-%m-01'))]"/>
                <separator/>
                <group expand="0" string="Group By">
                    <filter name="group_department" string="Department"
                            context="{'group_by': 'department_id'}"/>
                    <filter name="group_class" string="Class"
                            context="{'group_by': 'class_id'}"/>
                    <filter name="group_date" string="Date"
                            context="{'group_by': 'date'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ============================================================ -->
    <!--              STUDENT ATTENDANCE ACTION                       -->
    <!-- ============================================================ -->

    <record id="action_education_attendance" model="ir.actions.act_window">
        <field name="name">Student Attendance</field>
        <field name="res_model">education.attendance</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_education_attendance_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a new attendance session
            </p>
        </field>
    </record>

</odoo>
