<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ==================== -->
    <!-- Announcement          -->
    <!-- ==================== -->

    <record id="view_education_announcement_form" model="ir.ui.view">
        <field name="name">education.announcement.form</field>
        <field name="model">education.announcement</field>
        <field name="arch" type="xml">
            <form string="Announcement">
                <sheet>
                    <div class="oe_title">
                        <label for="title"/>
                        <h1>
                            <field name="title" placeholder="Announcement Title"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="date"/>
                            <field name="target_type"/>
                            <field name="department_id" invisible="target_type != 'department'"/>
                            <field name="class_id" invisible="target_type != 'class'"/>
                            <field name="branch_id" invisible="target_type != 'branch'"/>
                        </group>
                        <group>
                            <field name="priority"/>
                            <field name="is_published"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Content">
                            <field name="content" widget="html"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_education_announcement_tree" model="ir.ui.view">
        <field name="name">education.announcement.tree</field>
        <field name="model">education.announcement</field>
        <field name="arch" type="xml">
            <tree string="Announcements">
                <field name="title"/>
                <field name="date"/>
                <field name="target_type"/>
                <field name="priority"/>
                <field name="is_published"/>
            </tree>
        </field>
    </record>

    <record id="action_education_announcement" model="ir.actions.act_window">
        <field name="name">Announcements</field>
        <field name="res_model">education.announcement</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first announcement!
            </p>
        </field>
    </record>

    <!-- ==================== -->
    <!-- Message               -->
    <!-- ==================== -->

    <record id="view_education_message_form" model="ir.ui.view">
        <field name="name">education.message.form</field>
        <field name="model">education.message</field>
        <field name="arch" type="xml">
            <form string="Message">
                <sheet>
                    <div class="oe_title">
                        <label for="subject"/>
                        <h1>
                            <field name="subject" placeholder="Message Subject"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="date"/>
                            <field name="sender_id"/>
                            <field name="recipient_type"/>
                        </group>
                        <group>
                            <field name="parent_id" invisible="recipient_type != 'parent'"/>
                            <field name="employee_id" invisible="recipient_type != 'employee'"/>
                            <field name="user_id" invisible="recipient_type != 'user'"/>
                            <field name="is_read"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Body">
                            <field name="body" widget="html"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_education_message_tree" model="ir.ui.view">
        <field name="name">education.message.tree</field>
        <field name="model">education.message</field>
        <field name="arch" type="xml">
            <tree string="Messages">
                <field name="subject"/>
                <field name="date"/>
                <field name="sender_id"/>
                <field name="is_read"/>
            </tree>
        </field>
    </record>

    <record id="action_education_message" model="ir.actions.act_window">
        <field name="name">Messages</field>
        <field name="res_model">education.message</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Send your first message!
            </p>
        </field>
    </record>

    <!-- ==================== -->
    <!-- Support Ticket        -->
    <!-- ==================== -->

    <record id="view_education_support_ticket_form" model="ir.ui.view">
        <field name="name">education.support.ticket.form</field>
        <field name="model">education.support.ticket</field>
        <field name="arch" type="xml">
            <form string="Support Ticket">
                <header>
                    <button name="action_assign" string="Assign" type="object"
                            class="btn-primary"
                            invisible="state != 'new'"/>
                    <button name="action_in_progress" string="In Progress" type="object"
                            class="btn-primary"
                            invisible="state != 'assigned'"/>
                    <button name="action_resolve" string="Resolve" type="object"
                            class="btn-success"
                            invisible="state != 'in_progress'"/>
                    <button name="action_close" string="Close" type="object"
                            invisible="state != 'resolved'"/>
                    <button name="action_cancel" string="Cancel" type="object"
                            class="btn-danger"
                            invisible="state in ('resolved', 'closed', 'cancelled')"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="new,assigned,in_progress,resolved,closed"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" placeholder="Ticket Reference"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="subject"/>
                            <field name="parent_id"/>
                            <field name="student_id"/>
                            <field name="category"/>
                        </group>
                        <group>
                            <field name="priority"/>
                            <field name="assigned_to"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Description">
                            <field name="description"/>
                        </page>
                        <page string="Resolution">
                            <field name="resolution"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_education_support_ticket_tree" model="ir.ui.view">
        <field name="name">education.support.ticket.tree</field>
        <field name="model">education.support.ticket</field>
        <field name="arch" type="xml">
            <tree string="Support Tickets">
                <field name="name"/>
                <field name="subject"/>
                <field name="category"/>
                <field name="priority"/>
                <field name="state"/>
            </tree>
        </field>
    </record>

    <record id="action_education_support_ticket" model="ir.actions.act_window">
        <field name="name">Support Tickets</field>
        <field name="res_model">education.support.ticket</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No support tickets yet!
            </p>
        </field>
    </record>

</odoo>
