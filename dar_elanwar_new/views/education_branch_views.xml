<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ==================== Form View ==================== -->
    <record id="view_education_branch_form" model="ir.ui.view">
        <field name="name">education.branch.form</field>
        <field name="model">education.branch</field>
        <field name="arch" type="xml">
            <form string="Branch">
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button class="oe_stat_button" icon="fa-graduation-cap"
                                type="object" name="action_view_students">
                            <field name="student_count" widget="statinfo" string="Students"/>
                        </button>
                        <button class="oe_stat_button" icon="fa-users"
                                type="object" name="action_view_employees">
                            <field name="employee_count" widget="statinfo" string="Employees"/>
                        </button>
                    </div>
                    <widget name="web_ribbon" title="Main Branch"
                            invisible="not is_main"/>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" placeholder="Branch Name"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="code"/>
                            <field name="is_main"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                        <group>
                            <field name="phone" widget="phone"/>
                            <field name="email" widget="email"/>
                        </group>
                    </group>
                    <group>
                        <field name="address" placeholder="Full address..."/>
                    </group>
                    <field name="active" invisible="1"/>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- ==================== Tree View ==================== -->
    <record id="view_education_branch_tree" model="ir.ui.view">
        <field name="name">education.branch.tree</field>
        <field name="model">education.branch</field>
        <field name="arch" type="xml">
            <tree string="Branches" decoration-bf="is_main">
                <field name="name"/>
                <field name="code"/>
                <field name="phone"/>
                <field name="is_main"/>
            </tree>
        </field>
    </record>

    <!-- ==================== Search View ==================== -->
    <record id="view_education_branch_search" model="ir.ui.view">
        <field name="name">education.branch.search</field>
        <field name="model">education.branch</field>
        <field name="arch" type="xml">
            <search string="Search Branches">
                <field name="name"/>
                <field name="code"/>
                <separator/>
                <filter string="Main Branch" name="main" domain="[('is_main', '=', True)]"/>
                <filter string="Archived" name="inactive" domain="[('active', '=', False)]"/>
            </search>
        </field>
    </record>

    <!-- ==================== Action ==================== -->
    <record id="action_education_branch" model="ir.actions.act_window">
        <field name="name">Branches</field>
        <field name="res_model">education.branch</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_education_branch_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a new branch
            </p>
            <p>
                Branches represent the physical locations of your
                educational institution.
            </p>
        </field>
    </record>

</odoo>
