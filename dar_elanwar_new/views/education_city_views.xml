<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ==================== -->
    <!-- City                  -->
    <!-- ==================== -->

    <record id="view_education_city_form" model="ir.ui.view">
        <field name="name">education.city.form</field>
        <field name="model">education.city</field>
        <field name="arch" type="xml">
            <form string="City">
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" placeholder="City Name"/>
                        </h1>
                    </div>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_education_city_tree" model="ir.ui.view">
        <field name="name">education.city.tree</field>
        <field name="model">education.city</field>
        <field name="arch" type="xml">
            <tree string="Cities">
                <field name="name"/>
            </tree>
        </field>
    </record>

    <record id="action_education_city" model="ir.actions.act_window">
        <field name="name">Cities</field>
        <field name="res_model">education.city</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Add your first city!
            </p>
        </field>
    </record>

</odoo>
