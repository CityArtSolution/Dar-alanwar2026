<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================ -->
    <!--                    STUDENT FORM VIEW                         -->
    <!-- ============================================================ -->
    <record id="view_education_student_form" model="ir.ui.view">
        <field name="name">education.student.form</field>
        <field name="model">education.student</field>
        <field name="arch" type="xml">
            <form string="Student">
                <header>
                    <button name="action_submit"
                            string="Submit"
                            type="object"
                            class="btn-primary"
                            invisible="state != 'draft'"/>
                    <button name="action_enroll"
                            string="Enroll"
                            type="object"
                            class="btn-primary"
                            invisible="state != 'submitted'"/>
                    <button name="action_suspend"
                            string="Suspend"
                            type="object"
                            class="btn-warning"
                            invisible="state not in ('enrolled',)"/>
                    <button name="action_archive"
                            string="Archive"
                            type="object"
                            class="btn-danger"
                            invisible="state not in ('enrolled', 'suspended')"/>
                    <button name="action_reactivate"
                            string="Reactivate"
                            type="object"
                            class="btn-success"
                            invisible="state not in ('archived', 'suspended')"/>
                    <field name="state"
                           widget="statusbar"
                           statusbar_visible="draft,submitted,enrolled"/>
                </header>

                <!-- Smart Buttons -->
                <div class="oe_button_box" name="button_box">
                    <button name="action_view_balance"
                            type="object"
                            class="oe_stat_button"
                            icon="fa-money">
                        <field name="balance_due"
                               string="Balance Due"
                               widget="statinfo"/>
                    </button>
                    <button name="action_view_installments"
                            type="object"
                            class="oe_stat_button"
                            icon="fa-list">
                        <field name="installment_count"
                               string="Installments"
                               widget="statinfo"/>
                    </button>
                    <button name="action_view_goals"
                            type="object"
                            class="oe_stat_button"
                            icon="fa-bullseye">
                        <field name="goal_count"
                               string="Goals"
                               widget="statinfo"/>
                    </button>
                    <button name="action_view_attendance"
                            type="object"
                            class="oe_stat_button"
                            icon="fa-calendar-check-o">
                        <field name="attendance_rate"
                               string="Attendance Rate"
                               widget="statinfo"/>
                    </button>
                </div>

                <sheet>
                    <!-- Top Section: Photo + Key Fields -->
                    <group>
                        <field name="photo" widget="image" class="oe_avatar"
                               options="{'size': [128, 128]}"/>
                        <div class="oe_title">
                            <label for="name"/>
                            <h1>
                                <field name="name" placeholder="Student Name"/>
                            </h1>
                            <label for="arabic_name"/>
                            <h2>
                                <field name="arabic_name" placeholder="Arabic Name"/>
                            </h2>
                        </div>
                    </group>
                    <group>
                        <group>
                            <field name="code" readonly="1"/>
                        </group>
                        <group>
                            <field name="state" readonly="1"/>
                        </group>
                    </group>

                    <!-- Main Info Groups -->
                    <group col="2">
                        <!-- Left Column: Personal Info -->
                        <group string="Personal Information">
                            <field name="national_id"/>
                            <field name="birthdate"/>
                            <field name="gender"/>
                            <field name="nationality"/>
                            <field name="religion"/>
                            <field name="birth_place"/>
                            <field name="birth_order"/>
                            <field name="admission_time"/>
                            <field name="blood_type"/>
                        </group>
                        <!-- Right Column: Academic Info -->
                        <group string="Academic Information">
                            <field name="department_id"/>
                            <field name="class_id"/>
                            <field name="level_id"/>
                            <field name="enrollment_date"/>
                            <field name="period"/>
                            <field name="academic_year_id"/>
                            <field name="branch_id"/>
                            <field name="source_id"/>
                        </group>
                    </group>

                    <!-- Notebook Tabs -->
                    <notebook>
                        <!-- Guardian Info Tab -->
                        <page string="Guardian Info" name="guardian_info">
                            <group col="2">
                                <group string="Father Information">
                                    <field name="father_id"/>
                                    <field name="father_id" invisible="1"/>
                                    <!-- Related father fields rendered via parent record -->
                                </group>
                                <group string="Mother Information">
                                    <field name="mother_id"/>
                                    <field name="mother_id" invisible="1"/>
                                    <!-- Related mother fields rendered via parent record -->
                                </group>
                            </group>
                        </page>

                        <!-- Study Plans Tab -->
                        <page string="Study Plans" name="study_plans">
                            <group>
                                <p class="text-muted">
                                    Subject assignments and study plans will be configured here.
                                </p>
                            </group>
                        </page>

                        <!-- Financial Plans Tab -->
                        <page string="Financial Plans" name="financial_plans">
                            <field name="subscription_ids">
                                <tree editable="bottom">
                                    <field name="type_id"/>
                                    <field name="status"/>
                                    <field name="total_amount" sum="Total"/>
                                    <field name="discount_amount" sum="Discount"/>
                                    <field name="net_amount" sum="Net"/>
                                    <field name="paid_amount" sum="Paid"/>
                                    <field name="remaining_amount" sum="Remaining"/>
                                </tree>
                            </field>
                        </page>

                        <!-- Medical Info Tab -->
                        <page string="Medical Info" name="medical_info">
                            <group>
                                <group>
                                    <field name="blood_type"/>
                                    <field name="allergies"/>
                                </group>
                                <group>
                                    <field name="medical_notes" widget="html"/>
                                </group>
                            </group>
                        </page>

                        <!-- Siblings Tab -->
                        <page string="Siblings" name="siblings">
                            <field name="sibling_ids">
                                <tree>
                                    <field name="name"/>
                                    <field name="code"/>
                                    <field name="class_id"/>
                                    <field name="state"/>
                                </tree>
                            </field>
                        </page>

                        <!-- Notes Tab -->
                        <page string="Notes" name="notes">
                            <field name="note_ids">
                                <tree editable="bottom">
                                    <field name="date"/>
                                    <field name="subject"/>
                                    <field name="note"/>
                                    <field name="user_id"/>
                                </tree>
                            </field>
                        </page>

                        <!-- Authorized Pickup Tab -->
                        <page string="Authorized Pickup" name="authorized_pickup">
                            <field name="authorized_pickup_ids">
                                <tree editable="bottom">
                                    <field name="name"/>
                                    <field name="relation"/>
                                    <field name="phone"/>
                                    <field name="national_id"/>
                                </tree>
                            </field>
                        </page>

                        <!-- Archive History Tab -->
                        <page string="Archive History" name="archive_history">
                            <field name="archive_ids">
                                <tree>
                                    <field name="date"/>
                                    <field name="reason"/>
                                    <field name="user_id"/>
                                    <field name="notes"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>

                <!-- Chatter -->
                <chatter/>
            </form>
        </field>
    </record>

    <!-- ============================================================ -->
    <!--                    STUDENT LIST VIEW                         -->
    <!-- ============================================================ -->
    <record id="view_education_student_tree" model="ir.ui.view">
        <field name="name">education.student.tree</field>
        <field name="model">education.student</field>
        <field name="arch" type="xml">
            <tree string="Students"
                  decoration-muted="state == 'archived'"
                  decoration-warning="state == 'suspended'"
                  decoration-success="state == 'enrolled'"
                  multi_edit="1">
                <field name="code"/>
                <field name="name"/>
                <field name="arabic_name"/>
                <field name="department_id"/>
                <field name="class_id"/>
                <field name="state"
                       widget="badge"
                       decoration-info="state == 'draft'"
                       decoration-warning="state == 'submitted'"
                       decoration-success="state == 'enrolled'"
                       decoration-danger="state == 'archived'"
                       decoration-muted="state == 'suspended'"/>
                <field name="branch_id"/>
            </tree>
        </field>
    </record>

    <!-- ============================================================ -->
    <!--                    STUDENT SEARCH VIEW                       -->
    <!-- ============================================================ -->
    <record id="view_education_student_search" model="ir.ui.view">
        <field name="name">education.student.search</field>
        <field name="model">education.student</field>
        <field name="arch" type="xml">
            <search string="Search Students">
                <field name="name"
                       string="Student"
                       filter_domain="['|', '|', ('name', 'ilike', self), ('arabic_name', 'ilike', self), ('code', 'ilike', self)]"/>
                <field name="department_id"/>
                <field name="class_id"/>
                <field name="branch_id"/>
                <separator/>
                <filter name="filter_enrolled"
                        string="Enrolled"
                        domain="[('state', '=', 'enrolled')]"/>
                <filter name="filter_draft"
                        string="Draft"
                        domain="[('state', '=', 'draft')]"/>
                <filter name="filter_archived"
                        string="Archived"
                        domain="[('state', '=', 'archived')]"/>
                <filter name="filter_suspended"
                        string="Suspended"
                        domain="[('state', '=', 'suspended')]"/>
                <separator/>
                <filter name="filter_department"
                        string="Department"
                        context="{'group_by': 'department_id'}"/>
                <filter name="filter_class"
                        string="Class"
                        context="{'group_by': 'class_id'}"/>
                <separator/>
                <group expand="0" string="Group By">
                    <filter name="group_state"
                            string="State"
                            context="{'group_by': 'state'}"/>
                    <filter name="group_department"
                            string="Department"
                            context="{'group_by': 'department_id'}"/>
                    <filter name="group_class"
                            string="Class"
                            context="{'group_by': 'class_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ============================================================ -->
    <!--                    STUDENT ACTION                            -->
    <!-- ============================================================ -->
    <record id="action_education_student" model="ir.actions.act_window">
        <field name="name">Students</field>
        <field name="res_model">education.student</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_education_student_search"/>
        <field name="context">{'search_default_filter_enrolled': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a new student record
            </p>
            <p>
                Register new students and manage their academic and financial information.
            </p>
        </field>
    </record>

</odoo>
