<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ==================== -->
    <!-- Enrollment Source     -->
    <!-- ==================== -->

    <record id="view_education_enrollment_source_form" model="ir.ui.view">
        <field name="name">education.enrollment.source.form</field>
        <field name="model">education.enrollment.source</field>
        <field name="arch" type="xml">
            <form string="Enrollment Source">
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" placeholder="Source Name"/>
                        </h1>
                    </div>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_education_enrollment_source_tree" model="ir.ui.view">
        <field name="name">education.enrollment.source.tree</field>
        <field name="model">education.enrollment.source</field>
        <field name="arch" type="xml">
            <tree string="Enrollment Sources">
                <field name="name"/>
            </tree>
        </field>
    </record>

    <record id="action_education_enrollment_source" model="ir.actions.act_window">
        <field name="name">Enrollment Sources</field>
        <field name="res_model">education.enrollment.source</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Define your first enrollment source!
            </p>
        </field>
    </record>

</odoo>
