<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================ -->
    <!-- education.payment : Form View                                -->
    <!-- ============================================================ -->
    <record id="view_education_payment_form" model="ir.ui.view">
        <field name="name">education.payment.form</field>
        <field name="model">education.payment</field>
        <field name="arch" type="xml">
            <form string="Payment">
                <sheet>
                    <group>
                        <group string="Payment Info">
                            <field name="installment_id"/>
                            <field name="student_id"/>
                            <field name="date"/>
                            <field name="amount"/>
                        </group>
                        <group string="Additional Details">
                            <field name="payment_method"/>
                            <field name="received_by"/>
                            <field name="reference"/>
                        </group>
                    </group>
                    <separator/>
                    <group>
                        <field name="notes" placeholder="Additional notes..."/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ============================================================ -->
    <!-- education.payment : Tree View                                -->
    <!-- ============================================================ -->
    <record id="view_education_payment_tree" model="ir.ui.view">
        <field name="name">education.payment.tree</field>
        <field name="model">education.payment</field>
        <field name="arch" type="xml">
            <tree string="Payments">
                <field name="date"/>
                <field name="student_id"/>
                <field name="amount" sum="Total"/>
                <field name="payment_method"/>
                <field name="received_by"/>
            </tree>
        </field>
    </record>

    <!-- ============================================================ -->
    <!-- education.payment : Action                                   -->
    <!-- ============================================================ -->
    <record id="action_education_payment" model="ir.actions.act_window">
        <field name="name">Payments</field>
        <field name="res_model">education.payment</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Register a new payment
            </p>
            <p>
                Record payments received from students for their installments.
            </p>
        </field>
    </record>

    <!-- ============================================================ -->
    <!-- education.payment.receipt : Form View                        -->
    <!-- ============================================================ -->
    <record id="view_education_payment_receipt_form" model="ir.ui.view">
        <field name="name">education.payment.receipt.form</field>
        <field name="model">education.payment.receipt</field>
        <field name="arch" type="xml">
            <form string="Payment Receipt">
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="receipt_number" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="student_id"/>
                            <field name="date"/>
                        </group>
                        <group>
                            <field name="total_amount"/>
                        </group>
                    </group>
                    <separator/>
                    <group>
                        <field name="notes" placeholder="Receipt notes..."/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ============================================================ -->
    <!-- education.payment.receipt : Tree View                        -->
    <!-- ============================================================ -->
    <record id="view_education_payment_receipt_tree" model="ir.ui.view">
        <field name="name">education.payment.receipt.tree</field>
        <field name="model">education.payment.receipt</field>
        <field name="arch" type="xml">
            <tree string="Payment Receipts">
                <field name="receipt_number"/>
                <field name="student_id"/>
                <field name="date"/>
                <field name="total_amount" sum="Total"/>
            </tree>
        </field>
    </record>

    <!-- ============================================================ -->
    <!-- education.payment.receipt : Action                           -->
    <!-- ============================================================ -->
    <record id="action_education_payment_receipt" model="ir.actions.act_window">
        <field name="name">Payment Receipts</field>
        <field name="res_model">education.payment.receipt</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No payment receipts yet
            </p>
            <p>
                Payment receipts are generated when payments are recorded.
            </p>
        </field>
    </record>

    <!-- ============================================================ -->
    <!-- education.payment.plan : Form View                           -->
    <!-- ============================================================ -->
    <record id="view_education_payment_plan_form" model="ir.ui.view">
        <field name="name">education.payment.plan.form</field>
        <field name="model">education.payment.plan</field>
        <field name="arch" type="xml">
            <form string="Payment Plan">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                        </group>
                        <group>
                            <field name="installment_count"/>
                            <field name="interval_months"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ============================================================ -->
    <!-- education.payment.plan : Tree View                           -->
    <!-- ============================================================ -->
    <record id="view_education_payment_plan_tree" model="ir.ui.view">
        <field name="name">education.payment.plan.tree</field>
        <field name="model">education.payment.plan</field>
        <field name="arch" type="xml">
            <tree string="Payment Plans">
                <field name="name"/>
                <field name="installment_count"/>
                <field name="interval_months"/>
            </tree>
        </field>
    </record>

    <!-- ============================================================ -->
    <!-- education.payment.plan : Action                              -->
    <!-- ============================================================ -->
    <record id="action_education_payment_plan" model="ir.actions.act_window">
        <field name="name">Payment Plans</field>
        <field name="res_model">education.payment.plan</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a new payment plan
            </p>
            <p>
                Define payment plans with installment count and intervals.
            </p>
        </field>
    </record>

    <!-- ============================================================ -->
    <!-- education.subscription.type : Form View                      -->
    <!-- ============================================================ -->
    <record id="view_education_subscription_type_form" model="ir.ui.view">
        <field name="name">education.subscription.type.form</field>
        <field name="model">education.subscription.type</field>
        <field name="arch" type="xml">
            <form string="Subscription Type">
                <sheet>
                    <group>
                        <group string="General">
                            <field name="name"/>
                            <field name="code"/>
                            <field name="department_id"/>
                            <field name="level_id"/>
                        </group>
                        <group string="Financial">
                            <field name="amount"/>
                            <field name="payment_plan_id"/>
                        </group>
                    </group>
                    <group>
                        <field name="discount_ids" widget="many2many_tags"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ============================================================ -->
    <!-- education.subscription.type : Tree View                      -->
    <!-- ============================================================ -->
    <record id="view_education_subscription_type_tree" model="ir.ui.view">
        <field name="name">education.subscription.type.tree</field>
        <field name="model">education.subscription.type</field>
        <field name="arch" type="xml">
            <tree string="Subscription Types">
                <field name="name"/>
                <field name="code"/>
                <field name="department_id"/>
                <field name="amount"/>
            </tree>
        </field>
    </record>

    <!-- ============================================================ -->
    <!-- education.subscription.type : Action                         -->
    <!-- ============================================================ -->
    <record id="action_education_subscription_type" model="ir.actions.act_window">
        <field name="name">Subscription Types</field>
        <field name="res_model">education.subscription.type</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a new subscription type
            </p>
            <p>
                Define subscription types with pricing and payment plans.
            </p>
        </field>
    </record>

</odoo>
