<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ==================== Inherit Settings Form ==================== -->
    <record id="view_res_config_settings_form_dar_elanwar" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.dar_elanwar</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <app data-string="Education" string="Education" groups="base.group_system">
                    <!-- Default Settings -->
                    <block title="Default Settings">
                        <setting string="Default Branch"
                                 help="Set the default branch for new student records.">
                            <field name="default_branch_id"/>
                        </setting>
                        <setting string="Default Academic Year"
                                 help="Set the default academic year for new enrollments.">
                            <field name="default_academic_year_id"/>
                        </setting>
                    </block>

                    <!-- Code Prefixes -->
                    <block title="Code Prefixes">
                        <setting string="Student Code Prefix"
                                 help="Prefix used when auto-generating student codes.">
                            <field name="student_code_prefix"/>
                        </setting>
                        <setting string="Employee Code Prefix"
                                 help="Prefix used when auto-generating employee codes.">
                            <field name="employee_code_prefix"/>
                        </setting>
                        <setting string="Admission Code Prefix"
                                 help="Prefix used when auto-generating admission codes.">
                            <field name="admission_code_prefix"/>
                        </setting>
                    </block>

                    <!-- Feature Toggles -->
                    <block title="Features">
                        <setting help="Enable the Kids Area module for tracking children in play areas.">
                            <field name="enable_kids_area"/>
                        </setting>
                        <setting help="Enable Content Access for digital resources and learning materials.">
                            <field name="enable_content_access"/>
                        </setting>
                        <setting help="Enable Transportation management for student pickup and drop-off.">
                            <field name="enable_transportation"/>
                        </setting>
                        <setting help="Enable Parent Portal so parents can view student information online.">
                            <field name="enable_parent_portal"/>
                        </setting>
                    </block>

                    <!-- Automation Settings -->
                    <block title="Automation">
                        <setting help="Automatically generate invoices when installments are due.">
                            <field name="auto_generate_invoices"/>
                        </setting>
                        <setting help="Automatically apply sibling discounts when enrolling siblings.">
                            <field name="auto_apply_sibling_discount"/>
                        </setting>
                    </block>
                </app>
            </xpath>
        </field>
    </record>

    <!-- ==================== Action ==================== -->
    <record id="action_education_settings" model="ir.actions.act_window">
        <field name="name">Education Settings</field>
        <field name="res_model">res.config.settings</field>
        <field name="view_mode">form</field>
        <field name="target">inline</field>
        <field name="context">{'module': 'dar_elanwar'}</field>
    </record>

</odoo>
