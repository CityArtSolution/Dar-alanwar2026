<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================ -->
    <!--                   EMPLOYEE CATEGORY VIEWS                    -->
    <!-- ============================================================ -->

    <record id="view_education_employee_category_tree" model="ir.ui.view">
        <field name="name">education.employee.category.tree</field>
        <field name="model">education.employee.category</field>
        <field name="arch" type="xml">
            <tree string="Employee Categories">
                <field name="code"/>
                <field name="name"/>
            </tree>
        </field>
    </record>

    <record id="view_education_employee_category_form" model="ir.ui.view">
        <field name="name">education.employee.category.form</field>
        <field name="model">education.employee.category</field>
        <field name="arch" type="xml">
            <form string="Employee Category">
                <sheet>
                    <group>
                        <field name="code"/>
                        <field name="name"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_education_employee_category" model="ir.actions.act_window">
        <field name="name">Employee Categories</field>
        <field name="res_model">education.employee.category</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a new employee category
            </p>
        </field>
    </record>

    <!-- ============================================================ -->
    <!--                   EMPLOYEE SALARY VIEWS                      -->
    <!-- ============================================================ -->

    <record id="view_education_employee_salary_tree" model="ir.ui.view">
        <field name="name">education.employee.salary.tree</field>
        <field name="model">education.employee.salary</field>
        <field name="arch" type="xml">
            <tree string="Employee Salaries">
                <field name="employee_id"/>
                <field name="month"/>
                <field name="year"/>
                <field name="basic_salary"/>
                <field name="bonuses"/>
                <field name="deductions"/>
                <field name="loan_deduction"/>
                <field name="net_salary"/>
                <field name="state" widget="badge"
                       decoration-info="state == 'draft'"
                       decoration-success="state == 'paid'"
                       decoration-warning="state == 'confirmed'"
                       decoration-danger="state == 'cancelled'"/>
            </tree>
        </field>
    </record>

    <record id="view_education_employee_salary_form" model="ir.ui.view">
        <field name="name">education.employee.salary.form</field>
        <field name="model">education.employee.salary</field>
        <field name="arch" type="xml">
            <form string="Employee Salary">
                <header>
                    <button name="action_confirm" type="object" string="Confirm"
                            class="oe_highlight"
                            invisible="state != 'draft'"/>
                    <button name="action_pay" type="object" string="Pay"
                            class="oe_highlight"
                            invisible="state != 'confirmed'"/>
                    <button name="action_cancel" type="object" string="Cancel"
                            invisible="state in ('paid', 'cancelled')"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,confirmed,paid"/>
                </header>
                <sheet>
                    <group>
                        <group string="Employee Info">
                            <field name="employee_id"/>
                            <field name="month"/>
                            <field name="year"/>
                        </group>
                        <group string="Salary Details">
                            <field name="basic_salary"/>
                            <field name="bonuses"/>
                            <field name="deductions"/>
                            <field name="loan_deduction"/>
                            <field name="net_salary"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_education_employee_salary" model="ir.actions.act_window">
        <field name="name">Employee Salaries</field>
        <field name="res_model">education.employee.salary</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a new salary record
            </p>
        </field>
    </record>

    <!-- ============================================================ -->
    <!--                 EMPLOYEE ATTENDANCE VIEWS                    -->
    <!-- ============================================================ -->

    <record id="view_education_employee_attendance_tree" model="ir.ui.view">
        <field name="name">education.employee.attendance.tree</field>
        <field name="model">education.employee.attendance</field>
        <field name="arch" type="xml">
            <tree string="Employee Attendance">
                <field name="employee_id"/>
                <field name="date"/>
                <field name="check_in" widget="float_time"/>
                <field name="check_out" widget="float_time"/>
                <field name="worked_hours" widget="float_time"/>
                <field name="status" widget="badge"
                       decoration-success="status == 'present'"
                       decoration-danger="status == 'absent'"
                       decoration-warning="status == 'late'"/>
            </tree>
        </field>
    </record>

    <record id="view_education_employee_attendance_form" model="ir.ui.view">
        <field name="name">education.employee.attendance.form</field>
        <field name="model">education.employee.attendance</field>
        <field name="arch" type="xml">
            <form string="Employee Attendance">
                <sheet>
                    <group>
                        <group string="Employee">
                            <field name="employee_id"/>
                            <field name="date"/>
                        </group>
                        <group string="Time">
                            <field name="check_in" widget="float_time"/>
                            <field name="check_out" widget="float_time"/>
                            <field name="worked_hours" widget="float_time"/>
                            <field name="status"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_education_employee_attendance" model="ir.actions.act_window">
        <field name="name">Employee Attendance</field>
        <field name="res_model">education.employee.attendance</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No employee attendance records found
            </p>
        </field>
    </record>

    <!-- ============================================================ -->
    <!--                    EMPLOYEE LOAN VIEWS                       -->
    <!-- ============================================================ -->

    <record id="view_education_employee_loan_tree" model="ir.ui.view">
        <field name="name">education.employee.loan.tree</field>
        <field name="model">education.employee.loan</field>
        <field name="arch" type="xml">
            <tree string="Employee Loans">
                <field name="employee_id"/>
                <field name="amount"/>
                <field name="date"/>
                <field name="repayment_months"/>
                <field name="monthly_deduction"/>
                <field name="total_paid"/>
                <field name="remaining"/>
                <field name="status" widget="badge"
                       decoration-info="status == 'draft'"
                       decoration-success="status == 'paid'"
                       decoration-warning="status == 'approved'"
                       decoration-danger="status == 'rejected'"/>
            </tree>
        </field>
    </record>

    <record id="view_education_employee_loan_form" model="ir.ui.view">
        <field name="name">education.employee.loan.form</field>
        <field name="model">education.employee.loan</field>
        <field name="arch" type="xml">
            <form string="Employee Loan">
                <header>
                    <button name="action_approve" type="object" string="Approve"
                            class="oe_highlight"
                            invisible="status != 'draft'"/>
                    <button name="action_mark_paid" type="object" string="Mark Paid"
                            class="oe_highlight"
                            invisible="status != 'approved'"/>
                    <field name="status" widget="statusbar"
                           statusbar_visible="draft,approved,paid"/>
                </header>
                <sheet>
                    <group>
                        <group string="Loan Info">
                            <field name="employee_id"/>
                            <field name="amount"/>
                            <field name="date"/>
                        </group>
                        <group string="Repayment">
                            <field name="repayment_months"/>
                            <field name="monthly_deduction"/>
                            <field name="total_paid"/>
                            <field name="remaining"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_education_employee_loan" model="ir.actions.act_window">
        <field name="name">Employee Loans</field>
        <field name="res_model">education.employee.loan</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a new employee loan
            </p>
        </field>
    </record>

    <!-- ============================================================ -->
    <!--                      EMPLOYEE VIEWS                          -->
    <!-- ============================================================ -->

    <record id="view_education_employee_form" model="ir.ui.view">
        <field name="name">education.employee.form</field>
        <field name="model">education.employee</field>
        <field name="arch" type="xml">
            <form string="Employee">
                <header>
                    <button name="action_activate" type="object" string="Activate"
                            class="oe_highlight"
                            invisible="state != 'draft'"/>
                    <button name="action_on_leave" type="object" string="On Leave"
                            invisible="state != 'active'"/>
                    <button name="action_terminate" type="object" string="Terminate"
                            invisible="state in ('draft', 'terminated')"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,active,terminated"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box"/>
                    <field name="photo" widget="image" class="oe_avatar"
                           options="{'preview_image': 'photo'}"/>
                    <div class="oe_title">
                        <label for="code" string="Employee Code"/>
                        <h1>
                            <field name="code" placeholder="Employee Code" readonly="1"/>
                        </h1>
                        <label for="name" string="Name"/>
                        <h1>
                            <field name="name" placeholder="Employee Name"/>
                        </h1>
                        <label for="arabic_name" string="Arabic Name"/>
                        <h2>
                            <field name="arabic_name" placeholder="Arabic Name"/>
                        </h2>
                    </div>
                    <group>
                        <group string="Personal Information">
                            <field name="phone" widget="phone"/>
                            <field name="email" widget="email"/>
                            <field name="birthdate"/>
                            <field name="gender"/>
                            <field name="id_number"/>
                        </group>
                        <group string="Work Information">
                            <field name="category_id"/>
                            <field name="job_title"/>
                            <field name="department_id"/>
                            <field name="branch_id"/>
                            <field name="hire_date"/>
                            <field name="is_teacher"/>
                            <field name="shift_type"/>
                            <field name="salary"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Assigned Classes" name="assigned_classes">
                            <field name="assigned_class_ids" widget="many2many_tags"/>
                        </page>
                        <page string="Qualifications" name="qualifications">
                            <field name="qualification_ids">
                                <tree editable="bottom">
                                    <field name="name"/>
                                    <field name="institution"/>
                                    <field name="year"/>
                                    <field name="degree"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Attendance" name="attendance">
                            <field name="attendance_ids">
                                <tree>
                                    <field name="date"/>
                                    <field name="check_in" widget="float_time"/>
                                    <field name="check_out" widget="float_time"/>
                                    <field name="worked_hours" widget="float_time"/>
                                    <field name="status" widget="badge"
                                           decoration-success="status == 'present'"
                                           decoration-danger="status == 'absent'"
                                           decoration-warning="status == 'late'"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Salary Records" name="salary_records">
                            <field name="salary_ids">
                                <tree>
                                    <field name="month"/>
                                    <field name="year"/>
                                    <field name="basic_salary"/>
                                    <field name="bonuses"/>
                                    <field name="deductions"/>
                                    <field name="loan_deduction"/>
                                    <field name="net_salary"/>
                                    <field name="state" widget="badge"
                                           decoration-info="state == 'draft'"
                                           decoration-success="state == 'paid'"
                                           decoration-warning="state == 'confirmed'"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Penalties" name="penalties">
                            <field name="penalty_ids">
                                <tree>
                                    <field name="date"/>
                                    <field name="type"/>
                                    <field name="reason"/>
                                    <field name="amount"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Complaints" name="complaints">
                            <field name="complaint_ids">
                                <tree>
                                    <field name="date"/>
                                    <field name="subject"/>
                                    <field name="description"/>
                                    <field name="state"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Loans" name="loans">
                            <field name="loan_ids">
                                <tree>
                                    <field name="date"/>
                                    <field name="amount"/>
                                    <field name="repayment_months"/>
                                    <field name="monthly_deduction"/>
                                    <field name="total_paid"/>
                                    <field name="remaining"/>
                                    <field name="status" widget="badge"
                                           decoration-info="status == 'draft'"
                                           decoration-success="status == 'paid'"
                                           decoration-warning="status == 'approved'"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_education_employee_tree" model="ir.ui.view">
        <field name="name">education.employee.tree</field>
        <field name="model">education.employee</field>
        <field name="arch" type="xml">
            <tree string="Employees">
                <field name="code"/>
                <field name="name"/>
                <field name="job_title"/>
                <field name="department_id"/>
                <field name="is_teacher"/>
                <field name="shift_type"/>
                <field name="state" widget="badge"
                       decoration-info="state == 'draft'"
                       decoration-success="state == 'active'"
                       decoration-warning="state == 'on_leave'"
                       decoration-danger="state == 'terminated'"/>
            </tree>
        </field>
    </record>

    <record id="view_education_employee_search" model="ir.ui.view">
        <field name="name">education.employee.search</field>
        <field name="model">education.employee</field>
        <field name="arch" type="xml">
            <search string="Search Employees">
                <field name="name"/>
                <field name="code"/>
                <field name="department_id"/>
                <separator/>
                <filter name="filter_is_teacher" string="Teachers"
                        domain="[('is_teacher', '=', True)]"/>
                <filter name="filter_active" string="Active"
                        domain="[('state', '=', 'active')]"/>
                <filter name="filter_on_leave" string="On Leave"
                        domain="[('state', '=', 'on_leave')]"/>
                <filter name="filter_terminated" string="Terminated"
                        domain="[('state', '=', 'terminated')]"/>
                <separator/>
                <group expand="0" string="Group By">
                    <filter name="group_department" string="Department"
                            context="{'group_by': 'department_id'}"/>
                    <filter name="group_shift_type" string="Shift Type"
                            context="{'group_by': 'shift_type'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_education_employee" model="ir.actions.act_window">
        <field name="name">Employees</field>
        <field name="res_model">education.employee</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_education_employee_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a new employee
            </p>
        </field>
    </record>

</odoo>
