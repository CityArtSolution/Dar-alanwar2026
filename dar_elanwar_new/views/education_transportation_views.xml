<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ==================== -->
    <!-- Vehicle               -->
    <!-- ==================== -->

    <record id="view_education_vehicle_form" model="ir.ui.view">
        <field name="name">education.vehicle.form</field>
        <field name="model">education.vehicle</field>
        <field name="arch" type="xml">
            <form string="Vehicle">
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" placeholder="Vehicle Name"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="plate_number"/>
                            <field name="vehicle_type"/>
                            <field name="capacity"/>
                        </group>
                        <group>
                            <field name="driver_id"/>
                            <field name="supervisor_id"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_education_vehicle_tree" model="ir.ui.view">
        <field name="name">education.vehicle.tree</field>
        <field name="model">education.vehicle</field>
        <field name="arch" type="xml">
            <tree string="Vehicles">
                <field name="name"/>
                <field name="plate_number"/>
                <field name="vehicle_type"/>
                <field name="capacity"/>
                <field name="driver_id"/>
                <field name="supervisor_id"/>
            </tree>
        </field>
    </record>

    <record id="action_education_vehicle" model="ir.actions.act_window">
        <field name="name">Vehicles</field>
        <field name="res_model">education.vehicle</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Register your first vehicle!
            </p>
        </field>
    </record>

    <!-- ==================== -->
    <!-- Route                 -->
    <!-- ==================== -->

    <record id="view_education_route_form" model="ir.ui.view">
        <field name="name">education.route.form</field>
        <field name="model">education.route</field>
        <field name="arch" type="xml">
            <form string="Route">
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" placeholder="Route Name"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="vehicle_id"/>
                            <field name="route_type"/>
                        </group>
                        <group>
                            <field name="student_ids" widget="many2many_tags"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Stops">
                            <field name="stop_ids">
                                <tree string="Stops" editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="name"/>
                                    <field name="pickup_time" widget="float_time"/>
                                    <field name="dropoff_time" widget="float_time"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_education_route_tree" model="ir.ui.view">
        <field name="name">education.route.tree</field>
        <field name="model">education.route</field>
        <field name="arch" type="xml">
            <tree string="Routes">
                <field name="name"/>
                <field name="vehicle_id"/>
                <field name="route_type"/>
            </tree>
        </field>
    </record>

    <record id="action_education_route" model="ir.actions.act_window">
        <field name="name">Routes</field>
        <field name="res_model">education.route</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first route!
            </p>
        </field>
    </record>

</odoo>
