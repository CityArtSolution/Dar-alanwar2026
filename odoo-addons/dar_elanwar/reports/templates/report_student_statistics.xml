<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================ -->
    <!--  Student Statistics Report - Dar Al-Anwar Academy            -->
    <!--  Bilingual Arabic + English | RTL-Aware                      -->
    <!-- ============================================================ -->

    <template id="report_student_statistics_document">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="web.external_layout">
                    <div class="page" dir="rtl" style="font-family: 'Arial', 'Tahoma', sans-serif;">

                        <!-- ===== Shared CSS ===== -->
                        <style>
                            .page {
                                direction: rtl;
                                text-align: right;
                                font-size: 11pt;
                                color: #333;
                            }
                            .academy-header {
                                text-align: center;
                                border-bottom: 3px solid #1a5276;
                                padding-bottom: 12px;
                                margin-bottom: 20px;
                            }
                            .academy-header .ar-name {
                                font-size: 18pt;
                                font-weight: bold;
                                color: #1a5276;
                                margin: 4px 0;
                            }
                            .academy-header .en-name {
                                font-size: 12pt;
                                color: #555;
                                direction: ltr;
                            }
                            .section-title {
                                background-color: #1a5276;
                                color: #fff;
                                padding: 6px 14px;
                                font-size: 12pt;
                                font-weight: bold;
                                margin: 18px 0 10px 0;
                                border-radius: 3px;
                            }
                            .section-title .en {
                                font-weight: normal;
                                font-size: 10pt;
                                margin-right: 10px;
                                direction: ltr;
                                display: inline;
                            }
                            .stat-table {
                                width: 100%;
                                border-collapse: collapse;
                                margin-bottom: 14px;
                            }
                            .stat-table th,
                            .stat-table td {
                                border: 1px solid #ccc;
                                padding: 6px 10px;
                                vertical-align: middle;
                            }
                            .stat-table thead th {
                                background-color: #1a5276;
                                color: #fff;
                                font-weight: bold;
                                text-align: center;
                                -webkit-print-color-adjust: exact;
                                print-color-adjust: exact;
                            }
                            .stat-table tbody td {
                                text-align: center;
                            }
                            .stat-table tbody tr:nth-child(even) {
                                background-color: #f7f9fb;
                            }
                            .summary-cards {
                                display: flex;
                                gap: 12px;
                                margin-bottom: 16px;
                            }
                            .s-card {
                                flex: 1;
                                border: 1px solid #ccc;
                                border-radius: 4px;
                                padding: 12px;
                                text-align: center;
                            }
                            .s-card .val {
                                font-size: 20pt;
                                font-weight: bold;
                                color: #1a5276;
                            }
                            .s-card .lbl {
                                font-size: 9pt;
                                color: #666;
                                margin-top: 4px;
                            }
                            .filter-info {
                                background-color: #f0f4f8;
                                border: 1px solid #d5dce4;
                                border-radius: 4px;
                                padding: 8px 14px;
                                margin-bottom: 16px;
                                font-size: 10pt;
                            }
                            .highlight-green { color: #27ae60; font-weight: bold; }
                            .highlight-red { color: #e74c3c; font-weight: bold; }
                            .highlight-blue { color: #2980b9; font-weight: bold; }
                            .highlight-orange { color: #e67e22; font-weight: bold; }
                            .progress-bar-bg {
                                background-color: #eee;
                                border-radius: 4px;
                                overflow: hidden;
                                height: 16px;
                                width: 100%;
                            }
                            .progress-bar-fill {
                                height: 100%;
                                border-radius: 4px;
                                background-color: #1a5276;
                            }
                            @media print {
                                .page { page-break-after: always; }
                                .section-title,
                                .stat-table thead th {
                                    -webkit-print-color-adjust: exact;
                                    print-color-adjust: exact;
                                }
                            }
                        </style>

                        <!-- ===== Academy Header ===== -->
                        <div class="academy-header">
                            <div class="ar-name">&#1583;&#1575;&#1585; &#1575;&#1604;&#1571;&#1606;&#1608;&#1575;&#1585; &#1575;&#1604;&#1571;&#1603;&#1575;&#1583;&#1610;&#1605;&#1610;&#1577;</div>
                            <div class="en-name">Dar Al-Anwar Academy</div>
                        </div>

                        <h3 style="text-align:center; margin-bottom:4px;">
                            &#1578;&#1602;&#1585;&#1610;&#1585; &#1573;&#1581;&#1589;&#1575;&#1574;&#1610;&#1575;&#1578; &#1575;&#1604;&#1591;&#1604;&#1575;&#1576;
                        </h3>
                        <p style="text-align:center; font-size:10pt; color:#555; direction:ltr; margin-bottom:16px;">
                            Student Statistics Report
                        </p>

                        <!-- ===== Filter Info ===== -->
                        <div class="filter-info">
                            <strong>&#1575;&#1604;&#1601;&#1604;&#1575;&#1578;&#1585; &#1575;&#1604;&#1605;&#1591;&#1576;&#1602;&#1577; / Applied Filters:</strong>
                            <t t-if="doc.department_id">
                                &#1575;&#1604;&#1602;&#1587;&#1605;: <t t-esc="doc.department_id.name"/> |
                            </t>
                            <t t-if="doc.class_id">
                                &#1575;&#1604;&#1601;&#1589;&#1604;: <t t-esc="doc.class_id.name"/> |
                            </t>
                            <t t-if="doc.academic_year_id">
                                &#1575;&#1604;&#1593;&#1575;&#1605; &#1575;&#1604;&#1583;&#1585;&#1575;&#1587;&#1610;: <t t-esc="doc.academic_year_id.name"/>
                            </t>
                        </div>

                        <!-- ===== General Summary Cards ===== -->
                        <div class="section-title">
                            &#1605;&#1604;&#1582;&#1589; &#1593;&#1575;&#1605;
                            <span class="en">General Summary</span>
                        </div>
                        <div class="summary-cards">
                            <div class="s-card">
                                <div class="val highlight-blue">
                                    <t t-esc="doc.total_students or 0"/>
                                </div>
                                <div class="lbl">&#1573;&#1580;&#1605;&#1575;&#1604;&#1610; &#1575;&#1604;&#1591;&#1604;&#1575;&#1576;<br/>Total Students</div>
                            </div>
                            <div class="s-card">
                                <div class="val highlight-green">
                                    <t t-esc="doc.enrolled_count or 0"/>
                                </div>
                                <div class="lbl">&#1605;&#1587;&#1580;&#1604;&#1610;&#1606;<br/>Enrolled</div>
                            </div>
                            <div class="s-card">
                                <div class="val highlight-orange">
                                    <t t-esc="doc.draft_count or 0"/>
                                </div>
                                <div class="lbl">&#1605;&#1587;&#1608;&#1583;&#1577;<br/>Draft</div>
                            </div>
                            <div class="s-card">
                                <div class="val" style="color:#7f8c8d;">
                                    <t t-esc="doc.archived_count or 0"/>
                                </div>
                                <div class="lbl">&#1605;&#1572;&#1585;&#1588;&#1601;&#1610;&#1606;<br/>Archived</div>
                            </div>
                            <div class="s-card">
                                <div class="val highlight-red">
                                    <t t-esc="doc.suspended_count or 0"/>
                                </div>
                                <div class="lbl">&#1605;&#1608;&#1602;&#1608;&#1601;&#1610;&#1606;<br/>Suspended</div>
                            </div>
                        </div>

                        <!-- ===== Students by Department ===== -->
                        <div class="section-title">
                            &#1575;&#1604;&#1591;&#1604;&#1575;&#1576; &#1581;&#1587;&#1576; &#1575;&#1604;&#1602;&#1587;&#1605;
                            <span class="en">Students by Department</span>
                        </div>
                        <table class="stat-table">
                            <thead>
                                <tr>
                                    <th>#</th>
                                    <th>&#1575;&#1604;&#1602;&#1587;&#1605; / Department</th>
                                    <th>&#1593;&#1583;&#1583; &#1575;&#1604;&#1591;&#1604;&#1575;&#1576; / Count</th>
                                    <th>&#1575;&#1604;&#1606;&#1587;&#1576;&#1577; / Percentage</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="doc.department_lines" t-as="line">
                                    <tr>
                                        <td><t t-esc="line_index + 1"/></td>
                                        <td style="text-align:right;"><t t-esc="line.department_name or '-'"/></td>
                                        <td><t t-esc="line.student_count or 0"/></td>
                                        <td>
                                            <div class="progress-bar-bg">
                                                <div class="progress-bar-fill"
                                                     t-attf-style="width: {{ '%.0f' % (line.percentage or 0) }}%;"/>
                                            </div>
                                            <t t-esc="'%.1f%%' % (line.percentage or 0)"/>
                                        </td>
                                    </tr>
                                </t>
                            </tbody>
                        </table>

                        <!-- ===== Students by Gender ===== -->
                        <div class="section-title">
                            &#1575;&#1604;&#1591;&#1604;&#1575;&#1576; &#1581;&#1587;&#1576; &#1575;&#1604;&#1580;&#1606;&#1587;
                            <span class="en">Students by Gender</span>
                        </div>
                        <table class="stat-table">
                            <thead>
                                <tr>
                                    <th>&#1575;&#1604;&#1580;&#1606;&#1587; / Gender</th>
                                    <th>&#1575;&#1604;&#1593;&#1583;&#1583; / Count</th>
                                    <th>&#1575;&#1604;&#1606;&#1587;&#1576;&#1577; / Percentage</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="doc.gender_lines" t-as="gl">
                                    <tr>
                                        <td style="text-align:right;"><t t-esc="gl.gender_label or '-'"/></td>
                                        <td><t t-esc="gl.count or 0"/></td>
                                        <td><t t-esc="'%.1f%%' % (gl.percentage or 0)"/></td>
                                    </tr>
                                </t>
                            </tbody>
                        </table>

                        <!-- ===== Students by Class (Capacity Utilization) ===== -->
                        <div class="section-title">
                            &#1575;&#1604;&#1591;&#1604;&#1575;&#1576; &#1581;&#1587;&#1576; &#1575;&#1604;&#1601;&#1589;&#1604; (&#1575;&#1587;&#1578;&#1594;&#1604;&#1575;&#1604; &#1575;&#1604;&#1587;&#1593;&#1577;)
                            <span class="en">Students by Class (Capacity Utilization)</span>
                        </div>
                        <table class="stat-table">
                            <thead>
                                <tr>
                                    <th>#</th>
                                    <th>&#1575;&#1604;&#1601;&#1589;&#1604; / Class</th>
                                    <th>&#1575;&#1604;&#1602;&#1587;&#1605; / Department</th>
                                    <th>&#1575;&#1604;&#1587;&#1593;&#1577; / Capacity</th>
                                    <th>&#1575;&#1604;&#1605;&#1587;&#1580;&#1604;&#1610;&#1606; / Enrolled</th>
                                    <th>&#1575;&#1604;&#1575;&#1587;&#1578;&#1594;&#1604;&#1575;&#1604; / Utilization</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="doc.class_lines" t-as="cl">
                                    <tr>
                                        <td><t t-esc="cl_index + 1"/></td>
                                        <td style="text-align:right;"><t t-esc="cl.class_name or '-'"/></td>
                                        <td style="text-align:right;"><t t-esc="cl.department_name or '-'"/></td>
                                        <td><t t-esc="cl.capacity or 0"/></td>
                                        <td><t t-esc="cl.enrolled or 0"/></td>
                                        <td>
                                            <div class="progress-bar-bg">
                                                <div class="progress-bar-fill"
                                                     t-attf-style="width: {{ '%.0f' % (cl.utilization or 0) }}%;
                                                                    background-color: {{ 'e74c3c' if (cl.utilization or 0) > 100 else '1a5276' }};"/>
                                            </div>
                                            <t t-esc="'%.1f%%' % (cl.utilization or 0)"/>
                                        </td>
                                    </tr>
                                </t>
                            </tbody>
                        </table>

                        <!-- ===== Age Distribution ===== -->
                        <div class="section-title">
                            &#1578;&#1608;&#1586;&#1610;&#1593; &#1575;&#1604;&#1571;&#1593;&#1605;&#1575;&#1585;
                            <span class="en">Age Distribution</span>
                        </div>
                        <table class="stat-table">
                            <thead>
                                <tr>
                                    <th>&#1575;&#1604;&#1601;&#1574;&#1577; &#1575;&#1604;&#1593;&#1605;&#1585;&#1610;&#1577; / Age Range</th>
                                    <th>&#1575;&#1604;&#1593;&#1583;&#1583; / Count</th>
                                    <th>&#1575;&#1604;&#1606;&#1587;&#1576;&#1577; / Percentage</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="doc.age_lines" t-as="al">
                                    <tr>
                                        <td style="text-align:right;"><t t-esc="al.age_range or '-'"/></td>
                                        <td><t t-esc="al.count or 0"/></td>
                                        <td><t t-esc="'%.1f%%' % (al.percentage or 0)"/></td>
                                    </tr>
                                </t>
                            </tbody>
                        </table>

                        <!-- ===== Footer ===== -->
                        <div style="margin-top:20px; text-align:center; font-size:8pt; color:#999; border-top:1px solid #ddd; padding-top:8px;">
                            &#1578;&#1605; &#1573;&#1606;&#1588;&#1575;&#1569; &#1607;&#1584;&#1575; &#1575;&#1604;&#1578;&#1602;&#1585;&#1610;&#1585; &#1570;&#1604;&#1610;&#1575;&#1611; &#1576;&#1608;&#1575;&#1587;&#1591;&#1577; &#1606;&#1592;&#1575;&#1605; &#1583;&#1575;&#1585; &#1575;&#1604;&#1571;&#1606;&#1608;&#1575;&#1585;
                            |
                            <span style="direction:ltr;">Auto-generated by Dar Al-Anwar System</span>
                        </div>

                    </div>
                </t>
            </t>
        </t>
    </template>

</odoo>
