<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================ -->
    <!--  Communication Report - Dar Al-Anwar Academy                 -->
    <!--  Bilingual Arabic + English | RTL-Aware                      -->
    <!-- ============================================================ -->

    <template id="report_communication_document">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="web.external_layout">
                    <div class="page" dir="rtl" style="font-family: 'Arial', 'Tahoma', sans-serif;">

                        <!-- ===== CSS ===== -->
                        <style>
                            .page {
                                direction: rtl;
                                text-align: right;
                                font-size: 10pt;
                                color: #333;
                            }
                            .academy-header {
                                text-align: center;
                                border-bottom: 3px solid #1a5276;
                                padding-bottom: 12px;
                                margin-bottom: 20px;
                            }
                            .academy-header .ar-name {
                                font-size: 18pt;
                                font-weight: bold;
                                color: #1a5276;
                            }
                            .academy-header .en-name {
                                font-size: 12pt;
                                color: #555;
                                direction: ltr;
                            }
                            .section-title {
                                background-color: #1a5276;
                                color: #fff;
                                padding: 6px 14px;
                                font-size: 12pt;
                                font-weight: bold;
                                margin: 18px 0 10px 0;
                                border-radius: 3px;
                            }
                            .section-title .en {
                                font-weight: normal;
                                font-size: 10pt;
                                margin-right: 10px;
                                direction: ltr;
                                display: inline;
                            }
                            .comm-table {
                                width: 100%;
                                border-collapse: collapse;
                                margin-bottom: 14px;
                            }
                            .comm-table th,
                            .comm-table td {
                                border: 1px solid #ccc;
                                padding: 6px 10px;
                                vertical-align: middle;
                            }
                            .comm-table thead th {
                                background-color: #1a5276;
                                color: #fff;
                                font-weight: bold;
                                text-align: center;
                            }
                            .comm-table tbody td {
                                text-align: center;
                            }
                            .comm-table tbody tr:nth-child(even) {
                                background-color: #f7f9fb;
                            }
                            .comm-table tfoot td {
                                background-color: #eaf2f8;
                                font-weight: bold;
                            }
                            .summary-cards {
                                display: flex;
                                gap: 10px;
                                margin-bottom: 16px;
                            }
                            .s-card {
                                flex: 1;
                                border: 1px solid #ccc;
                                border-radius: 4px;
                                padding: 12px;
                                text-align: center;
                            }
                            .s-card .val {
                                font-size: 18pt;
                                font-weight: bold;
                            }
                            .s-card .lbl {
                                font-size: 8pt;
                                color: #666;
                                margin-top: 4px;
                            }
                            .badge-sent {
                                background-color: #27ae60;
                                color: #fff;
                                padding: 2px 8px;
                                border-radius: 10px;
                                font-size: 8pt;
                            }
                            .badge-draft {
                                background-color: #7f8c8d;
                                color: #fff;
                                padding: 2px 8px;
                                border-radius: 10px;
                                font-size: 8pt;
                            }
                            .badge-read {
                                background-color: #1a5276;
                                color: #fff;
                                padding: 2px 8px;
                                border-radius: 10px;
                                font-size: 8pt;
                            }
                            .badge-unread {
                                background-color: #e67e22;
                                color: #fff;
                                padding: 2px 8px;
                                border-radius: 10px;
                                font-size: 8pt;
                            }
                            .badge-open {
                                background-color: #e67e22;
                                color: #fff;
                                padding: 2px 8px;
                                border-radius: 10px;
                                font-size: 8pt;
                            }
                            .badge-resolved {
                                background-color: #27ae60;
                                color: #fff;
                                padding: 2px 8px;
                                border-radius: 10px;
                                font-size: 8pt;
                            }
                            .badge-closed {
                                background-color: #7f8c8d;
                                color: #fff;
                                padding: 2px 8px;
                                border-radius: 10px;
                                font-size: 8pt;
                            }
                            .badge-high {
                                background-color: #e74c3c;
                                color: #fff;
                                padding: 2px 8px;
                                border-radius: 10px;
                                font-size: 8pt;
                            }
                            .badge-medium {
                                background-color: #e67e22;
                                color: #fff;
                                padding: 2px 8px;
                                border-radius: 10px;
                                font-size: 8pt;
                            }
                            .badge-low {
                                background-color: #27ae60;
                                color: #fff;
                                padding: 2px 8px;
                                border-radius: 10px;
                                font-size: 8pt;
                            }
                            .green { color: #27ae60; }
                            .blue { color: #1a5276; }
                            .orange { color: #e67e22; }
                            .red { color: #e74c3c; }
                            .filter-box {
                                background-color: #f0f4f8;
                                border: 1px solid #d5dce4;
                                border-radius: 4px;
                                padding: 8px 14px;
                                margin-bottom: 16px;
                                font-size: 10pt;
                            }
                            @media print {
                                .page { page-break-after: always; }
                                .section-title,
                                .comm-table thead th,
                                .comm-table tfoot td,
                                .badge-sent, .badge-draft, .badge-read, .badge-unread,
                                .badge-open, .badge-resolved, .badge-closed,
                                .badge-high, .badge-medium, .badge-low {
                                    -webkit-print-color-adjust: exact;
                                    print-color-adjust: exact;
                                }
                            }
                        </style>

                        <!-- ===== Header ===== -->
                        <div class="academy-header">
                            <div class="ar-name">&#1583;&#1575;&#1585; &#1575;&#1604;&#1571;&#1606;&#1608;&#1575;&#1585; &#1575;&#1604;&#1571;&#1603;&#1575;&#1583;&#1610;&#1605;&#1610;&#1577;</div>
                            <div class="en-name">Dar Al-Anwar Academy</div>
                        </div>

                        <h3 style="text-align:center; margin-bottom:4px;">
                            &#1578;&#1602;&#1585;&#1610;&#1585; &#1575;&#1604;&#1575;&#1578;&#1589;&#1575;&#1604;&#1575;&#1578;
                        </h3>
                        <p style="text-align:center; font-size:10pt; color:#555; direction:ltr; margin-bottom:16px;">
                            Communication Report
                        </p>

                        <!-- ===== Filter Info ===== -->
                        <div class="filter-box">
                            <strong>&#1575;&#1604;&#1601;&#1578;&#1585;&#1577; / Period:</strong>
                            <t t-if="doc.date_from">
                                &#1605;&#1606;: <t t-esc="doc.date_from" t-options="{'widget': 'date'}"/>
                            </t>
                            <t t-if="doc.date_to">
                                &#1573;&#1604;&#1609;: <t t-esc="doc.date_to" t-options="{'widget': 'date'}"/>
                            </t>
                        </div>

                        <!-- ===== Summary Cards ===== -->
                        <div class="section-title">
                            &#1605;&#1604;&#1582;&#1589; &#1575;&#1604;&#1575;&#1578;&#1589;&#1575;&#1604;&#1575;&#1578;
                            <span class="en">Communication Summary</span>
                        </div>
                        <div class="summary-cards">
                            <div class="s-card">
                                <div class="val blue"><t t-esc="doc.total_announcements or 0"/></div>
                                <div class="lbl">&#1573;&#1580;&#1605;&#1575;&#1604;&#1610; &#1575;&#1604;&#1573;&#1593;&#1604;&#1575;&#1606;&#1575;&#1578;<br/>Total Announcements</div>
                            </div>
                            <div class="s-card">
                                <div class="val green"><t t-esc="doc.total_messages or 0"/></div>
                                <div class="lbl">&#1573;&#1580;&#1605;&#1575;&#1604;&#1610; &#1575;&#1604;&#1585;&#1587;&#1575;&#1574;&#1604;<br/>Total Messages</div>
                            </div>
                            <div class="s-card">
                                <div class="val orange"><t t-esc="doc.total_support_tickets or 0"/></div>
                                <div class="lbl">&#1578;&#1584;&#1575;&#1603;&#1585; &#1575;&#1604;&#1583;&#1593;&#1605;<br/>Support Tickets</div>
                            </div>
                            <div class="s-card">
                                <div class="val red"><t t-esc="doc.total_unread or 0"/></div>
                                <div class="lbl">&#1594;&#1610;&#1585; &#1605;&#1602;&#1585;&#1608;&#1569;&#1577;<br/>Unread</div>
                            </div>
                        </div>

                        <!-- ===== Announcements Table ===== -->
                        <div class="section-title">
                            &#1587;&#1580;&#1604; &#1575;&#1604;&#1573;&#1593;&#1604;&#1575;&#1606;&#1575;&#1578;
                            <span class="en">Announcements</span>
                        </div>
                        <table class="comm-table">
                            <thead>
                                <tr>
                                    <th>#</th>
                                    <th>&#1575;&#1604;&#1578;&#1575;&#1585;&#1610;&#1582; / Date</th>
                                    <th>&#1575;&#1604;&#1593;&#1606;&#1608;&#1575;&#1606; / Title</th>
                                    <th>&#1575;&#1604;&#1601;&#1574;&#1577; &#1575;&#1604;&#1605;&#1587;&#1578;&#1607;&#1583;&#1601;&#1577; / Target</th>
                                    <th>&#1606;&#1588;&#1585; &#1576;&#1608;&#1575;&#1587;&#1591;&#1577; / Published By</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="doc.announcement_lines" t-as="ann">
                                    <tr>
                                        <td><t t-esc="ann_index + 1"/></td>
                                        <td><t t-esc="ann.date" t-options="{'widget': 'date'}"/></td>
                                        <td style="text-align:right;"><t t-esc="ann.title or '-'"/></td>
                                        <td style="text-align:right;"><t t-esc="ann.target or '-'"/></td>
                                        <td style="text-align:right;"><t t-esc="ann.published_by or '-'"/></td>
                                    </tr>
                                </t>
                            </tbody>
                            <tfoot>
                                <tr>
                                    <td colspan="5" style="text-align:right;">
                                        &#1573;&#1580;&#1605;&#1575;&#1604;&#1610; &#1575;&#1604;&#1573;&#1593;&#1604;&#1575;&#1606;&#1575;&#1578; / Total Announcements:
                                        <strong><t t-esc="doc.total_announcements or 0"/></strong>
                                    </td>
                                </tr>
                            </tfoot>
                        </table>

                        <!-- ===== Messages Table ===== -->
                        <div class="section-title">
                            &#1587;&#1580;&#1604; &#1575;&#1604;&#1585;&#1587;&#1575;&#1574;&#1604;
                            <span class="en">Messages</span>
                        </div>
                        <table class="comm-table">
                            <thead>
                                <tr>
                                    <th>#</th>
                                    <th>&#1575;&#1604;&#1578;&#1575;&#1585;&#1610;&#1582; / Date</th>
                                    <th>&#1605;&#1606; / From</th>
                                    <th>&#1573;&#1604;&#1609; / To</th>
                                    <th>&#1575;&#1604;&#1605;&#1608;&#1590;&#1608;&#1593; / Subject</th>
                                    <th>&#1575;&#1604;&#1581;&#1575;&#1604;&#1577; / Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="doc.message_lines" t-as="msg">
                                    <tr>
                                        <td><t t-esc="msg_index + 1"/></td>
                                        <td><t t-esc="msg.date" t-options="{'widget': 'date'}"/></td>
                                        <td style="text-align:right;"><t t-esc="msg.sender or '-'"/></td>
                                        <td style="text-align:right;"><t t-esc="msg.recipient or '-'"/></td>
                                        <td style="text-align:right;"><t t-esc="msg.subject or '-'"/></td>
                                        <td>
                                            <t t-if="msg.status == 'sent'">
                                                <span class="badge-sent">&#1605;&#1585;&#1587;&#1604;&#1577; / Sent</span>
                                            </t>
                                            <t t-if="msg.status == 'read'">
                                                <span class="badge-read">&#1605;&#1602;&#1585;&#1608;&#1569;&#1577; / Read</span>
                                            </t>
                                            <t t-if="msg.status == 'unread'">
                                                <span class="badge-unread">&#1594;&#1610;&#1585; &#1605;&#1602;&#1585;&#1608;&#1569;&#1577; / Unread</span>
                                            </t>
                                            <t t-if="msg.status == 'draft'">
                                                <span class="badge-draft">&#1605;&#1587;&#1608;&#1583;&#1577; / Draft</span>
                                            </t>
                                        </td>
                                    </tr>
                                </t>
                            </tbody>
                            <tfoot>
                                <tr>
                                    <td colspan="6" style="text-align:right;">
                                        &#1573;&#1580;&#1605;&#1575;&#1604;&#1610; &#1575;&#1604;&#1585;&#1587;&#1575;&#1574;&#1604; / Total Messages:
                                        <strong><t t-esc="doc.total_messages or 0"/></strong>
                                    </td>
                                </tr>
                            </tfoot>
                        </table>

                        <!-- ===== Support Tickets Table ===== -->
                        <div class="section-title">
                            &#1578;&#1584;&#1575;&#1603;&#1585; &#1575;&#1604;&#1583;&#1593;&#1605;
                            <span class="en">Support Tickets</span>
                        </div>
                        <table class="comm-table">
                            <thead>
                                <tr>
                                    <th>#</th>
                                    <th>&#1575;&#1604;&#1585;&#1602;&#1605; / Number</th>
                                    <th>&#1575;&#1604;&#1578;&#1575;&#1585;&#1610;&#1582; / Date</th>
                                    <th>&#1575;&#1604;&#1605;&#1608;&#1590;&#1608;&#1593; / Subject</th>
                                    <th>&#1575;&#1604;&#1571;&#1608;&#1604;&#1608;&#1610;&#1577; / Priority</th>
                                    <th>&#1575;&#1604;&#1581;&#1575;&#1604;&#1577; / Status</th>
                                    <th>&#1605;&#1587;&#1606;&#1583; &#1573;&#1604;&#1609; / Assigned To</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="doc.ticket_lines" t-as="tkt">
                                    <tr>
                                        <td><t t-esc="tkt_index + 1"/></td>
                                        <td><t t-esc="tkt.number or '-'"/></td>
                                        <td><t t-esc="tkt.date" t-options="{'widget': 'date'}"/></td>
                                        <td style="text-align:right;"><t t-esc="tkt.subject or '-'"/></td>
                                        <td>
                                            <t t-if="tkt.priority == 'high'">
                                                <span class="badge-high">&#1593;&#1575;&#1604;&#1610;&#1577; / High</span>
                                            </t>
                                            <t t-if="tkt.priority == 'medium'">
                                                <span class="badge-medium">&#1605;&#1578;&#1608;&#1587;&#1591;&#1577; / Medium</span>
                                            </t>
                                            <t t-if="tkt.priority == 'low'">
                                                <span class="badge-low">&#1605;&#1606;&#1582;&#1601;&#1590;&#1577; / Low</span>
                                            </t>
                                        </td>
                                        <td>
                                            <t t-if="tkt.status == 'open'">
                                                <span class="badge-open">&#1605;&#1601;&#1578;&#1608;&#1581;&#1577; / Open</span>
                                            </t>
                                            <t t-if="tkt.status == 'resolved'">
                                                <span class="badge-resolved">&#1605;&#1581;&#1604;&#1608;&#1604;&#1577; / Resolved</span>
                                            </t>
                                            <t t-if="tkt.status == 'closed'">
                                                <span class="badge-closed">&#1605;&#1594;&#1604;&#1602;&#1577; / Closed</span>
                                            </t>
                                        </td>
                                        <td style="text-align:right;"><t t-esc="tkt.assigned_to or '-'"/></td>
                                    </tr>
                                </t>
                            </tbody>
                            <tfoot>
                                <tr>
                                    <td colspan="7" style="text-align:right;">
                                        &#1573;&#1580;&#1605;&#1575;&#1604;&#1610; &#1575;&#1604;&#1578;&#1584;&#1575;&#1603;&#1585; / Total Tickets:
                                        <strong><t t-esc="doc.total_support_tickets or 0"/></strong>
                                    </td>
                                </tr>
                            </tfoot>
                        </table>

                        <!-- ===== Footer ===== -->
                        <div style="margin-top:20px; text-align:center; font-size:8pt; color:#999; border-top:1px solid #ddd; padding-top:8px;">
                            &#1578;&#1605; &#1573;&#1606;&#1588;&#1575;&#1569; &#1607;&#1584;&#1575; &#1575;&#1604;&#1578;&#1602;&#1585;&#1610;&#1585; &#1570;&#1604;&#1610;&#1575;&#1611; &#1576;&#1608;&#1575;&#1587;&#1591;&#1577; &#1606;&#1592;&#1575;&#1605; &#1583;&#1575;&#1585; &#1575;&#1604;&#1571;&#1606;&#1608;&#1575;&#1585;
                            |
                            <span style="direction:ltr;">Auto-generated by Dar Al-Anwar System</span>
                        </div>

                    </div>
                </t>
            </t>
        </t>
    </template>

</odoo>
