<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================ -->
    <!--  Inventory Report - Dar Al-Anwar Academy                     -->
    <!--  Bilingual Arabic + English | RTL-Aware                      -->
    <!-- ============================================================ -->

    <template id="report_inventory_document">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="web.external_layout">
                    <div class="page" dir="rtl" style="font-family: 'Arial', 'Tahoma', sans-serif;">

                        <!-- ===== CSS ===== -->
                        <style>
                            .page {
                                direction: rtl;
                                text-align: right;
                                font-size: 10pt;
                                color: #333;
                            }
                            .academy-header {
                                text-align: center;
                                border-bottom: 3px solid #1a5276;
                                padding-bottom: 12px;
                                margin-bottom: 20px;
                            }
                            .academy-header .ar-name {
                                font-size: 18pt;
                                font-weight: bold;
                                color: #1a5276;
                            }
                            .academy-header .en-name {
                                font-size: 12pt;
                                color: #555;
                                direction: ltr;
                            }
                            .section-title {
                                background-color: #1a5276;
                                color: #fff;
                                padding: 6px 14px;
                                font-size: 12pt;
                                font-weight: bold;
                                margin: 18px 0 10px 0;
                                border-radius: 3px;
                            }
                            .section-title .en {
                                font-weight: normal;
                                font-size: 10pt;
                                margin-right: 10px;
                                direction: ltr;
                                display: inline;
                            }
                            .inv-table {
                                width: 100%;
                                border-collapse: collapse;
                                margin-bottom: 14px;
                            }
                            .inv-table th,
                            .inv-table td {
                                border: 1px solid #ccc;
                                padding: 6px 10px;
                                vertical-align: middle;
                            }
                            .inv-table thead th {
                                background-color: #1a5276;
                                color: #fff;
                                font-weight: bold;
                                text-align: center;
                            }
                            .inv-table tbody td {
                                text-align: center;
                            }
                            .inv-table tbody tr:nth-child(even) {
                                background-color: #f7f9fb;
                            }
                            .inv-table tfoot td {
                                background-color: #eaf2f8;
                                font-weight: bold;
                            }
                            .amount {
                                direction: ltr;
                                text-align: left;
                                font-family: 'Courier New', monospace;
                                white-space: nowrap;
                            }
                            .summary-cards {
                                display: flex;
                                gap: 10px;
                                margin-bottom: 16px;
                            }
                            .s-card {
                                flex: 1;
                                border: 1px solid #ccc;
                                border-radius: 4px;
                                padding: 12px;
                                text-align: center;
                            }
                            .s-card .val {
                                font-size: 18pt;
                                font-weight: bold;
                            }
                            .s-card .lbl {
                                font-size: 8pt;
                                color: #666;
                                margin-top: 4px;
                            }
                            .low-stock-row {
                                background-color: #fdecea !important;
                            }
                            .low-stock-badge {
                                background-color: #e74c3c;
                                color: #fff;
                                padding: 2px 8px;
                                border-radius: 10px;
                                font-size: 8pt;
                                font-weight: bold;
                            }
                            .green { color: #27ae60; }
                            .blue { color: #1a5276; }
                            .orange { color: #e67e22; }
                            .red { color: #e74c3c; }
                            @media print {
                                .page { page-break-after: always; }
                                .section-title,
                                .inv-table thead th,
                                .inv-table tfoot td,
                                .low-stock-badge {
                                    -webkit-print-color-adjust: exact;
                                    print-color-adjust: exact;
                                }
                            }
                        </style>

                        <!-- ===== Header ===== -->
                        <div class="academy-header">
                            <div class="ar-name">&#1583;&#1575;&#1585; &#1575;&#1604;&#1571;&#1606;&#1608;&#1575;&#1585; &#1575;&#1604;&#1571;&#1603;&#1575;&#1583;&#1610;&#1605;&#1610;&#1577;</div>
                            <div class="en-name">Dar Al-Anwar Academy</div>
                        </div>

                        <h3 style="text-align:center; margin-bottom:4px;">
                            &#1578;&#1602;&#1585;&#1610;&#1585; &#1575;&#1604;&#1605;&#1582;&#1586;&#1608;&#1606;
                        </h3>
                        <p style="text-align:center; font-size:10pt; color:#555; direction:ltr; margin-bottom:16px;">
                            Inventory Report
                        </p>

                        <!-- ===== Summary Cards ===== -->
                        <div class="summary-cards">
                            <div class="s-card">
                                <div class="val blue"><t t-esc="doc.total_items or 0"/></div>
                                <div class="lbl">&#1573;&#1580;&#1605;&#1575;&#1604;&#1610; &#1575;&#1604;&#1571;&#1589;&#1606;&#1575;&#1601;<br/>Total Items</div>
                            </div>
                            <div class="s-card">
                                <div class="val green"><t t-esc="doc.in_stock_count or 0"/></div>
                                <div class="lbl">&#1605;&#1578;&#1608;&#1601;&#1585;<br/>In Stock</div>
                            </div>
                            <div class="s-card">
                                <div class="val red"><t t-esc="doc.low_stock_count or 0"/></div>
                                <div class="lbl">&#1571;&#1602;&#1604; &#1605;&#1606; &#1575;&#1604;&#1581;&#1583; &#1575;&#1604;&#1571;&#1583;&#1606;&#1609;<br/>Below Minimum</div>
                            </div>
                            <div class="s-card">
                                <div class="val" style="color:#1a5276;">
                                    <t t-esc="'%.2f' % (doc.total_inventory_value or 0)"/>
                                </div>
                                <div class="lbl">&#1575;&#1604;&#1602;&#1610;&#1605;&#1577; &#1575;&#1604;&#1573;&#1580;&#1605;&#1575;&#1604;&#1610;&#1577;<br/>Total Value</div>
                            </div>
                        </div>

                        <!-- ===== Current Stock Levels ===== -->
                        <div class="section-title">
                            &#1605;&#1587;&#1578;&#1608;&#1610;&#1575;&#1578; &#1575;&#1604;&#1605;&#1582;&#1586;&#1608;&#1606; &#1575;&#1604;&#1581;&#1575;&#1604;&#1610;&#1577;
                            <span class="en">Current Stock Levels</span>
                        </div>
                        <table class="inv-table">
                            <thead>
                                <tr>
                                    <th>#</th>
                                    <th>&#1575;&#1604;&#1589;&#1606;&#1601; / Item</th>
                                    <th>&#1575;&#1604;&#1601;&#1574;&#1577; / Category</th>
                                    <th>&#1575;&#1604;&#1608;&#1581;&#1583;&#1577; / Unit</th>
                                    <th>&#1575;&#1604;&#1603;&#1605;&#1610;&#1577; &#1575;&#1604;&#1581;&#1575;&#1604;&#1610;&#1577; / Current Qty</th>
                                    <th>&#1575;&#1604;&#1581;&#1583; &#1575;&#1604;&#1571;&#1583;&#1606;&#1609; / Min Qty</th>
                                    <th>&#1587;&#1593;&#1585; &#1575;&#1604;&#1608;&#1581;&#1583;&#1577; / Unit Price</th>
                                    <th>&#1575;&#1604;&#1602;&#1610;&#1605;&#1577; / Value</th>
                                    <th>&#1575;&#1604;&#1581;&#1575;&#1604;&#1577; / Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="doc.stock_lines" t-as="stk">
                                    <tr t-attf-class="{{ 'low-stock-row' if stk.is_below_minimum else '' }}">
                                        <td><t t-esc="stk_index + 1"/></td>
                                        <td style="text-align:right;"><t t-esc="stk.item_name or '-'"/></td>
                                        <td style="text-align:right;"><t t-esc="stk.category_name or '-'"/></td>
                                        <td><t t-esc="stk.unit or '-'"/></td>
                                        <td>
                                            <strong t-attf-style="color: {{ '#e74c3c' if stk.is_below_minimum else '#333' }};">
                                                <t t-esc="stk.current_qty or 0"/>
                                            </strong>
                                        </td>
                                        <td><t t-esc="stk.min_qty or 0"/></td>
                                        <td class="amount">
                                            <t t-esc="'%.2f' % (stk.unit_price or 0)"/>
                                        </td>
                                        <td class="amount">
                                            <t t-esc="'%.2f' % (stk.total_value or 0)"/>
                                            <t t-esc="doc.currency_symbol or ''"/>
                                        </td>
                                        <td>
                                            <t t-if="stk.is_below_minimum">
                                                <span class="low-stock-badge">
                                                    &#1606;&#1602;&#1589; / Low
                                                </span>
                                            </t>
                                            <t t-else="">
                                                <span class="green">&#1605;&#1578;&#1608;&#1601;&#1585; / OK</span>
                                            </t>
                                        </td>
                                    </tr>
                                </t>
                            </tbody>
                            <tfoot>
                                <tr>
                                    <td colspan="7" style="text-align:right;">
                                        &#1573;&#1580;&#1605;&#1575;&#1604;&#1610; &#1602;&#1610;&#1605;&#1577; &#1575;&#1604;&#1605;&#1582;&#1586;&#1608;&#1606; / Total Inventory Value
                                    </td>
                                    <td class="amount" style="font-weight:bold;">
                                        <t t-esc="'%.2f' % (doc.total_inventory_value or 0)"/>
                                        <t t-esc="doc.currency_symbol or ''"/>
                                    </td>
                                    <td></td>
                                </tr>
                            </tfoot>
                        </table>

                        <!-- ===== Items Below Minimum ===== -->
                        <t t-if="doc.low_stock_lines">
                            <div class="section-title" style="background-color:#e74c3c;">
                                &#1571;&#1589;&#1606;&#1575;&#1601; &#1571;&#1602;&#1604; &#1605;&#1606; &#1575;&#1604;&#1581;&#1583; &#1575;&#1604;&#1571;&#1583;&#1606;&#1609;
                                <span class="en">Items Below Minimum Quantity</span>
                            </div>
                            <table class="inv-table">
                                <thead>
                                    <tr>
                                        <th>#</th>
                                        <th>&#1575;&#1604;&#1589;&#1606;&#1601; / Item</th>
                                        <th>&#1575;&#1604;&#1603;&#1605;&#1610;&#1577; &#1575;&#1604;&#1581;&#1575;&#1604;&#1610;&#1577; / Current</th>
                                        <th>&#1575;&#1604;&#1581;&#1583; &#1575;&#1604;&#1571;&#1583;&#1606;&#1609; / Minimum</th>
                                        <th>&#1575;&#1604;&#1606;&#1602;&#1589; / Shortage</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <t t-foreach="doc.low_stock_lines" t-as="ls">
                                        <tr class="low-stock-row">
                                            <td><t t-esc="ls_index + 1"/></td>
                                            <td style="text-align:right;"><t t-esc="ls.item_name or '-'"/></td>
                                            <td class="red"><t t-esc="ls.current_qty or 0"/></td>
                                            <td><t t-esc="ls.min_qty or 0"/></td>
                                            <td class="red">
                                                <strong><t t-esc="ls.shortage or 0"/></strong>
                                            </td>
                                        </tr>
                                    </t>
                                </tbody>
                            </table>
                        </t>

                        <!-- ===== Movement Summary ===== -->
                        <div class="section-title">
                            &#1605;&#1604;&#1582;&#1589; &#1575;&#1604;&#1581;&#1585;&#1603;&#1577;
                            <span class="en">Movement Summary (Incoming vs Outgoing)</span>
                        </div>
                        <div class="summary-cards">
                            <div class="s-card">
                                <div class="val green"><t t-esc="doc.total_incoming or 0"/></div>
                                <div class="lbl">&#1573;&#1580;&#1605;&#1575;&#1604;&#1610; &#1575;&#1604;&#1608;&#1575;&#1585;&#1583;<br/>Total Incoming</div>
                            </div>
                            <div class="s-card">
                                <div class="val red"><t t-esc="doc.total_outgoing or 0"/></div>
                                <div class="lbl">&#1573;&#1580;&#1605;&#1575;&#1604;&#1610; &#1575;&#1604;&#1589;&#1575;&#1583;&#1585;<br/>Total Outgoing</div>
                            </div>
                            <div class="s-card">
                                <div class="val" t-attf-style="color: {{ '#27ae60' if (doc.net_movement or 0) >= 0 else '#e74c3c' }};">
                                    <t t-esc="doc.net_movement or 0"/>
                                </div>
                                <div class="lbl">&#1589;&#1575;&#1601;&#1610; &#1575;&#1604;&#1581;&#1585;&#1603;&#1577;<br/>Net Movement</div>
                            </div>
                        </div>

                        <table class="inv-table">
                            <thead>
                                <tr>
                                    <th>#</th>
                                    <th>&#1575;&#1604;&#1589;&#1606;&#1601; / Item</th>
                                    <th>&#1575;&#1604;&#1608;&#1575;&#1585;&#1583; / Incoming</th>
                                    <th>&#1575;&#1604;&#1589;&#1575;&#1583;&#1585; / Outgoing</th>
                                    <th>&#1575;&#1604;&#1589;&#1575;&#1601;&#1610; / Net</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="doc.movement_lines" t-as="mv">
                                    <tr>
                                        <td><t t-esc="mv_index + 1"/></td>
                                        <td style="text-align:right;"><t t-esc="mv.item_name or '-'"/></td>
                                        <td class="green"><t t-esc="mv.incoming or 0"/></td>
                                        <td class="red"><t t-esc="mv.outgoing or 0"/></td>
                                        <td>
                                            <strong t-attf-style="color: {{ '#27ae60' if (mv.net or 0) >= 0 else '#e74c3c' }};">
                                                <t t-esc="mv.net or 0"/>
                                            </strong>
                                        </td>
                                    </tr>
                                </t>
                            </tbody>
                        </table>

                        <!-- ===== Footer ===== -->
                        <div style="margin-top:20px; text-align:center; font-size:8pt; color:#999; border-top:1px solid #ddd; padding-top:8px;">
                            &#1578;&#1605; &#1573;&#1606;&#1588;&#1575;&#1569; &#1607;&#1584;&#1575; &#1575;&#1604;&#1578;&#1602;&#1585;&#1610;&#1585; &#1570;&#1604;&#1610;&#1575;&#1611; &#1576;&#1608;&#1575;&#1587;&#1591;&#1577; &#1606;&#1592;&#1575;&#1605; &#1583;&#1575;&#1585; &#1575;&#1604;&#1571;&#1606;&#1608;&#1575;&#1585;
                            |
                            <span style="direction:ltr;">Auto-generated by Dar Al-Anwar System</span>
                        </div>

                    </div>
                </t>
            </t>
        </t>
    </template>

</odoo>
