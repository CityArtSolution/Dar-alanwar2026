<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Student Code Sequence -->
    <record id="seq_education_student" model="ir.sequence">
        <field name="name">Student Code</field>
        <field name="code">education.student</field>
        <field name="prefix">STD/</field>
        <field name="padding">5</field>
        <field name="number_next">1</field>
        <field name="number_increment">1</field>
    </record>

    <!-- Employee Code Sequence -->
    <record id="seq_education_employee" model="ir.sequence">
        <field name="name">Employee Code</field>
        <field name="code">education.employee</field>
        <field name="prefix">EMP/</field>
        <field name="padding">5</field>
        <field name="number_next">1</field>
        <field name="number_increment">1</field>
    </record>

    <!-- Payment Receipt Sequence -->
    <record id="seq_education_receipt" model="ir.sequence">
        <field name="name">Payment Receipt</field>
        <field name="code">education.payment.receipt</field>
        <field name="prefix">REC/%(year)s/</field>
        <field name="padding">5</field>
        <field name="number_next">1</field>
        <field name="number_increment">1</field>
    </record>

    <!-- Stock In Sequence -->
    <record id="seq_education_stock_in" model="ir.sequence">
        <field name="name">Stock In</field>
        <field name="code">education.stock.in</field>
        <field name="prefix">IN/%(year)s/</field>
        <field name="padding">5</field>
        <field name="number_next">1</field>
        <field name="number_increment">1</field>
    </record>

    <!-- Stock Out Sequence -->
    <record id="seq_education_stock_out" model="ir.sequence">
        <field name="name">Stock Out</field>
        <field name="code">education.stock.out</field>
        <field name="prefix">OUT/%(year)s/</field>
        <field name="padding">5</field>
        <field name="number_next">1</field>
        <field name="number_increment">1</field>
    </record>

    <!-- Transaction Sequence -->
    <record id="seq_education_transaction" model="ir.sequence">
        <field name="name">Transaction</field>
        <field name="code">education.transaction</field>
        <field name="prefix">TRX/%(year)s/</field>
        <field name="padding">5</field>
        <field name="number_next">1</field>
        <field name="number_increment">1</field>
    </record>

    <!-- Message Sequence -->
    <record id="seq_education_message" model="ir.sequence">
        <field name="name">Message</field>
        <field name="code">education.message</field>
        <field name="prefix">MSG/%(year)s/</field>
        <field name="padding">5</field>
        <field name="number_next">1</field>
        <field name="number_increment">1</field>
    </record>

</odoo>
