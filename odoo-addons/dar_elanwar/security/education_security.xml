<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- ========================== -->
        <!-- MODULE CATEGORY -->
        <!-- ========================== -->

        <record id="module_category_education" model="ir.module.category">
            <field name="name">Education</field>
            <field name="description">Education Management System</field>
            <field name="sequence">100</field>
        </record>

        <!-- ========================== -->
        <!-- SECURITY GROUPS -->
        <!-- ========================== -->

        <!-- User Group (Base) -->
        <record id="group_education_user" model="res.groups">
            <field name="name">Education / User</field>
            <field name="comment">Basic access to education module - can view records</field>
        </record>

        <!-- Teacher Group -->
        <record id="group_education_teacher" model="res.groups">
            <field name="name">Education / Teacher</field>
            <field name="implied_ids" eval="[Command.link(ref('group_education_user'))]"/>
            <field name="comment">Can manage attendance, evaluations, and homework</field>
        </record>

        <!-- Secretary Group -->
        <record id="group_education_secretary" model="res.groups">
            <field name="name">Education / Secretary</field>
            <field name="implied_ids" eval="[Command.link(ref('group_education_user'))]"/>
            <field name="comment">Can manage students, parents, and subscriptions</field>
        </record>

        <!-- Accountant Group -->
        <record id="group_education_accountant" model="res.groups">
            <field name="name">Education / Accountant</field>
            <field name="implied_ids" eval="[Command.link(ref('group_education_user'))]"/>
            <field name="comment">Can manage payments, treasury, and financial records</field>
        </record>

        <!-- Manager Group -->
        <record id="group_education_manager" model="res.groups">
            <field name="name">Education / Manager</field>
            <field name="implied_ids" eval="[Command.link(ref('group_education_teacher')), Command.link(ref('group_education_secretary')), Command.link(ref('group_education_accountant'))]"/>
            <field name="comment">Full access to all operations except configuration</field>
        </record>

        <!-- Administrator Group -->
        <record id="group_education_admin" model="res.groups">
            <field name="name">Education / Administrator</field>
            <field name="implied_ids" eval="[Command.link(ref('group_education_manager'))]"/>
            <field name="comment">Full access including configuration and settings</field>
        </record>

    </data>
</odoo>
