<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ========================== -->
    <!-- BRANCH VIEWS -->
    <!-- ========================== -->

    <!-- Branch Tree View -->
    <record id="view_education_branch_tree" model="ir.ui.view">
        <field name="name">education.branch.tree</field>
        <field name="model">education.branch</field>
        <field name="arch" type="xml">
            <list>
                <field name="sequence" widget="handle"/>
                <field name="code"/>
                <field name="name"/>
                <field name="phone"/>
                <field name="email"/>
                <field name="is_main"/>
                <field name="active" column_invisible="1"/>
            </list>
        </field>
    </record>

    <!-- Branch Form View -->
    <record id="view_education_branch_form" model="ir.ui.view">
        <field name="name">education.branch.form</field>
        <field name="model">education.branch</field>
        <field name="arch" type="xml">
            <form string="Branch">
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_departments" type="object" class="oe_stat_button" icon="fa-sitemap">
                            <field name="department_count" widget="statinfo" string="Departments"/>
                        </button>
                        <button name="action_view_students" type="object" class="oe_stat_button" icon="fa-graduation-cap">
                            <field name="student_count" widget="statinfo" string="Students"/>
                        </button>
                        <button name="action_view_employees" type="object" class="oe_stat_button" icon="fa-id-badge">
                            <field name="employee_count" widget="statinfo" string="Employees"/>
                        </button>
                    </div>
                    <widget name="web_ribbon" title="Archived" bg_color="text-bg-danger" invisible="active"/>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" placeholder="Branch Name"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="code"/>
                            <field name="is_main"/>
                            <field name="active" invisible="1"/>
                        </group>
                        <group>
                            <field name="phone"/>
                            <field name="email"/>
                        </group>
                    </group>
                    <group>
                        <field name="address"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Branch Search View -->
    <record id="view_education_branch_search" model="ir.ui.view">
        <field name="name">education.branch.search</field>
        <field name="model">education.branch</field>
        <field name="arch" type="xml">
            <search string="Search Branches">
                <field name="name"/>
                <field name="code"/>
                <filter string="Main Branch" name="main" domain="[('is_main', '=', True)]"/>
                <filter string="Archived" name="archived" domain="[('active', '=', False)]"/>
            </search>
        </field>
    </record>

    <!-- Branch Action -->
    <record id="action_education_branch" model="ir.actions.act_window">
        <field name="name">Branches</field>
        <field name="res_model">education.branch</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first branch!
            </p>
        </field>
    </record>

    <!-- ========================== -->
    <!-- ACADEMIC YEAR VIEWS -->
    <!-- ========================== -->

    <!-- Academic Year Tree View -->
    <record id="view_education_academic_year_tree" model="ir.ui.view">
        <field name="name">education.academic.year.tree</field>
        <field name="model">education.academic.year</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="date_start"/>
                <field name="date_end"/>
                <field name="is_current"/>
                <field name="active" column_invisible="1"/>
            </list>
        </field>
    </record>

    <!-- Academic Year Form View -->
    <record id="view_education_academic_year_form" model="ir.ui.view">
        <field name="name">education.academic.year.form</field>
        <field name="model">education.academic.year</field>
        <field name="arch" type="xml">
            <form string="Academic Year">
                <header>
                    <button name="action_set_current"
                            string="Set as Current"
                            type="object"
                            class="btn-primary"
                            invisible="is_current"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_classes" type="object" class="oe_stat_button" icon="fa-users">
                            <field name="class_count" widget="statinfo" string="Classes"/>
                        </button>
                        <button name="action_view_students" type="object" class="oe_stat_button" icon="fa-graduation-cap">
                            <field name="student_count" widget="statinfo" string="Students"/>
                        </button>
                        <button name="action_view_subscriptions" type="object" class="oe_stat_button" icon="fa-credit-card">
                            <field name="subscription_count" widget="statinfo" string="Subscriptions"/>
                        </button>
                        <button name="action_view_homework" type="object" class="oe_stat_button" icon="fa-book">
                            <field name="homework_count" widget="statinfo" string="Homework"/>
                        </button>
                        <button name="action_view_attendance" type="object" class="oe_stat_button" icon="fa-calendar-check-o">
                            <field name="attendance_count" widget="statinfo" string="Attendance"/>
                        </button>
                        <button name="action_view_evaluations" type="object" class="oe_stat_button" icon="fa-star">
                            <field name="evaluation_count" widget="statinfo" string="Evaluations"/>
                        </button>
                    </div>
                    <widget name="web_ribbon" title="Current Year" bg_color="text-bg-success" invisible="not is_current"/>
                    <widget name="web_ribbon" title="Archived" bg_color="text-bg-danger" invisible="active"/>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" placeholder="e.g., 2024-2025"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="date_start"/>
                            <field name="date_end"/>
                        </group>
                        <group>
                            <field name="is_current"/>
                            <field name="active" invisible="1"/>
                        </group>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Academic Year Search View -->
    <record id="view_education_academic_year_search" model="ir.ui.view">
        <field name="name">education.academic.year.search</field>
        <field name="model">education.academic.year</field>
        <field name="arch" type="xml">
            <search string="Search Academic Years">
                <field name="name"/>
                <filter string="Current Year" name="current" domain="[('is_current', '=', True)]"/>
                <filter string="Archived" name="archived" domain="[('active', '=', False)]"/>
            </search>
        </field>
    </record>

    <!-- Academic Year Action -->
    <record id="action_education_academic_year" model="ir.actions.act_window">
        <field name="name">Academic Years</field>
        <field name="res_model">education.academic.year</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first academic year!
            </p>
        </field>
    </record>

    <!-- ========================== -->
    <!-- ENROLLMENT SOURCE VIEWS -->
    <!-- ========================== -->

    <!-- Enrollment Source Tree View -->
    <record id="view_education_enrollment_source_tree" model="ir.ui.view">
        <field name="name">education.enrollment.source.tree</field>
        <field name="model">education.enrollment.source</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="sequence" widget="handle"/>
                <field name="code"/>
                <field name="name"/>
                <field name="active" column_invisible="1"/>
            </list>
        </field>
    </record>

    <!-- Enrollment Source Action -->
    <record id="action_education_enrollment_source" model="ir.actions.act_window">
        <field name="name">Enrollment Sources</field>
        <field name="res_model">education.enrollment.source</field>
        <field name="view_mode">list</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create enrollment sources (e.g., Website, Referral, Advertisement)
            </p>
        </field>
    </record>

    <!-- ========================== -->
    <!-- LEAVE REASON VIEWS -->
    <!-- ========================== -->

    <!-- Leave Reason Tree View -->
    <record id="view_education_leave_reason_tree" model="ir.ui.view">
        <field name="name">education.leave.reason.tree</field>
        <field name="model">education.leave.reason</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="sequence" widget="handle"/>
                <field name="code"/>
                <field name="name"/>
                <field name="description"/>
                <field name="active" column_invisible="1"/>
            </list>
        </field>
    </record>

    <!-- Leave Reason Action -->
    <record id="action_education_leave_reason" model="ir.actions.act_window">
        <field name="name">Leave Reasons</field>
        <field name="res_model">education.leave.reason</field>
        <field name="view_mode">list</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create leave reasons for student archive
            </p>
        </field>
    </record>

    <!-- ========================== -->
    <!-- CITY VIEWS -->
    <!-- ========================== -->

    <!-- City Tree View -->
    <record id="view_education_city_tree" model="ir.ui.view">
        <field name="name">education.city.tree</field>
        <field name="model">education.city</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="code"/>
                <field name="name"/>
                <field name="country_id"/>
                <field name="active" column_invisible="1"/>
            </list>
        </field>
    </record>

    <!-- City Action -->
    <record id="action_education_city" model="ir.actions.act_window">
        <field name="name">Cities</field>
        <field name="res_model">education.city</field>
        <field name="view_mode">list</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Add cities
            </p>
        </field>
    </record>

    <!-- ========================== -->
    <!-- DAILY NOTE VIEWS -->
    <!-- ========================== -->

    <!-- Daily Note Tree View -->
    <record id="view_education_daily_note_tree" model="ir.ui.view">
        <field name="name">education.daily.note.tree</field>
        <field name="model">education.daily.note</field>
        <field name="arch" type="xml">
            <list>
                <field name="date"/>
                <field name="note"/>
                <field name="branch_id"/>
                <field name="user_id"/>
            </list>
        </field>
    </record>

    <!-- Daily Note Form View -->
    <record id="view_education_daily_note_form" model="ir.ui.view">
        <field name="name">education.daily.note.form</field>
        <field name="model">education.daily.note</field>
        <field name="arch" type="xml">
            <form string="Daily Note">
                <sheet>
                    <group>
                        <group>
                            <field name="date"/>
                            <field name="branch_id"/>
                        </group>
                        <group>
                            <field name="user_id"/>
                        </group>
                    </group>
                    <group>
                        <field name="note"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Daily Note Search View -->
    <record id="view_education_daily_note_search" model="ir.ui.view">
        <field name="name">education.daily.note.search</field>
        <field name="model">education.daily.note</field>
        <field name="arch" type="xml">
            <search string="Search Notes">
                <field name="note"/>
                <field name="date"/>
                <field name="user_id"/>
                <field name="branch_id"/>
                <filter string="Today" name="today" domain="[('date', '=', context_today().strftime('%Y-%m-%d'))]"/>
                <group>
                    <filter string="Date" name="group_date" context="{'group_by': 'date'}"/>
                    <filter string="Branch" name="group_branch" context="{'group_by': 'branch_id'}"/>
                    <filter string="User" name="group_user" context="{'group_by': 'user_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Daily Note Action -->
    <record id="action_education_daily_note" model="ir.actions.act_window">
        <field name="name">Daily Notes</field>
        <field name="res_model">education.daily.note</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_today': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Add a daily note
            </p>
        </field>
    </record>

    <!-- ========================== -->
    <!-- REMINDER VIEWS -->
    <!-- ========================== -->

    <!-- Reminder Tree View -->
    <record id="view_education_reminder_tree" model="ir.ui.view">
        <field name="name">education.reminder.tree</field>
        <field name="model">education.reminder</field>
        <field name="arch" type="xml">
            <list decoration-success="is_done" decoration-danger="priority == '3' and not is_done">
                <field name="date"/>
                <field name="time" widget="float_time"/>
                <field name="title"/>
                <field name="priority"/>
                <field name="user_id"/>
                <field name="is_done"/>
            </list>
        </field>
    </record>

    <!-- Reminder Form View -->
    <record id="view_education_reminder_form" model="ir.ui.view">
        <field name="name">education.reminder.form</field>
        <field name="model">education.reminder</field>
        <field name="arch" type="xml">
            <form string="Reminder">
                <header>
                    <button name="action_mark_done"
                            string="Mark as Done"
                            type="object"
                            class="btn-primary"
                            invisible="is_done"/>
                    <button name="action_mark_undone"
                            string="Reopen"
                            type="object"
                            invisible="not is_done"/>
                </header>
                <sheet>
                    <widget name="web_ribbon" title="Done" bg_color="text-bg-success" invisible="not is_done"/>
                    <div class="oe_title">
                        <label for="title"/>
                        <h1>
                            <field name="title" placeholder="Reminder Title"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="date"/>
                            <field name="time" widget="float_time"/>
                            <field name="priority"/>
                        </group>
                        <group>
                            <field name="user_id"/>
                            <field name="is_done"/>
                        </group>
                    </group>
                    <group>
                        <field name="description"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Reminder Kanban View -->
    <record id="view_education_reminder_kanban" model="ir.ui.view">
        <field name="name">education.reminder.kanban</field>
        <field name="model">education.reminder</field>
        <field name="arch" type="xml">
            <kanban default_group_by="is_done" class="o_kanban_mobile">
                <field name="title"/>
                <field name="date"/>
                <field name="time"/>
                <field name="priority"/>
                <field name="is_done"/>
                <field name="color"/>
                <templates>
                    <t t-name="card">
                        <div t-attf-class="#{record.is_done.raw_value ? 'text-muted' : ''}">
                            <field name="priority" widget="priority"/>
                            <strong><field name="title"/></strong>
                            <div>
                                <field name="date"/> - <field name="time" widget="float_time"/>
                            </div>
                            <field name="user_id" widget="many2one_avatar_user"/>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Reminder Search View -->
    <record id="view_education_reminder_search" model="ir.ui.view">
        <field name="name">education.reminder.search</field>
        <field name="model">education.reminder</field>
        <field name="arch" type="xml">
            <search string="Search Reminders">
                <field name="title"/>
                <field name="user_id"/>
                <filter string="My Reminders" name="my" domain="[('user_id', '=', uid)]"/>
                <filter string="Today" name="today" domain="[('date', '=', context_today().strftime('%Y-%m-%d'))]"/>
                <filter string="Pending" name="pending" domain="[('is_done', '=', False)]"/>
                <filter string="Done" name="done" domain="[('is_done', '=', True)]"/>
                <separator/>
                <filter string="Urgent" name="urgent" domain="[('priority', '=', '3')]"/>
                <group>
                    <filter string="Date" name="group_date" context="{'group_by': 'date'}"/>
                    <filter string="Priority" name="group_priority" context="{'group_by': 'priority'}"/>
                    <filter string="User" name="group_user" context="{'group_by': 'user_id'}"/>
                    <filter string="Status" name="group_status" context="{'group_by': 'is_done'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Reminder Action -->
    <record id="action_education_reminder" model="ir.actions.act_window">
        <field name="name">Reminders</field>
        <field name="res_model">education.reminder</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="context">{'search_default_pending': 1, 'search_default_my': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a reminder
            </p>
        </field>
    </record>

    <!-- ========================== -->
    <!-- SETTINGS VIEWS -->
    <!-- ========================== -->

    <!-- Settings Form View (inheriting res.config.settings) -->
    <record id="view_res_config_settings_education" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.education</field>
        <field name="model">res.config.settings</field>
        <field name="priority">100</field>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <app data-string="Education" string="Education" name="dar_elanwar">
                    <block title="General Settings" name="education_general_settings">
                        <setting string="Default Branch">
                            <div class="content-group">
                                <div class="mt16">
                                    <field name="education_default_branch_id"/>
                                </div>
                            </div>
                        </setting>
                        <setting string="Default Academic Year">
                            <div class="content-group">
                                <div class="mt16">
                                    <field name="education_default_academic_year_id"/>
                                </div>
                            </div>
                        </setting>
                        <setting string="Company Name">
                            <div class="content-group">
                                <div class="mt16">
                                    <field name="education_company_name"/>
                                </div>
                            </div>
                        </setting>
                    </block>
                    <block title="Code Prefixes" name="education_code_prefixes">
                        <setting string="Student Code Prefix">
                            <div class="content-group">
                                <div class="mt16">
                                    <field name="education_student_code_prefix"/>
                                </div>
                            </div>
                        </setting>
                        <setting string="Employee Code Prefix">
                            <div class="content-group">
                                <div class="mt16">
                                    <field name="education_employee_code_prefix"/>
                                </div>
                            </div>
                        </setting>
                        <setting string="Receipt Prefix">
                            <div class="content-group">
                                <div class="mt16">
                                    <field name="education_receipt_prefix"/>
                                </div>
                            </div>
                        </setting>
                    </block>
                    <block title="Features" name="education_features">
                        <setting string="Transportation">
                            <div class="content-group">
                                <div class="mt16">
                                    <field name="education_enable_transportation"/>
                                    <label for="education_enable_transportation" string=" Enable Transportation Module"/>
                                </div>
                            </div>
                        </setting>
                        <setting string="Inventory">
                            <div class="content-group">
                                <div class="mt16">
                                    <field name="education_enable_inventory"/>
                                    <label for="education_enable_inventory" string=" Enable Inventory Module"/>
                                </div>
                            </div>
                        </setting>
                        <setting string="Communication">
                            <div class="content-group">
                                <div class="mt16">
                                    <field name="education_enable_communication"/>
                                    <label for="education_enable_communication" string=" Enable Communication Module"/>
                                </div>
                            </div>
                        </setting>
                    </block>
                </app>
            </xpath>
        </field>
    </record>

</odoo>
