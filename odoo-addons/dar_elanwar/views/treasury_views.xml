<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ========================== -->
    <!-- TRANSACTION CATEGORY VIEWS -->
    <!-- ========================== -->

    <record id="view_education_transaction_category_tree" model="ir.ui.view">
        <field name="name">education.transaction.category.tree</field>
        <field name="model">education.transaction.category</field>
        <field name="arch" type="xml">
            <list>
                <field name="code"/>
                <field name="name"/>
                <field name="type"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_education_transaction_category_form" model="ir.ui.view">
        <field name="name">education.transaction.category.form</field>
        <field name="model">education.transaction.category</field>
        <field name="arch" type="xml">
            <form string="Transaction Category">
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_transactions" type="object" class="oe_stat_button" icon="fa-exchange">
                            <field name="transaction_count" widget="statinfo" string="Transactions"/>
                        </button>
                    </div>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="code"/>
                        </group>
                        <group>
                            <field name="type"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <group>
                        <field name="description"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_education_transaction_category_search" model="ir.ui.view">
        <field name="name">education.transaction.category.search</field>
        <field name="model">education.transaction.category</field>
        <field name="arch" type="xml">
            <search string="Search Categories">
                <field name="name"/>
                <field name="code"/>
                <filter string="Income" name="income" domain="[('type', '=', 'income')]"/>
                <filter string="Expense" name="expense" domain="[('type', '=', 'expense')]"/>
                <separator/>
                <filter string="Active" name="active" domain="[('active', '=', True)]"/>
                <group>
                    <filter string="Type" name="group_type" context="{'group_by': 'type'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_education_transaction_category" model="ir.actions.act_window">
        <field name="name">Transaction Categories</field>
        <field name="res_model">education.transaction.category</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_active': 1}</field>
    </record>

    <record id="action_education_income_category" model="ir.actions.act_window">
        <field name="name">Income Categories</field>
        <field name="res_model">education.transaction.category</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('type', '=', 'income')]</field>
        <field name="context">{'default_type': 'income', 'search_default_active': 1}</field>
    </record>

    <record id="action_education_expense_category" model="ir.actions.act_window">
        <field name="name">Expense Categories</field>
        <field name="res_model">education.transaction.category</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('type', '=', 'expense')]</field>
        <field name="context">{'default_type': 'expense', 'search_default_active': 1}</field>
    </record>

    <!-- ========================== -->
    <!-- TREASURY VIEWS -->
    <!-- ========================== -->

    <record id="view_education_treasury_tree" model="ir.ui.view">
        <field name="name">education.treasury.tree</field>
        <field name="model">education.treasury</field>
        <field name="arch" type="xml">
            <list decoration-success="state == 'closed'" decoration-info="state == 'open'">
                <field name="date"/>
                <field name="branch_id"/>
                <field name="opening_balance"/>
                <field name="total_income"/>
                <field name="total_expense"/>
                <field name="closing_balance"/>
                <field name="responsible_id"/>
                <field name="state" widget="badge"/>
            </list>
        </field>
    </record>

    <record id="view_education_treasury_form" model="ir.ui.view">
        <field name="name">education.treasury.form</field>
        <field name="model">education.treasury</field>
        <field name="arch" type="xml">
            <form string="Daily Treasury">
                <header>
                    <button name="action_open" string="Open" type="object" class="btn-primary" invisible="state != 'draft'"/>
                    <button name="action_close" string="Close" type="object" class="btn-success" invisible="state != 'open'"/>
                    <button name="action_reset" string="Reset to Draft" type="object" invisible="state not in ['open', 'closed']"/>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_branch" type="object" class="oe_stat_button" icon="fa-building">
                            <span class="o_stat_text">Branch</span>
                        </button>
                        <button name="action_view_transactions" type="object" class="oe_stat_button" icon="fa-exchange">
                            <field name="transaction_count" widget="statinfo" string="Transactions"/>
                        </button>
                        <button name="action_view_income" type="object" class="oe_stat_button" icon="fa-plus-circle">
                            <field name="income_count" widget="statinfo" string="Income"/>
                        </button>
                        <button name="action_view_expense" type="object" class="oe_stat_button" icon="fa-minus-circle">
                            <field name="expense_count" widget="statinfo" string="Expense"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <h1>
                            Treasury - <field name="date" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="date" readonly="state != 'draft'"/>
                            <field name="branch_id" readonly="state != 'draft'"/>
                            <field name="responsible_id"/>
                        </group>
                        <group>
                            <field name="opening_balance" readonly="state != 'draft'"/>
                            <field name="total_income"/>
                            <field name="total_expense"/>
                            <field name="closing_balance"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Transactions" name="transactions">
                            <field name="transaction_ids" readonly="state == 'closed'">
                                <list editable="bottom">
                                    <field name="name" readonly="1"/>
                                    <field name="type"/>
                                    <field name="category_id"/>
                                    <field name="description"/>
                                    <field name="amount"/>
                                    <field name="payment_method"/>
                                </list>
                            </field>
                        </page>
                        <page string="Notes" name="notes">
                            <field name="notes" placeholder="Additional notes..."/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_education_treasury_search" model="ir.ui.view">
        <field name="name">education.treasury.search</field>
        <field name="model">education.treasury</field>
        <field name="arch" type="xml">
            <search string="Search Treasury">
                <field name="date"/>
                <field name="branch_id"/>
                <field name="responsible_id"/>
                <filter string="Today" name="today" domain="[('date', '=', context_today().strftime('%Y-%m-%d'))]"/>
                <filter string="This Week" name="this_week" domain="[('date', '&gt;=', (context_today() - relativedelta(days=context_today().weekday())).strftime('%Y-%m-%d'))]"/>
                <filter string="This Month" name="this_month" domain="[('date', '&gt;=', context_today().strftime('%Y-%m-01'))]"/>
                <separator/>
                <filter string="Draft" name="draft" domain="[('state', '=', 'draft')]"/>
                <filter string="Open" name="open" domain="[('state', '=', 'open')]"/>
                <filter string="Closed" name="closed" domain="[('state', '=', 'closed')]"/>
                <separator/>
                <group>
                    <filter string="Date" name="group_date" context="{'group_by': 'date'}"/>
                    <filter string="Branch" name="group_branch" context="{'group_by': 'branch_id'}"/>
                    <filter string="Status" name="group_state" context="{'group_by': 'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_education_treasury" model="ir.actions.act_window">
        <field name="name">Daily Treasury</field>
        <field name="res_model">education.treasury</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- ========================== -->
    <!-- TRANSACTION VIEWS -->
    <!-- ========================== -->

    <record id="view_education_transaction_tree" model="ir.ui.view">
        <field name="name">education.transaction.tree</field>
        <field name="model">education.transaction</field>
        <field name="arch" type="xml">
            <list decoration-success="type == 'income'" decoration-danger="type == 'expense'">
                <field name="name"/>
                <field name="date"/>
                <field name="type"/>
                <field name="category_id"/>
                <field name="description"/>
                <field name="amount"/>
                <field name="payment_method"/>
                <field name="user_id"/>
            </list>
        </field>
    </record>

    <record id="view_education_transaction_form" model="ir.ui.view">
        <field name="name">education.transaction.form</field>
        <field name="model">education.transaction</field>
        <field name="arch" type="xml">
            <form string="Transaction">
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="date"/>
                            <field name="type"/>
                            <field name="category_id"/>
                            <field name="treasury_id"/>
                        </group>
                        <group>
                            <field name="amount"/>
                            <field name="payment_method"/>
                            <field name="reference"/>
                            <field name="user_id"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                    </group>
                    <group>
                        <field name="description" placeholder="Transaction description..."/>
                    </group>
                    <group string="Related Records" groups="base.group_no_one">
                        <group>
                            <field name="student_id"/>
                        </group>
                        <group>
                            <field name="employee_id"/>
                        </group>
                    </group>
                    <group>
                        <field name="notes" placeholder="Additional notes..."/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_education_transaction_search" model="ir.ui.view">
        <field name="name">education.transaction.search</field>
        <field name="model">education.transaction</field>
        <field name="arch" type="xml">
            <search string="Search Transactions">
                <field name="name"/>
                <field name="category_id"/>
                <field name="description"/>
                <field name="student_id"/>
                <field name="employee_id"/>
                <filter string="Income" name="income" domain="[('type', '=', 'income')]"/>
                <filter string="Expense" name="expense" domain="[('type', '=', 'expense')]"/>
                <separator/>
                <filter string="Today" name="today" domain="[('date', '=', context_today().strftime('%Y-%m-%d'))]"/>
                <filter string="This Week" name="this_week" domain="[('date', '&gt;=', (context_today() - relativedelta(days=context_today().weekday())).strftime('%Y-%m-%d'))]"/>
                <filter string="This Month" name="this_month" domain="[('date', '&gt;=', context_today().strftime('%Y-%m-01'))]"/>
                <separator/>
                <filter string="Cash" name="cash" domain="[('payment_method', '=', 'cash')]"/>
                <filter string="Bank" name="bank" domain="[('payment_method', '=', 'bank')]"/>
                <separator/>
                <group>
                    <filter string="Type" name="group_type" context="{'group_by': 'type'}"/>
                    <filter string="Category" name="group_category" context="{'group_by': 'category_id'}"/>
                    <filter string="Date" name="group_date" context="{'group_by': 'date'}"/>
                    <filter string="Payment Method" name="group_payment" context="{'group_by': 'payment_method'}"/>
                    <filter string="User" name="group_user" context="{'group_by': 'user_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_education_transaction" model="ir.actions.act_window">
        <field name="name">Transactions</field>
        <field name="res_model">education.transaction</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="action_education_income" model="ir.actions.act_window">
        <field name="name">Income</field>
        <field name="res_model">education.transaction</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('type', '=', 'income')]</field>
        <field name="context">{'default_type': 'income'}</field>
    </record>

    <record id="action_education_expense" model="ir.actions.act_window">
        <field name="name">Expenses</field>
        <field name="res_model">education.transaction</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('type', '=', 'expense')]</field>
        <field name="context">{'default_type': 'expense'}</field>
    </record>

</odoo>
