<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================ -->
    <!-- education.admission.application : Form View                  -->
    <!-- ============================================================ -->
    <record id="view_education_admission_application_form" model="ir.ui.view">
        <field name="name">education.admission.application.form</field>
        <field name="model">education.admission.application</field>
        <field name="arch" type="xml">
            <form string="Admission Application">
                <header>
                    <button name="action_assess"
                            string="Assess"
                            type="object"
                            class="btn-primary"
                            invisible="stage != 'new'"/>
                    <button name="action_accept"
                            string="Accept"
                            type="object"
                            class="btn-primary"
                            invisible="stage != 'assessment'"/>
                    <button name="action_waitlist"
                            string="Waitlist"
                            type="object"
                            class="btn-warning"
                            invisible="stage not in ('new', 'assessment')"/>
                    <button name="action_reject"
                            string="Reject"
                            type="object"
                            class="btn-danger"
                            invisible="stage in ('rejected', 'enrolled')"/>
                    <button name="action_enroll"
                            string="Enroll"
                            type="object"
                            class="btn-success"
                            invisible="stage != 'accepted'"/>
                    <field name="stage"
                           widget="statusbar"
                           statusbar_visible="new,assessment,accepted,enrolled"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Student Information">
                            <field name="student_name"/>
                            <field name="arabic_name"/>
                            <field name="birthdate"/>
                            <field name="gender"/>
                            <field name="priority" widget="priority"/>
                        </group>
                        <group string="Parent Information">
                            <field name="parent_name"/>
                            <field name="parent_phone" widget="phone"/>
                            <field name="parent_email" widget="email"/>
                            <field name="parent_national_id"/>
                        </group>
                    </group>
                    <group>
                        <group string="Academic Information">
                            <field name="department_id"/>
                            <field name="level_id"/>
                            <field name="branch_id"/>
                            <field name="academic_year_id"/>
                            <field name="source_id"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Documents" name="documents">
                            <field name="document_ids">
                                <list editable="bottom">
                                    <field name="name"/>
                                    <field name="document_type"/>
                                    <field name="is_required"/>
                                    <field name="is_received"/>
                                    <field name="file" widget="binary" filename="name"/>
                                </list>
                            </field>
                        </page>
                        <page string="Notes" name="notes">
                            <field name="notes"
                                   placeholder="Internal notes about this application..."
                                   nolabel="1"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- ============================================================ -->
    <!-- education.admission.application : Tree View                  -->
    <!-- ============================================================ -->
    <record id="view_education_admission_application_tree" model="ir.ui.view">
        <field name="name">education.admission.application.tree</field>
        <field name="model">education.admission.application</field>
        <field name="arch" type="xml">
            <list string="Admission Applications"
                  decoration-success="stage == 'accepted'"
                  decoration-danger="stage == 'rejected'"
                  decoration-info="stage == 'enrolled'"
                  decoration-warning="stage == 'waitlisted'">
                <field name="name"/>
                <field name="student_name"/>
                <field name="parent_name"/>
                <field name="department_id"/>
                <field name="stage"
                       widget="badge"
                       decoration-success="stage == 'accepted'"
                       decoration-danger="stage == 'rejected'"
                       decoration-info="stage == 'enrolled'"
                       decoration-warning="stage == 'waitlisted'"/>
                <field name="date"/>
                <field name="priority" widget="priority"/>
            </list>
        </field>
    </record>

    <!-- ============================================================ -->
    <!-- education.admission.application : Kanban View                -->
    <!-- ============================================================ -->
    <record id="view_education_admission_application_kanban" model="ir.ui.view">
        <field name="name">education.admission.application.kanban</field>
        <field name="model">education.admission.application</field>
        <field name="arch" type="xml">
            <kanban default_group_by="stage"
                    class="o_kanban_small_column"
                    quick_create="false">
                <field name="student_name"/>
                <field name="parent_phone"/>
                <field name="department_id"/>
                <field name="stage"/>
                <field name="priority"/>
                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_content">
                            <div class="o_kanban_record_top mb-0">
                                <div class="o_kanban_record_headings">
                                    <strong class="o_kanban_record_title">
                                        <field name="student_name"/>
                                    </strong>
                                </div>
                                <div class="o_kanban_record_top_right">
                                    <field name="priority" widget="priority"/>
                                </div>
                            </div>
                            <div class="o_kanban_record_body">
                                <div t-if="record.parent_phone.raw_value">
                                    <i class="fa fa-phone" role="img" aria-label="Phone"/>
                                    <field name="parent_phone" widget="phone"/>
                                </div>
                                <div t-if="record.department_id.value">
                                    <field name="department_id"/>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- ============================================================ -->
    <!-- education.admission.application : Search View                -->
    <!-- ============================================================ -->
    <record id="view_education_admission_application_search" model="ir.ui.view">
        <field name="name">education.admission.application.search</field>
        <field name="model">education.admission.application</field>
        <field name="arch" type="xml">
            <search string="Search Applications">
                <field name="student_name"/>
                <field name="parent_name"/>
                <field name="department_id"/>
                <filter string="New"
                        name="filter_new"
                        domain="[('stage', '=', 'new')]"/>
                <filter string="Assessment"
                        name="filter_assessment"
                        domain="[('stage', '=', 'assessment')]"/>
                <filter string="Accepted"
                        name="filter_accepted"
                        domain="[('stage', '=', 'accepted')]"/>
                <filter string="Waitlisted"
                        name="filter_waitlisted"
                        domain="[('stage', '=', 'waitlisted')]"/>
                <filter string="Enrolled"
                        name="filter_enrolled"
                        domain="[('stage', '=', 'enrolled')]"/>
                <filter string="Rejected"
                        name="filter_rejected"
                        domain="[('stage', '=', 'rejected')]"/>
                <group>
                    <filter string="Stage"
                            name="group_stage"
                            context="{'group_by': 'stage'}"/>
                    <filter string="Department"
                            name="group_department"
                            context="{'group_by': 'department_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ============================================================ -->
    <!-- education.admission.application : Action                     -->
    <!-- ============================================================ -->
    <record id="action_education_admission" model="ir.actions.act_window">
        <field name="name">Admission Applications</field>
        <field name="res_model">education.admission.application</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="search_view_id" ref="view_education_admission_application_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a new admission application
            </p>
            <p>
                Manage the full admission pipeline from application to enrollment.
            </p>
        </field>
    </record>

    <!-- ============================================================ -->
    <!-- education.admission.criteria : Form View                     -->
    <!-- ============================================================ -->
    <record id="view_education_admission_criteria_form" model="ir.ui.view">
        <field name="name">education.admission.criteria.form</field>
        <field name="model">education.admission.criteria</field>
        <field name="arch" type="xml">
            <form string="Admission Criteria">
                <sheet>
                    <group>
                        <group>
                            <field name="department_id"/>
                            <field name="level_id"/>
                            <field name="academic_year_id"/>
                        </group>
                        <group>
                            <field name="min_age"/>
                            <field name="max_age"/>
                            <field name="capacity"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ============================================================ -->
    <!-- education.admission.criteria : Tree View                     -->
    <!-- ============================================================ -->
    <record id="view_education_admission_criteria_tree" model="ir.ui.view">
        <field name="name">education.admission.criteria.tree</field>
        <field name="model">education.admission.criteria</field>
        <field name="arch" type="xml">
            <list string="Admission Criteria">
                <field name="department_id"/>
                <field name="level_id"/>
                <field name="min_age"/>
                <field name="max_age"/>
                <field name="capacity"/>
                <field name="academic_year_id"/>
            </list>
        </field>
    </record>

    <!-- ============================================================ -->
    <!-- education.admission.criteria : Action                        -->
    <!-- ============================================================ -->
    <record id="action_education_admission_criteria" model="ir.actions.act_window">
        <field name="name">Admission Criteria</field>
        <field name="res_model">education.admission.criteria</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Define admission criteria
            </p>
            <p>
                Set age limits and capacity for each department and level.
            </p>
        </field>
    </record>

</odoo>
