<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ========================== -->
    <!-- EMPLOYEE CATEGORY VIEWS -->
    <!-- ========================== -->

    <record id="view_education_employee_category_tree" model="ir.ui.view">
        <field name="name">education.employee.category.tree</field>
        <field name="model">education.employee.category</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="sequence" widget="handle"/>
                <field name="code"/>
                <field name="name"/>
                <field name="description"/>
            </list>
        </field>
    </record>

    <record id="action_education_employee_category" model="ir.actions.act_window">
        <field name="name">Employee Categories</field>
        <field name="res_model">education.employee.category</field>
        <field name="view_mode">list</field>
    </record>

    <!-- ========================== -->
    <!-- EMPLOYEE VIEWS -->
    <!-- ========================== -->

    <record id="view_education_employee_tree" model="ir.ui.view">
        <field name="name">education.employee.tree</field>
        <field name="model">education.employee</field>
        <field name="arch" type="xml">
            <list decoration-muted="state == 'terminated'">
                <field name="code"/>
                <field name="name"/>
                <field name="job_title"/>
                <field name="category_id"/>
                <field name="department_id"/>
                <field name="phone"/>
                <field name="is_teacher"/>
                <field name="state" widget="badge" decoration-info="state == 'draft'" decoration-success="state == 'active'" decoration-warning="state == 'on_leave'" decoration-danger="state == 'terminated'"/>
            </list>
        </field>
    </record>

    <record id="view_education_employee_form" model="ir.ui.view">
        <field name="name">education.employee.form</field>
        <field name="model">education.employee</field>
        <field name="arch" type="xml">
            <form string="Employee">
                <header>
                    <button name="action_activate" string="Activate" type="object" class="btn-primary" invisible="state != 'draft'"/>
                    <button name="action_on_leave" string="On Leave" type="object" invisible="state != 'active'"/>
                    <button name="action_activate" string="Return from Leave" type="object" class="btn-primary" invisible="state != 'on_leave'"/>
                    <button name="action_terminate" string="Terminate" type="object" invisible="state in ['draft', 'terminated']" confirm="Are you sure you want to terminate this employee?"/>
                    <button name="action_reactivate" string="Reactivate" type="object" class="btn-primary" invisible="state != 'terminated'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,active"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_attendance" type="object" class="oe_stat_button" icon="fa-calendar-check-o">
                            <field name="attendance_count" widget="statinfo" string="Attendance"/>
                        </button>
                        <button name="action_view_salaries" type="object" class="oe_stat_button" icon="fa-money">
                            <field name="salary_count" widget="statinfo" string="Salaries"/>
                        </button>
                        <button name="action_view_loans" type="object" class="oe_stat_button" icon="fa-bank">
                            <field name="loan_count" widget="statinfo" string="Loans"/>
                        </button>
                        <button name="action_view_penalties" type="object" class="oe_stat_button" icon="fa-warning">
                            <field name="penalty_count" widget="statinfo" string="Penalties"/>
                        </button>
                        <button name="action_view_complaints" type="object" class="oe_stat_button" icon="fa-exclamation-circle">
                            <field name="complaint_count" widget="statinfo" string="Complaints"/>
                        </button>
                        <button name="action_view_classes" type="object" class="oe_stat_button" icon="fa-users" invisible="not is_teacher">
                            <field name="class_count" widget="statinfo" string="Classes"/>
                        </button>
                        <button name="action_view_homework" type="object" class="oe_stat_button" icon="fa-book" invisible="not is_teacher">
                            <field name="homework_count" widget="statinfo" string="Homework"/>
                        </button>
                        <button name="action_view_evaluations" type="object" class="oe_stat_button" icon="fa-star" invisible="not is_teacher">
                            <field name="evaluation_count" widget="statinfo" string="Evaluations"/>
                        </button>
                    </div>
                    <field name="photo" widget="image" class="oe_avatar"/>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" placeholder="Full Name"/>
                        </h1>
                        <field name="job_title" placeholder="Job Title"/>
                    </div>
                    <group>
                        <group>
                            <field name="code"/>
                            <field name="category_id"/>
                            <field name="department_id"/>
                            <field name="branch_id"/>
                            <field name="is_teacher"/>
                        </group>
                        <group>
                            <field name="phone"/>
                            <field name="mobile"/>
                            <field name="email"/>
                            <field name="user_id"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Personal Info" name="personal">
                            <group>
                                <group>
                                    <field name="birthdate"/>
                                    <field name="age"/>
                                    <field name="gender"/>
                                    <field name="id_number"/>
                                </group>
                                <group>
                                    <field name="hire_date"/>
                                    <field name="end_date" invisible="state != 'terminated'"/>
                                    <field name="qualification"/>
                                </group>
                            </group>
                            <group>
                                <field name="address"/>
                            </group>
                        </page>
                        <page string="Salary" name="salary">
                            <group>
                                <group>
                                    <label for="salary"/>
                                    <div class="o_row">
                                        <field name="salary"/>
                                        <field name="currency_id" groups="base.group_multi_currency"/>
                                    </div>
                                </group>
                            </group>
                            <field name="salary_ids">
                                <list>
                                    <field name="month"/>
                                    <field name="year"/>
                                    <field name="basic_salary"/>
                                    <field name="bonuses"/>
                                    <field name="deductions"/>
                                    <field name="net_salary"/>
                                    <field name="state" widget="badge"/>
                                </list>
                            </field>
                        </page>
                        <page string="Qualifications" name="qualifications">
                            <field name="qualification_ids">
                                <list editable="bottom">
                                    <field name="name"/>
                                    <field name="institution"/>
                                    <field name="date"/>
                                    <field name="certificate" filename="certificate_filename"/>
                                    <field name="certificate_filename" column_invisible="1"/>
                                </list>
                            </field>
                        </page>
                        <page string="Attendance" name="attendance">
                            <field name="attendance_ids">
                                <list>
                                    <field name="date"/>
                                    <field name="check_in" widget="float_time"/>
                                    <field name="check_out" widget="float_time"/>
                                    <field name="worked_hours" widget="float_time"/>
                                    <field name="status"/>
                                </list>
                            </field>
                        </page>
                        <page string="Penalties" name="penalties">
                            <field name="penalty_ids">
                                <list>
                                    <field name="date"/>
                                    <field name="penalty_type"/>
                                    <field name="reason"/>
                                    <field name="amount"/>
                                    <field name="is_applied"/>
                                </list>
                            </field>
                        </page>
                        <page string="Loans" name="loans">
                            <field name="loan_ids">
                                <list>
                                    <field name="request_date"/>
                                    <field name="amount"/>
                                    <field name="repayment_months"/>
                                    <field name="remaining_amount"/>
                                    <field name="status" widget="badge"/>
                                </list>
                            </field>
                        </page>
                        <page string="Complaints" name="complaints">
                            <field name="complaint_ids">
                                <list>
                                    <field name="date"/>
                                    <field name="complainant"/>
                                    <field name="complaint"/>
                                    <field name="status" widget="badge"/>
                                </list>
                            </field>
                        </page>
                        <page string="Notes" name="notes">
                            <field name="notes"/>
                        </page>
                    </notebook>
                    <field name="active" invisible="1"/>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_education_employee_kanban" model="ir.ui.view">
        <field name="name">education.employee.kanban</field>
        <field name="model">education.employee</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_mobile">
                <field name="name"/>
                <field name="photo"/>
                <field name="job_title"/>
                <field name="state"/>
                <templates>
                    <t t-name="card">
                        <div class="o_kanban_image">
                            <field name="photo" widget="image"/>
                        </div>
                        <div class="oe_kanban_details">
                            <strong><field name="name"/></strong>
                            <div><field name="job_title"/></div>
                            <div><field name="state" widget="badge"/></div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="view_education_employee_search" model="ir.ui.view">
        <field name="name">education.employee.search</field>
        <field name="model">education.employee</field>
        <field name="arch" type="xml">
            <search string="Search Employees">
                <field name="name"/>
                <field name="code"/>
                <field name="job_title"/>
                <field name="department_id"/>
                <field name="category_id"/>
                <filter string="Teachers" name="teachers" domain="[('is_teacher', '=', True)]"/>
                <filter string="Active" name="active_state" domain="[('state', '=', 'active')]"/>
                <filter string="On Leave" name="on_leave" domain="[('state', '=', 'on_leave')]"/>
                <filter string="Terminated" name="terminated" domain="[('state', '=', 'terminated')]"/>
                <group>
                    <filter string="Category" name="group_category" context="{'group_by': 'category_id'}"/>
                    <filter string="Department" name="group_department" context="{'group_by': 'department_id'}"/>
                    <filter string="Status" name="group_state" context="{'group_by': 'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_education_employee" model="ir.actions.act_window">
        <field name="name">Employees</field>
        <field name="res_model">education.employee</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="context">{'search_default_active_state': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Add your first employee!</p>
        </field>
    </record>

    <record id="action_education_employee_teachers" model="ir.actions.act_window">
        <field name="name">Teachers</field>
        <field name="res_model">education.employee</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="domain">[('is_teacher', '=', True)]</field>
        <field name="context">{'default_is_teacher': True}</field>
    </record>

    <!-- ========================== -->
    <!-- EMPLOYEE ATTENDANCE VIEWS -->
    <!-- ========================== -->

    <record id="view_education_employee_attendance_tree" model="ir.ui.view">
        <field name="name">education.employee.attendance.tree</field>
        <field name="model">education.employee.attendance</field>
        <field name="arch" type="xml">
            <list editable="bottom" decoration-danger="status == 'absent'" decoration-warning="status == 'late'">
                <field name="date"/>
                <field name="employee_id"/>
                <field name="check_in" widget="float_time"/>
                <field name="check_out" widget="float_time"/>
                <field name="worked_hours" widget="float_time"/>
                <field name="status"/>
                <field name="notes"/>
            </list>
        </field>
    </record>

    <record id="view_education_employee_attendance_search" model="ir.ui.view">
        <field name="name">education.employee.attendance.search</field>
        <field name="model">education.employee.attendance</field>
        <field name="arch" type="xml">
            <search string="Search Attendance">
                <field name="employee_id"/>
                <field name="date"/>
                <filter string="Today" name="today" domain="[('date', '=', context_today().strftime('%Y-%m-%d'))]"/>
                <filter string="Present" name="present" domain="[('status', '=', 'present')]"/>
                <filter string="Absent" name="absent" domain="[('status', '=', 'absent')]"/>
                <filter string="Late" name="late" domain="[('status', '=', 'late')]"/>
                <group>
                    <filter string="Employee" name="group_employee" context="{'group_by': 'employee_id'}"/>
                    <filter string="Date" name="group_date" context="{'group_by': 'date'}"/>
                    <filter string="Status" name="group_status" context="{'group_by': 'status'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_education_employee_attendance" model="ir.actions.act_window">
        <field name="name">Employee Attendance</field>
        <field name="res_model">education.employee.attendance</field>
        <field name="view_mode">list</field>
        <field name="context">{'search_default_today': 1}</field>
    </record>

    <!-- ========================== -->
    <!-- EMPLOYEE SALARY VIEWS -->
    <!-- ========================== -->

    <record id="view_education_employee_salary_tree" model="ir.ui.view">
        <field name="name">education.employee.salary.tree</field>
        <field name="model">education.employee.salary</field>
        <field name="arch" type="xml">
            <list decoration-success="state == 'paid'" decoration-muted="state == 'cancelled'">
                <field name="employee_id"/>
                <field name="month"/>
                <field name="year"/>
                <field name="basic_salary"/>
                <field name="bonuses"/>
                <field name="deductions"/>
                <field name="net_salary"/>
                <field name="state" widget="badge"/>
            </list>
        </field>
    </record>

    <record id="view_education_employee_salary_form" model="ir.ui.view">
        <field name="name">education.employee.salary.form</field>
        <field name="model">education.employee.salary</field>
        <field name="arch" type="xml">
            <form string="Salary">
                <header>
                    <button name="action_confirm" string="Confirm" type="object" class="btn-primary" invisible="state != 'draft'"/>
                    <button name="action_pay" string="Mark as Paid" type="object" class="btn-primary" invisible="state != 'confirmed'"/>
                    <button name="action_cancel" string="Cancel" type="object" invisible="state in ['paid', 'cancelled']"/>
                    <button name="action_reset" string="Reset to Draft" type="object" invisible="state != 'cancelled'"/>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="employee_id"/>
                            <field name="month"/>
                            <field name="year"/>
                        </group>
                        <group>
                            <field name="paid_date" invisible="state != 'paid'"/>
                            <field name="paid_by" invisible="state != 'paid'"/>
                        </group>
                    </group>
                    <group>
                        <group>
                            <field name="basic_salary"/>
                            <field name="bonuses"/>
                        </group>
                        <group>
                            <field name="deductions"/>
                            <field name="loan_deduction"/>
                            <field name="penalty_deduction"/>
                        </group>
                    </group>
                    <group>
                        <field name="net_salary"/>
                    </group>
                    <group>
                        <field name="notes"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_education_employee_salary" model="ir.actions.act_window">
        <field name="name">Salaries</field>
        <field name="res_model">education.employee.salary</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- ========================== -->
    <!-- EMPLOYEE PENALTY VIEWS -->
    <!-- ========================== -->

    <record id="view_education_employee_penalty_tree" model="ir.ui.view">
        <field name="name">education.employee.penalty.tree</field>
        <field name="model">education.employee.penalty</field>
        <field name="arch" type="xml">
            <list>
                <field name="date"/>
                <field name="employee_id"/>
                <field name="penalty_type"/>
                <field name="reason"/>
                <field name="amount"/>
                <field name="is_applied"/>
            </list>
        </field>
    </record>

    <record id="action_education_employee_penalty" model="ir.actions.act_window">
        <field name="name">Penalties</field>
        <field name="res_model">education.employee.penalty</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- ========================== -->
    <!-- EMPLOYEE LOAN VIEWS -->
    <!-- ========================== -->

    <record id="view_education_employee_loan_tree" model="ir.ui.view">
        <field name="name">education.employee.loan.tree</field>
        <field name="model">education.employee.loan</field>
        <field name="arch" type="xml">
            <list decoration-success="status == 'completed'" decoration-info="status in ['approved', 'paid']">
                <field name="request_date"/>
                <field name="employee_id"/>
                <field name="amount"/>
                <field name="repayment_months"/>
                <field name="remaining_amount"/>
                <field name="status" widget="badge"/>
            </list>
        </field>
    </record>

    <record id="view_education_employee_loan_form" model="ir.ui.view">
        <field name="name">education.employee.loan.form</field>
        <field name="model">education.employee.loan</field>
        <field name="arch" type="xml">
            <form string="Loan">
                <header>
                    <button name="action_request" string="Submit Request" type="object" class="btn-primary" invisible="status != 'draft'"/>
                    <button name="action_approve" string="Approve" type="object" class="btn-primary" invisible="status != 'requested'"/>
                    <button name="action_reject" string="Reject" type="object" invisible="status != 'requested'"/>
                    <button name="action_pay" string="Pay to Employee" type="object" class="btn-primary" invisible="status != 'approved'"/>
                    <button name="action_complete" string="Mark Completed" type="object" class="btn-success" invisible="status != 'repaying'"/>
                    <field name="status" widget="statusbar"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="employee_id"/>
                            <field name="request_date"/>
                            <field name="amount"/>
                        </group>
                        <group>
                            <field name="repayment_months"/>
                            <field name="monthly_deduction"/>
                            <field name="remaining_amount"/>
                        </group>
                    </group>
                    <group>
                        <field name="reason"/>
                    </group>
                    <group invisible="status not in ['approved', 'paid', 'repaying', 'completed']">
                        <group>
                            <field name="approved_by"/>
                            <field name="approval_date"/>
                        </group>
                        <group>
                            <field name="paid_date"/>
                        </group>
                    </group>
                    <group>
                        <field name="notes"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_education_employee_loan" model="ir.actions.act_window">
        <field name="name">Loans</field>
        <field name="res_model">education.employee.loan</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- ========================== -->
    <!-- EMPLOYEE COMPLAINT VIEWS -->
    <!-- ========================== -->

    <record id="view_education_employee_complaint_tree" model="ir.ui.view">
        <field name="name">education.employee.complaint.tree</field>
        <field name="model">education.employee.complaint</field>
        <field name="arch" type="xml">
            <list decoration-success="status == 'resolved'" decoration-muted="status == 'dismissed'">
                <field name="date"/>
                <field name="employee_id"/>
                <field name="complainant"/>
                <field name="complaint"/>
                <field name="status" widget="badge"/>
            </list>
        </field>
    </record>

    <record id="action_education_employee_complaint" model="ir.actions.act_window">
        <field name="name">Complaints</field>
        <field name="res_model">education.employee.complaint</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
