<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ========================== -->
    <!-- STUDENT VIEWS -->
    <!-- ========================== -->

    <!-- Student Tree View -->
    <record id="view_education_student_tree" model="ir.ui.view">
        <field name="name">education.student.tree</field>
        <field name="model">res.partner</field>
        <field name="priority">50</field>
        <field name="arch" type="xml">
            <list decoration-info="student_state == 'draft'" decoration-warning="student_state == 'pending'" decoration-muted="student_state == 'archived'">
                <field name="code"/>
                <field name="name"/>
                <field name="arabic_name" optional="hide"/>
                <field name="gender"/>
                <field name="age"/>
                <field name="department_id"/>
                <field name="class_id"/>
                <field name="period"/>
                <field name="student_state" widget="badge" decoration-info="student_state == 'draft'" decoration-warning="student_state == 'pending'" decoration-success="student_state == 'enrolled'" decoration-danger="student_state == 'archived'"/>
                <field name="active" column_invisible="1"/>
            </list>
        </field>
    </record>

    <!-- Student Form View -->
    <record id="view_education_student_form" model="ir.ui.view">
        <field name="name">education.student.form</field>
        <field name="model">res.partner</field>
        <field name="priority">50</field>
        <field name="arch" type="xml">
            <form string="Student">
                <header>
                    <button name="action_pending"
                            string="Submit for Enrollment"
                            type="object"
                            class="btn-primary"
                            invisible="student_state != 'draft'"/>
                    <button name="action_enroll"
                            string="Enroll"
                            type="object"
                            class="btn-primary"
                            invisible="student_state != 'pending'"/>
                    <button name="action_archive_student"
                            string="Archive"
                            type="object"
                            invisible="student_state not in ['enrolled', 'pending']"
                            confirm="Are you sure you want to archive this student?"/>
                    <button name="action_reactivate"
                            string="Reactivate"
                            type="object"
                            class="btn-primary"
                            invisible="student_state != 'archived'"/>
                    <field name="student_state" widget="statusbar" statusbar_visible="draft,pending,enrolled"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_subscriptions" type="object" class="oe_stat_button" icon="fa-credit-card">
                            <field name="subscription_count" widget="statinfo" string="Subscriptions"/>
                        </button>
                        <button name="action_view_payments" type="object" class="oe_stat_button" icon="fa-money">
                            <field name="payment_count" widget="statinfo" string="Payments"/>
                        </button>
                        <button name="action_view_receipts" type="object" class="oe_stat_button" icon="fa-file-text-o">
                            <field name="receipt_count" widget="statinfo" string="Receipts"/>
                        </button>
                        <button name="action_view_attendance" type="object" class="oe_stat_button" icon="fa-calendar-check-o">
                            <field name="attendance_count" widget="statinfo" string="Attendance"/>
                        </button>
                        <button name="action_view_evaluations" type="object" class="oe_stat_button" icon="fa-star">
                            <field name="evaluation_count" widget="statinfo" string="Evaluations"/>
                        </button>
                        <button name="action_view_homework" type="object" class="oe_stat_button" icon="fa-book">
                            <field name="homework_count" widget="statinfo" string="Homework"/>
                        </button>
                        <button name="action_view_transport" type="object" class="oe_stat_button" icon="fa-bus">
                            <field name="transport_count" widget="statinfo" string="Transport"/>
                        </button>
                        <button name="action_view_stock_out" type="object" class="oe_stat_button" icon="fa-archive">
                            <field name="stock_out_count" widget="statinfo" string="Stock Out"/>
                        </button>
                        <button name="action_view_messages" type="object" class="oe_stat_button" icon="fa-envelope">
                            <field name="student_message_count" widget="statinfo" string="Messages"/>
                        </button>
                        <button name="action_view_siblings" type="object" class="oe_stat_button" icon="fa-users">
                            <field name="sibling_count" widget="statinfo" string="Siblings"/>
                        </button>
                        <button name="action_view_notes" type="object" class="oe_stat_button" icon="fa-sticky-note">
                            <field name="student_note_count" widget="statinfo" string="Notes"/>
                        </button>
                        <button name="action_view_balance" type="object" class="oe_stat_button" icon="fa-money">
                            <div class="o_stat_info">
                                <field name="balance_due" widget="monetary"/>
                                <span class="o_stat_text">Balance Due</span>
                            </div>
                        </button>
                        <button name="action_view_account_statement" type="object" class="oe_stat_button" icon="fa-book">
                            <div class="o_stat_info">
                                <span class="o_stat_text">Account Statement</span>
                            </div>
                        </button>
                        <button name="action_view_installments" type="object" class="oe_stat_button" icon="fa-calendar">
                            <field name="installment_count" widget="statinfo" string="Installments"/>
                        </button>
                        <button name="action_view_goals" type="object" class="oe_stat_button" icon="fa-trophy">
                            <field name="goal_count" widget="statinfo" string="Goals"/>
                        </button>
                    </div>
                    <widget name="web_ribbon" title="Archived" bg_color="text-bg-danger" invisible="active"/>
                    <field name="image_1920" widget="image" class="oe_avatar"/>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" placeholder="Full Name (English)"/>
                        </h1>
                        <h2>
                            <field name="arabic_name" placeholder="Full Name (Arabic)"/>
                        </h2>
                    </div>
                    <group>
                        <group>
                            <field name="code"/>
                            <field name="birthdate"/>
                            <field name="age"/>
                            <field name="gender"/>
                            <field name="country_id" string="Nationality"/>
                            <field name="id_number" string="National ID"/>
                            <field name="religion"/>
                            <field name="birth_place"/>
                            <field name="birth_order"/>
                        </group>
                        <group>
                            <field name="department_id"/>
                            <field name="class_id"/>
                            <field name="period"/>
                            <field name="branch_id"/>
                            <field name="admission_time"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Parents" name="parents">
                            <group>
                                <group>
                                    <field name="father_id"/>
                                </group>
                                <group>
                                    <field name="mother_id"/>
                                </group>
                            </group>
                        </page>
                        <page string="Enrollment" name="enrollment">
                            <group>
                                <group>
                                    <field name="enrollment_date"/>
                                    <field name="enrollment_source_id"/>
                                    <field name="academic_year_id"/>
                                </group>
                                <group>
                                    <field name="phone"/>
                                    <field name="student_city_id"/>
                                </group>
                            </group>
                            <group>
                                <field name="street" string="Address"/>
                            </group>
                        </page>
                        <page string="Health" name="health">
                            <group>
                                <group>
                                    <field name="blood_type"/>
                                </group>
                                <group>
                                    <field name="allergies"/>
                                </group>
                            </group>
                            <group>
                                <field name="medical_notes"/>
                            </group>
                        </page>
                        <page string="Siblings" name="siblings">
                            <field name="sibling_ids">
                                <list editable="bottom">
                                    <field name="name"/>
                                    <field name="birthdate"/>
                                    <field name="gender"/>
                                    <field name="age"/>
                                    <field name="is_enrolled"/>
                                    <field name="enrolled_student_id" invisible="not is_enrolled"/>
                                </list>
                            </field>
                        </page>
                        <page string="Authorized Pickup" name="pickup">
                            <field name="authorized_pickup_ids">
                                <list editable="bottom">
                                    <field name="name"/>
                                    <field name="relation"/>
                                    <field name="phone"/>
                                    <field name="id_number"/>
                                </list>
                            </field>
                        </page>
                        <page string="Notes" name="notes">
                            <field name="student_note_ids">
                                <list>
                                    <field name="date"/>
                                    <field name="note_type"/>
                                    <field name="note"/>
                                    <field name="is_important"/>
                                    <field name="user_id"/>
                                </list>
                            </field>
                            <group>
                                <field name="comment" string="General Notes"/>
                            </group>
                        </page>
                        <page string="Study Plans" name="study_plans">
                            <field name="study_plan_ids">
                                <list editable="bottom">
                                    <field name="name"/>
                                    <field name="academic_year_id"/>
                                    <field name="subject_id"/>
                                    <field name="teacher_id"/>
                                    <field name="schedule"/>
                                    <field name="notes"/>
                                </list>
                            </field>
                        </page>
                        <page string="Financial Plans" name="financial_plans">
                            <field name="financial_plan_ids">
                                <list editable="bottom">
                                    <field name="name"/>
                                    <field name="subscription_id"/>
                                    <field name="total_amount"/>
                                    <field name="paid_amount"/>
                                    <field name="remaining_amount"/>
                                    <field name="installment_count"/>
                                    <field name="start_date"/>
                                    <field name="end_date"/>
                                    <field name="status"/>
                                </list>
                            </field>
                        </page>
                        <page string="Archive History" name="archive_history" invisible="not archive_ids">
                            <field name="archive_ids">
                                <list>
                                    <field name="archive_date"/>
                                    <field name="reason_id"/>
                                    <field name="return_date"/>
                                    <field name="notes"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                    <field name="active" invisible="1"/>
                    <field name="is_student" invisible="1"/>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Student Kanban View -->
    <record id="view_education_student_kanban" model="ir.ui.view">
        <field name="name">education.student.kanban</field>
        <field name="model">res.partner</field>
        <field name="priority">50</field>
        <field name="arch" type="xml">
            <kanban default_group_by="class_id" class="o_kanban_small_column">
                <field name="code"/>
                <field name="name"/>
                <field name="image_1920"/>
                <field name="student_state"/>
                <field name="class_id"/>
                <field name="age"/>
                <templates>
                    <t t-name="card">
                        <div class="o_kanban_image">
                            <field name="image_1920" widget="image" options="{'preview_image': 'image_128'}"/>
                        </div>
                        <div class="oe_kanban_details">
                            <strong><field name="name"/></strong>
                            <div><field name="code"/></div>
                            <div><field name="age"/></div>
                            <div><field name="student_state" widget="badge"/></div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Student Search View -->
    <record id="view_education_student_search" model="ir.ui.view">
        <field name="name">education.student.search</field>
        <field name="model">res.partner</field>
        <field name="priority">50</field>
        <field name="arch" type="xml">
            <search string="Search Students">
                <field name="code"/>
                <field name="name"/>
                <field name="arabic_name"/>
                <field name="department_id"/>
                <field name="class_id"/>
                <field name="father_id"/>
                <field name="mother_id"/>
                <filter string="Draft" name="draft" domain="[('student_state', '=', 'draft')]"/>
                <filter string="Pending" name="pending" domain="[('student_state', '=', 'pending')]"/>
                <filter string="Enrolled" name="enrolled" domain="[('student_state', '=', 'enrolled')]"/>
                <filter string="Archived" name="archived" domain="[('student_state', '=', 'archived')]"/>
                <separator/>
                <filter string="Male" name="male" domain="[('gender', '=', 'male')]"/>
                <filter string="Female" name="female" domain="[('gender', '=', 'female')]"/>
                <separator/>
                <filter string="Morning" name="morning" domain="[('period', '=', 'morning')]"/>
                <filter string="Afternoon" name="afternoon" domain="[('period', '=', 'afternoon')]"/>
                <group>
                    <filter string="Department" name="group_department" context="{'group_by': 'department_id'}"/>
                    <filter string="Class" name="group_class" context="{'group_by': 'class_id'}"/>
                    <filter string="Status" name="group_state" context="{'group_by': 'student_state'}"/>
                    <filter string="Gender" name="group_gender" context="{'group_by': 'gender'}"/>
                    <filter string="Period" name="group_period" context="{'group_by': 'period'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Student Action -->
    <record id="action_education_student" model="ir.actions.act_window">
        <field name="name">Students</field>
        <field name="res_model">res.partner</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="domain">[('is_student', '=', True)]</field>
        <field name="context">{'default_is_student': True, 'search_default_enrolled': 1}</field>
        <field name="view_ids" eval="[(5, 0, 0),
            (0, 0, {'view_mode': 'list', 'view_id': ref('view_education_student_tree')}),
            (0, 0, {'view_mode': 'kanban', 'view_id': ref('view_education_student_kanban')}),
            (0, 0, {'view_mode': 'form', 'view_id': ref('view_education_student_form')})]"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Register your first student!
            </p>
        </field>
    </record>

    <!-- Pending Students Action -->
    <record id="action_education_student_pending" model="ir.actions.act_window">
        <field name="name">Pending Enrollment</field>
        <field name="res_model">res.partner</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('is_student', '=', True), ('student_state', '=', 'pending')]</field>
        <field name="context">{'default_is_student': True}</field>
        <field name="view_ids" eval="[(5, 0, 0),
            (0, 0, {'view_mode': 'list', 'view_id': ref('view_education_student_tree')}),
            (0, 0, {'view_mode': 'form', 'view_id': ref('view_education_student_form')})]"/>
    </record>

    <!-- Archived Students Action -->
    <record id="action_education_student_archived" model="ir.actions.act_window">
        <field name="name">Archived Students</field>
        <field name="res_model">res.partner</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('is_student', '=', True), ('student_state', '=', 'archived')]</field>
        <field name="context">{'default_is_student': True, 'active_test': False}</field>
        <field name="view_ids" eval="[(5, 0, 0),
            (0, 0, {'view_mode': 'list', 'view_id': ref('view_education_student_tree')}),
            (0, 0, {'view_mode': 'form', 'view_id': ref('view_education_student_form')})]"/>
    </record>

</odoo>
