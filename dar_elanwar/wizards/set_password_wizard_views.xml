<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_set_password_wizard_form" model="ir.ui.view">
        <field name="name">dar.portal.user.set.password.wizard.form</field>
        <field name="model">dar.portal.user.set.password.wizard</field>
        <field name="arch" type="xml">
            <form string="Set Password">
                <group>
                    <field name="portal_user_id" readonly="1"/>
                    <field name="new_password" password="True"/>
                    <field name="confirm_password" password="True"/>
                </group>
                <footer>
                    <button name="action_set_password" type="object"
                            string="Set Password" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>
