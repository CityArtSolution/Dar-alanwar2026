<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================ -->
    <!--  Student Details Report - Dar Al-Anwar Academy               -->
    <!--  Bilingual Arabic + English | RTL-Aware                      -->
    <!-- ============================================================ -->

    <!-- Outer wrapper: iterates over selected student records -->
    <template id="report_student_details_document">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="dar_elanwar.report_student_details_inner"/>
            </t>
        </t>
    </template>

    <!-- Inner template: single student profile page -->
    <template id="report_student_details_inner">
        <t t-call="web.external_layout">
            <div class="page" dir="rtl" style="font-family: 'Arial', 'Tahoma', sans-serif;">

                <!-- ===== Shared CSS ===== -->
                <style>
                    /* ---------- RTL and Base ---------- */
                    .page {
                        direction: rtl;
                        text-align: right;
                        font-size: 11pt;
                        color: #333;
                    }

                    /* ---------- Academy Header ---------- */
                    .academy-header {
                        text-align: center;
                        border-bottom: 3px solid #1a5276;
                        padding-bottom: 12px;
                        margin-bottom: 20px;
                    }
                    .academy-header .logo-placeholder {
                        width: 80px;
                        height: 80px;
                        margin: 0 auto 8px auto;
                        border: 2px dashed #aaa;
                        border-radius: 50%;
                        display: flex;
                        align-items: center;
                        justify-content: center;
                        color: #aaa;
                        font-size: 9pt;
                    }
                    .academy-header .ar-name {
                        font-size: 18pt;
                        font-weight: bold;
                        color: #1a5276;
                        margin: 4px 0;
                    }
                    .academy-header .en-name {
                        font-size: 12pt;
                        color: #555;
                        direction: ltr;
                    }

                    /* ---------- Section Title ---------- */
                    .section-title {
                        background-color: #1a5276;
                        color: #fff;
                        padding: 6px 14px;
                        font-size: 12pt;
                        font-weight: bold;
                        margin: 18px 0 10px 0;
                        border-radius: 3px;
                    }
                    .section-title .en {
                        font-weight: normal;
                        font-size: 10pt;
                        margin-right: 10px;
                        direction: ltr;
                        display: inline;
                    }

                    /* ---------- Tables ---------- */
                    .info-table {
                        width: 100%;
                        border-collapse: collapse;
                        margin-bottom: 14px;
                    }
                    .info-table th,
                    .info-table td {
                        border: 1px solid #ccc;
                        padding: 6px 10px;
                        vertical-align: top;
                    }
                    .info-table th {
                        background-color: #eaf2f8;
                        font-weight: bold;
                        width: 25%;
                        white-space: nowrap;
                    }
                    .info-table td {
                        width: 25%;
                    }

                    /* ---------- Student Photo ---------- */
                    .student-photo {
                        width: 110px;
                        height: 130px;
                        border: 1px solid #bbb;
                        object-fit: cover;
                    }
                    .photo-placeholder {
                        width: 110px;
                        height: 130px;
                        border: 2px dashed #bbb;
                        display: flex;
                        align-items: center;
                        justify-content: center;
                        color: #aaa;
                        font-size: 9pt;
                        text-align: center;
                    }

                    /* ---------- Summary Cards ---------- */
                    .summary-row {
                        display: flex;
                        gap: 12px;
                        margin-bottom: 14px;
                    }
                    .summary-card {
                        flex: 1;
                        border: 1px solid #ccc;
                        border-radius: 4px;
                        padding: 10px;
                        text-align: center;
                    }
                    .summary-card .card-value {
                        font-size: 16pt;
                        font-weight: bold;
                        color: #1a5276;
                    }
                    .summary-card .card-label {
                        font-size: 9pt;
                        color: #666;
                        margin-top: 4px;
                    }

                    /* ---------- Print ---------- */
                    @media print {
                        .page { page-break-after: always; }
                        .section-title { -webkit-print-color-adjust: exact; print-color-adjust: exact; }
                        .info-table th { -webkit-print-color-adjust: exact; print-color-adjust: exact; }
                    }
                </style>

                <!-- ===== Academy Header ===== -->
                <div class="academy-header">
                    <div class="logo-placeholder">
                        <t t-if="doc.company_id.logo">
                            <img t-att-src="image_data_uri(doc.company_id.logo)"
                                 style="max-width:78px;max-height:78px;border-radius:50%;"/>
                        </t>
                        <t t-else="">LOGO</t>
                    </div>
                    <div class="ar-name">&#1583;&#1575;&#1585; &#1575;&#1604;&#1571;&#1606;&#1608;&#1575;&#1585; &#1575;&#1604;&#1571;&#1603;&#1575;&#1583;&#1610;&#1605;&#1610;&#1577;</div>
                    <div class="en-name">Dar Al-Anwar Academy</div>
                </div>

                <!-- ===== Report Title ===== -->
                <h3 style="text-align:center; margin-bottom:16px;">
                    &#1578;&#1602;&#1585;&#1610;&#1585; &#1576;&#1610;&#1575;&#1606;&#1575;&#1578; &#1575;&#1604;&#1591;&#1575;&#1604;&#1576;
                    <br/>
                    <span style="font-size:10pt; color:#555; direction:ltr;">Student Details Report</span>
                </h3>

                <!-- ===== Student Identity ===== -->
                <table class="info-table">
                    <tr>
                        <td rowspan="5" style="width:120px; text-align:center; vertical-align:middle;">
                            <t t-if="doc.image_1920">
                                <img t-att-src="image_data_uri(doc.image_1920)" class="student-photo"/>
                            </t>
                            <t t-else="">
                                <div class="photo-placeholder">&#1604;&#1575; &#1578;&#1608;&#1580;&#1583; &#1589;&#1608;&#1585;&#1577;<br/>No Photo</div>
                            </t>
                        </td>
                        <th>&#1575;&#1604;&#1603;&#1608;&#1583; / Code</th>
                        <td colspan="3"><t t-esc="doc.code or '-'"/></td>
                    </tr>
                    <tr>
                        <th>&#1575;&#1604;&#1575;&#1587;&#1605; (&#1593;&#1585;&#1576;&#1610;) / Name (AR)</th>
                        <td colspan="3"><t t-esc="doc.arabic_name or '-'"/></td>
                    </tr>
                    <tr>
                        <th>&#1575;&#1604;&#1575;&#1587;&#1605; (&#1573;&#1606;&#1580;&#1604;&#1610;&#1586;&#1610;) / Name (EN)</th>
                        <td colspan="3" style="direction:ltr; text-align:left;">
                            <t t-esc="doc.name or '-'"/>
                        </td>
                    </tr>
                    <tr>
                        <th>&#1575;&#1604;&#1602;&#1587;&#1605; / Department</th>
                        <td><t t-esc="doc.department_id.name or '-'"/></td>
                        <th>&#1575;&#1604;&#1601;&#1589;&#1604; / Class</th>
                        <td><t t-esc="doc.class_id.name or '-'"/></td>
                    </tr>
                    <tr>
                        <th>&#1575;&#1604;&#1605;&#1587;&#1578;&#1608;&#1609; / Level</th>
                        <td><t t-esc="doc.level_id.name if doc.level_id else '-'"/></td>
                        <th>&#1575;&#1604;&#1581;&#1575;&#1604;&#1577; / State</th>
                        <td><t t-esc="doc.student_state or '-'"/></td>
                    </tr>
                </table>

                <!-- ===== Personal Information ===== -->
                <div class="section-title">
                    &#1575;&#1604;&#1605;&#1593;&#1604;&#1608;&#1605;&#1575;&#1578; &#1575;&#1604;&#1588;&#1582;&#1589;&#1610;&#1577;
                    <span class="en">Personal Information</span>
                </div>
                <table class="info-table">
                    <tr>
                        <th>&#1578;&#1575;&#1585;&#1610;&#1582; &#1575;&#1604;&#1605;&#1610;&#1604;&#1575;&#1583; / Birthdate</th>
                        <td><t t-esc="doc.birthdate" t-options="{'widget': 'date'}"/></td>
                        <th>&#1575;&#1604;&#1580;&#1606;&#1587; / Gender</th>
                        <td><t t-esc="doc.gender or '-'"/></td>
                    </tr>
                    <tr>
                        <th>&#1575;&#1604;&#1580;&#1606;&#1587;&#1610;&#1577; / Nationality</th>
                        <td><t t-esc="doc.country_id.name if doc.country_id else '-'"/></td>
                        <th>&#1575;&#1604;&#1585;&#1602;&#1605; &#1575;&#1604;&#1608;&#1591;&#1606;&#1610; / National ID</th>
                        <td style="direction:ltr; text-align:left;">
                            <t t-esc="doc.id_number or '-'"/>
                        </td>
                    </tr>
                    <tr>
                        <th>&#1575;&#1604;&#1583;&#1610;&#1575;&#1606;&#1577; / Religion</th>
                        <td><t t-esc="doc.religion or '-'"/></td>
                        <th>&#1605;&#1603;&#1575;&#1606; &#1575;&#1604;&#1605;&#1610;&#1604;&#1575;&#1583; / Birth Place</th>
                        <td><t t-esc="doc.birth_place or '-'"/></td>
                    </tr>
                    <tr>
                        <th>&#1601;&#1589;&#1610;&#1604;&#1577; &#1575;&#1604;&#1583;&#1605; / Blood Type</th>
                        <td><t t-esc="doc.blood_type or '-'"/></td>
                        <th></th>
                        <td></td>
                    </tr>
                </table>

                <!-- ===== Guardian Information ===== -->
                <div class="section-title">
                    &#1605;&#1593;&#1604;&#1608;&#1605;&#1575;&#1578; &#1608;&#1604;&#1610; &#1575;&#1604;&#1571;&#1605;&#1585;
                    <span class="en">Guardian Information</span>
                </div>
                <table class="info-table">
                    <tr>
                        <th>&#1575;&#1587;&#1605; &#1575;&#1604;&#1571;&#1576; / Father Name</th>
                        <td><t t-esc="doc.father_id.name if doc.father_id else '-'"/></td>
                        <th>&#1607;&#1575;&#1578;&#1601; &#1575;&#1604;&#1571;&#1576; / Father Phone</th>
                        <td style="direction:ltr; text-align:left;">
                            <t t-esc="doc.father_id.phone if doc.father_id else '-'"/>
                        </td>
                    </tr>
                    <tr>
                        <th>&#1607;&#1608;&#1610;&#1577; &#1575;&#1604;&#1571;&#1576; / Father ID</th>
                        <td style="direction:ltr; text-align:left;">
                            <t t-esc="doc.father_id.id_number if doc.father_id else '-'"/>
                        </td>
                        <th></th>
                        <td></td>
                    </tr>
                    <tr>
                        <th>&#1575;&#1587;&#1605; &#1575;&#1604;&#1571;&#1605; / Mother Name</th>
                        <td><t t-esc="doc.mother_id.name if doc.mother_id else '-'"/></td>
                        <th>&#1607;&#1575;&#1578;&#1601; &#1575;&#1604;&#1571;&#1605; / Mother Phone</th>
                        <td style="direction:ltr; text-align:left;">
                            <t t-esc="doc.mother_id.phone if doc.mother_id else '-'"/>
                        </td>
                    </tr>
                    <tr>
                        <th>&#1607;&#1608;&#1610;&#1577; &#1575;&#1604;&#1571;&#1605; / Mother ID</th>
                        <td style="direction:ltr; text-align:left;">
                            <t t-esc="doc.mother_id.id_number if doc.mother_id else '-'"/>
                        </td>
                        <th></th>
                        <td></td>
                    </tr>
                </table>

                <!-- ===== Medical Information ===== -->
                <div class="section-title">
                    &#1575;&#1604;&#1605;&#1593;&#1604;&#1608;&#1605;&#1575;&#1578; &#1575;&#1604;&#1591;&#1576;&#1610;&#1577;
                    <span class="en">Medical Information</span>
                </div>
                <table class="info-table">
                    <tr>
                        <th>&#1601;&#1589;&#1610;&#1604;&#1577; &#1575;&#1604;&#1583;&#1605; / Blood Type</th>
                        <td><t t-esc="doc.blood_type or '-'"/></td>
                        <th>&#1575;&#1604;&#1581;&#1587;&#1575;&#1587;&#1610;&#1577; / Allergies</th>
                        <td><t t-esc="doc.allergies or '-'"/></td>
                    </tr>
                    <tr>
                        <th>&#1605;&#1604;&#1575;&#1581;&#1592;&#1575;&#1578; &#1591;&#1576;&#1610;&#1577; / Medical Notes</th>
                        <td colspan="3"><t t-esc="doc.medical_notes or '-'"/></td>
                    </tr>
                </table>

                <!-- ===== Financial Summary ===== -->
                <div class="section-title">
                    &#1575;&#1604;&#1605;&#1604;&#1582;&#1589; &#1575;&#1604;&#1605;&#1575;&#1604;&#1610;
                    <span class="en">Financial Summary</span>
                </div>
                <div class="summary-row">
                    <div class="summary-card">
                        <div class="card-value">
                            <t t-esc="'%.2f' % (doc.total_subscriptions or 0)"/>
                        </div>
                        <div class="card-label">
                            &#1573;&#1580;&#1605;&#1575;&#1604;&#1610; &#1575;&#1604;&#1575;&#1588;&#1578;&#1585;&#1575;&#1603;&#1575;&#1578;<br/>Total Subscriptions
                        </div>
                    </div>
                    <div class="summary-card">
                        <div class="card-value" style="color:#27ae60;">
                            <t t-esc="'%.2f' % (doc.paid_amount or 0)"/>
                        </div>
                        <div class="card-label">
                            &#1575;&#1604;&#1605;&#1576;&#1604;&#1594; &#1575;&#1604;&#1605;&#1583;&#1601;&#1608;&#1593;<br/>Paid Amount
                        </div>
                    </div>
                    <div class="summary-card">
                        <div class="card-value" style="color:#e74c3c;">
                            <t t-esc="'%.2f' % (doc.balance_due or 0)"/>
                        </div>
                        <div class="card-label">
                            &#1575;&#1604;&#1585;&#1589;&#1610;&#1583; &#1575;&#1604;&#1605;&#1587;&#1578;&#1581;&#1602;<br/>Balance Due
                        </div>
                    </div>
                </div>

                <!-- ===== Attendance Summary ===== -->
                <div class="section-title">
                    &#1605;&#1604;&#1582;&#1589; &#1575;&#1604;&#1581;&#1590;&#1608;&#1585;
                    <span class="en">Attendance Summary</span>
                </div>
                <div class="summary-row">
                    <div class="summary-card">
                        <div class="card-value">
                            <t t-esc="'%.1f%%' % (doc.attendance_rate or 0)"/>
                        </div>
                        <div class="card-label">
                            &#1606;&#1587;&#1576;&#1577; &#1575;&#1604;&#1581;&#1590;&#1608;&#1585;<br/>Attendance Rate
                        </div>
                    </div>
                    <div class="summary-card">
                        <div class="card-value" style="color:#27ae60;">
                            <t t-esc="doc.present_days or 0"/>
                        </div>
                        <div class="card-label">
                            &#1571;&#1610;&#1575;&#1605; &#1575;&#1604;&#1581;&#1590;&#1608;&#1585;<br/>Present Days
                        </div>
                    </div>
                    <div class="summary-card">
                        <div class="card-value" style="color:#e74c3c;">
                            <t t-esc="doc.absent_days or 0"/>
                        </div>
                        <div class="card-label">
                            &#1571;&#1610;&#1575;&#1605; &#1575;&#1604;&#1594;&#1610;&#1575;&#1576;<br/>Absent Days
                        </div>
                    </div>
                </div>

                <!-- ===== Footer Note ===== -->
                <div style="margin-top:20px; text-align:center; font-size:8pt; color:#999; border-top:1px solid #ddd; padding-top:8px;">
                    &#1578;&#1605; &#1573;&#1606;&#1588;&#1575;&#1569; &#1607;&#1584;&#1575; &#1575;&#1604;&#1578;&#1602;&#1585;&#1610;&#1585; &#1570;&#1604;&#1610;&#1575;&#1611; &#1576;&#1608;&#1575;&#1587;&#1591;&#1577; &#1606;&#1592;&#1575;&#1605; &#1583;&#1575;&#1585; &#1575;&#1604;&#1571;&#1606;&#1608;&#1575;&#1585;
                    |
                    <span style="direction:ltr;">Auto-generated by Dar Al-Anwar System</span>
                </div>

            </div>
        </t>
    </template>

</odoo>
