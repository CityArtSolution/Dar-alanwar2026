<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================ -->
    <!--  Kids Area Report - Dar Al-Anwar Academy                     -->
    <!--  Bilingual Arabic + English | RTL-Aware                      -->
    <!-- ============================================================ -->

    <template id="report_kids_area_document">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="web.external_layout">
                    <div class="page" dir="rtl" style="font-family: 'Arial', 'Tahoma', sans-serif;">

                        <!-- ===== CSS ===== -->
                        <style>
                            .page {
                                direction: rtl;
                                text-align: right;
                                font-size: 10pt;
                                color: #333;
                            }
                            .academy-header {
                                text-align: center;
                                border-bottom: 3px solid #1a5276;
                                padding-bottom: 12px;
                                margin-bottom: 20px;
                            }
                            .academy-header .ar-name {
                                font-size: 18pt;
                                font-weight: bold;
                                color: #1a5276;
                            }
                            .academy-header .en-name {
                                font-size: 12pt;
                                color: #555;
                                direction: ltr;
                            }
                            .section-title {
                                background-color: #1a5276;
                                color: #fff;
                                padding: 6px 14px;
                                font-size: 12pt;
                                font-weight: bold;
                                margin: 18px 0 10px 0;
                                border-radius: 3px;
                            }
                            .section-title .en {
                                font-weight: normal;
                                font-size: 10pt;
                                margin-right: 10px;
                                direction: ltr;
                                display: inline;
                            }
                            .kids-table {
                                width: 100%;
                                border-collapse: collapse;
                                margin-bottom: 14px;
                            }
                            .kids-table th,
                            .kids-table td {
                                border: 1px solid #ccc;
                                padding: 6px 10px;
                                vertical-align: middle;
                            }
                            .kids-table thead th {
                                background-color: #1a5276;
                                color: #fff;
                                font-weight: bold;
                                text-align: center;
                            }
                            .kids-table tbody td {
                                text-align: center;
                            }
                            .kids-table tbody tr:nth-child(even) {
                                background-color: #f7f9fb;
                            }
                            .kids-table tfoot td {
                                background-color: #eaf2f8;
                                font-weight: bold;
                            }
                            .amount {
                                direction: ltr;
                                text-align: left;
                                font-family: 'Courier New', monospace;
                                white-space: nowrap;
                            }
                            .summary-cards {
                                display: flex;
                                gap: 10px;
                                margin-bottom: 16px;
                            }
                            .s-card {
                                flex: 1;
                                border: 1px solid #ccc;
                                border-radius: 4px;
                                padding: 12px;
                                text-align: center;
                            }
                            .s-card .val {
                                font-size: 18pt;
                                font-weight: bold;
                            }
                            .s-card .lbl {
                                font-size: 8pt;
                                color: #666;
                                margin-top: 4px;
                            }
                            .progress-bar-bg {
                                background-color: #eee;
                                border-radius: 4px;
                                overflow: hidden;
                                height: 16px;
                                width: 100%;
                            }
                            .progress-bar-fill {
                                height: 100%;
                                border-radius: 4px;
                            }
                            .green { color: #27ae60; }
                            .blue { color: #1a5276; }
                            .orange { color: #e67e22; }
                            .red { color: #e74c3c; }
                            .filter-box {
                                background-color: #f0f4f8;
                                border: 1px solid #d5dce4;
                                border-radius: 4px;
                                padding: 8px 14px;
                                margin-bottom: 16px;
                                font-size: 10pt;
                            }
                            @media print {
                                .page { page-break-after: always; }
                                .section-title,
                                .kids-table thead th,
                                .kids-table tfoot td {
                                    -webkit-print-color-adjust: exact;
                                    print-color-adjust: exact;
                                }
                            }
                        </style>

                        <!-- ===== Header ===== -->
                        <div class="academy-header">
                            <div class="ar-name">&#1583;&#1575;&#1585; &#1575;&#1604;&#1571;&#1606;&#1608;&#1575;&#1585; &#1575;&#1604;&#1571;&#1603;&#1575;&#1583;&#1610;&#1605;&#1610;&#1577;</div>
                            <div class="en-name">Dar Al-Anwar Academy</div>
                        </div>

                        <h3 style="text-align:center; margin-bottom:4px;">
                            &#1578;&#1602;&#1585;&#1610;&#1585; &#1605;&#1606;&#1591;&#1602;&#1577; &#1575;&#1604;&#1571;&#1591;&#1601;&#1575;&#1604;
                        </h3>
                        <p style="text-align:center; font-size:10pt; color:#555; direction:ltr; margin-bottom:16px;">
                            Kids Area Report
                        </p>

                        <!-- ===== Filter Info ===== -->
                        <div class="filter-box">
                            <strong>&#1575;&#1604;&#1601;&#1578;&#1585;&#1577; / Period:</strong>
                            <t t-if="doc.date_from">
                                &#1605;&#1606;: <t t-esc="doc.date_from" t-options="{'widget': 'date'}"/>
                            </t>
                            <t t-if="doc.date_to">
                                &#1573;&#1604;&#1609;: <t t-esc="doc.date_to" t-options="{'widget': 'date'}"/>
                            </t>
                        </div>

                        <!-- ===== Service Utilization ===== -->
                        <div class="section-title">
                            &#1575;&#1587;&#1578;&#1582;&#1583;&#1575;&#1605; &#1575;&#1604;&#1582;&#1583;&#1605;&#1575;&#1578;
                            <span class="en">Service Utilization</span>
                        </div>
                        <table class="kids-table">
                            <thead>
                                <tr>
                                    <th>#</th>
                                    <th>&#1575;&#1604;&#1582;&#1583;&#1605;&#1577; / Service</th>
                                    <th>&#1593;&#1583;&#1583; &#1575;&#1604;&#1581;&#1580;&#1608;&#1586;&#1575;&#1578; / Bookings</th>
                                    <th>&#1575;&#1604;&#1587;&#1593;&#1577; / Capacity</th>
                                    <th>&#1606;&#1587;&#1576;&#1577; &#1575;&#1604;&#1575;&#1587;&#1578;&#1582;&#1583;&#1575;&#1605; / Utilization</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="doc.service_lines" t-as="sv">
                                    <tr>
                                        <td><t t-esc="sv_index + 1"/></td>
                                        <td style="text-align:right;"><t t-esc="sv.service_name or '-'"/></td>
                                        <td><t t-esc="sv.booking_count or 0"/></td>
                                        <td><t t-esc="sv.capacity or 0"/></td>
                                        <td>
                                            <div class="progress-bar-bg" style="width:80%; margin:0 auto;">
                                                <div class="progress-bar-fill"
                                                     t-attf-style="width: {{ '%.0f' % (sv.utilization or 0) }}%;
                                                                    background-color: {{ '#27ae60' if (sv.utilization or 0) &lt; 80 else ('#e67e22' if (sv.utilization or 0) &lt; 100 else '#e74c3c') }};"/>
                                            </div>
                                            <span style="font-size:9pt;">
                                                <t t-esc="'%.1f%%' % (sv.utilization or 0)"/>
                                            </span>
                                        </td>
                                    </tr>
                                </t>
                            </tbody>
                        </table>

                        <!-- ===== Daily Attendance Summary ===== -->
                        <div class="section-title">
                            &#1605;&#1604;&#1582;&#1589; &#1575;&#1604;&#1581;&#1590;&#1608;&#1585; &#1575;&#1604;&#1610;&#1608;&#1605;&#1610;
                            <span class="en">Daily Attendance Summary</span>
                        </div>
                        <table class="kids-table">
                            <thead>
                                <tr>
                                    <th>&#1575;&#1604;&#1578;&#1575;&#1585;&#1610;&#1582; / Date</th>
                                    <th>&#1573;&#1580;&#1605;&#1575;&#1604;&#1610; &#1575;&#1604;&#1571;&#1591;&#1601;&#1575;&#1604; / Total Kids</th>
                                    <th>&#1608;&#1602;&#1578; &#1575;&#1604;&#1584;&#1585;&#1608;&#1577; / Peak Time</th>
                                    <th>&#1575;&#1604;&#1582;&#1583;&#1605;&#1577; &#1575;&#1604;&#1571;&#1603;&#1579;&#1585; &#1591;&#1604;&#1576;&#1575;&#1611; / Most Popular</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="doc.daily_attendance_lines" t-as="da">
                                    <tr>
                                        <td><t t-esc="da.date" t-options="{'widget': 'date'}"/></td>
                                        <td><t t-esc="da.total_kids or 0"/></td>
                                        <td style="direction:ltr;"><t t-esc="da.peak_time or '-'"/></td>
                                        <td style="text-align:right;"><t t-esc="da.most_popular_service or '-'"/></td>
                                    </tr>
                                </t>
                            </tbody>
                        </table>

                        <!-- ===== Revenue from Bookings ===== -->
                        <div class="section-title">
                            &#1573;&#1610;&#1585;&#1575;&#1583;&#1575;&#1578; &#1575;&#1604;&#1581;&#1580;&#1608;&#1586;&#1575;&#1578;
                            <span class="en">Revenue from Bookings</span>
                        </div>
                        <div class="summary-cards">
                            <div class="s-card">
                                <div class="val blue">
                                    <t t-esc="doc.total_bookings or 0"/>
                                </div>
                                <div class="lbl">&#1573;&#1580;&#1605;&#1575;&#1604;&#1610; &#1575;&#1604;&#1581;&#1580;&#1608;&#1586;&#1575;&#1578;<br/>Total Bookings</div>
                            </div>
                            <div class="s-card">
                                <div class="val green">
                                    <t t-esc="'%.2f' % (doc.total_booking_revenue or 0)"/>
                                </div>
                                <div class="lbl">&#1573;&#1580;&#1605;&#1575;&#1604;&#1610; &#1575;&#1604;&#1573;&#1610;&#1585;&#1575;&#1583;&#1575;&#1578;<br/>Total Revenue</div>
                            </div>
                            <div class="s-card">
                                <div class="val orange">
                                    <t t-esc="'%.2f' % (doc.avg_revenue_per_booking or 0)"/>
                                </div>
                                <div class="lbl">&#1605;&#1578;&#1608;&#1587;&#1591; &#1575;&#1604;&#1573;&#1610;&#1585;&#1575;&#1583; / &#1581;&#1580;&#1586;<br/>Avg Revenue/Booking</div>
                            </div>
                        </div>

                        <table class="kids-table">
                            <thead>
                                <tr>
                                    <th>#</th>
                                    <th>&#1575;&#1604;&#1582;&#1583;&#1605;&#1577; / Service</th>
                                    <th>&#1593;&#1583;&#1583; &#1575;&#1604;&#1581;&#1580;&#1608;&#1586;&#1575;&#1578; / Bookings</th>
                                    <th>&#1575;&#1604;&#1573;&#1610;&#1585;&#1575;&#1583; / Revenue</th>
                                    <th>&#1575;&#1604;&#1606;&#1587;&#1576;&#1577; / Share %</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="doc.revenue_lines" t-as="rv">
                                    <tr>
                                        <td><t t-esc="rv_index + 1"/></td>
                                        <td style="text-align:right;"><t t-esc="rv.service_name or '-'"/></td>
                                        <td><t t-esc="rv.booking_count or 0"/></td>
                                        <td class="amount">
                                            <t t-esc="'%.2f' % (rv.revenue or 0)"/>
                                            <t t-esc="doc.currency_symbol or ''"/>
                                        </td>
                                        <td><t t-esc="'%.1f%%' % (rv.share_percentage or 0)"/></td>
                                    </tr>
                                </t>
                            </tbody>
                            <tfoot>
                                <tr>
                                    <td colspan="2" style="text-align:right;">
                                        &#1575;&#1604;&#1573;&#1580;&#1605;&#1575;&#1604;&#1610; / Total
                                    </td>
                                    <td><t t-esc="doc.total_bookings or 0"/></td>
                                    <td class="amount">
                                        <t t-esc="'%.2f' % (doc.total_booking_revenue or 0)"/>
                                        <t t-esc="doc.currency_symbol or ''"/>
                                    </td>
                                    <td>100%</td>
                                </tr>
                            </tfoot>
                        </table>

                        <!-- ===== Occupancy Rates per Slot ===== -->
                        <div class="section-title">
                            &#1606;&#1587;&#1576; &#1575;&#1604;&#1573;&#1588;&#1594;&#1575;&#1604; &#1581;&#1587;&#1576; &#1575;&#1604;&#1601;&#1578;&#1585;&#1577;
                            <span class="en">Occupancy Rates per Slot</span>
                        </div>
                        <table class="kids-table">
                            <thead>
                                <tr>
                                    <th>&#1575;&#1604;&#1601;&#1578;&#1585;&#1577; / Slot</th>
                                    <th>&#1575;&#1604;&#1587;&#1593;&#1577; / Capacity</th>
                                    <th>&#1575;&#1604;&#1605;&#1581;&#1580;&#1608;&#1586; / Booked</th>
                                    <th>&#1575;&#1604;&#1605;&#1578;&#1575;&#1581; / Available</th>
                                    <th>&#1606;&#1587;&#1576;&#1577; &#1575;&#1604;&#1573;&#1588;&#1594;&#1575;&#1604; / Occupancy</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="doc.slot_lines" t-as="sl">
                                    <tr>
                                        <td style="direction:ltr;"><t t-esc="sl.slot_name or '-'"/></td>
                                        <td><t t-esc="sl.capacity or 0"/></td>
                                        <td><t t-esc="sl.booked or 0"/></td>
                                        <td>
                                            <span t-attf-style="color: {{ '#27ae60' if (sl.available or 0) > 0 else '#e74c3c' }};">
                                                <t t-esc="sl.available or 0"/>
                                            </span>
                                        </td>
                                        <td>
                                            <div class="progress-bar-bg" style="width:80%; margin:0 auto;">
                                                <div class="progress-bar-fill"
                                                     t-attf-style="width: {{ '%.0f' % (sl.occupancy_rate or 0) }}%;
                                                                    background-color: {{ '#e74c3c' if (sl.occupancy_rate or 0) >= 95 else ('#e67e22' if (sl.occupancy_rate or 0) >= 80 else '#27ae60') }};"/>
                                            </div>
                                            <span style="font-size:9pt;">
                                                <t t-esc="'%.1f%%' % (sl.occupancy_rate or 0)"/>
                                            </span>
                                        </td>
                                    </tr>
                                </t>
                            </tbody>
                        </table>

                        <!-- ===== Footer ===== -->
                        <div style="margin-top:20px; text-align:center; font-size:8pt; color:#999; border-top:1px solid #ddd; padding-top:8px;">
                            &#1578;&#1605; &#1573;&#1606;&#1588;&#1575;&#1569; &#1607;&#1584;&#1575; &#1575;&#1604;&#1578;&#1602;&#1585;&#1610;&#1585; &#1570;&#1604;&#1610;&#1575;&#1611; &#1576;&#1608;&#1575;&#1587;&#1591;&#1577; &#1606;&#1592;&#1575;&#1605; &#1583;&#1575;&#1585; &#1575;&#1604;&#1571;&#1606;&#1608;&#1575;&#1585;
                            |
                            <span style="direction:ltr;">Auto-generated by Dar Al-Anwar System</span>
                        </div>

                    </div>
                </t>
            </t>
        </t>
    </template>

</odoo>
