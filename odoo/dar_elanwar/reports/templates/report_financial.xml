<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================ -->
    <!--  Financial Report - Dar Al-Anwar Academy                     -->
    <!--  Bilingual Arabic + English | RTL-Aware                      -->
    <!-- ============================================================ -->

    <template id="report_financial_document">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="web.external_layout">
                    <div class="page" dir="rtl" style="font-family: 'Arial', 'Tahoma', sans-serif;">

                        <!-- ===== CSS ===== -->
                        <style>
                            .page {
                                direction: rtl;
                                text-align: right;
                                font-size: 10pt;
                                color: #333;
                            }
                            .academy-header {
                                text-align: center;
                                border-bottom: 3px solid #1a5276;
                                padding-bottom: 12px;
                                margin-bottom: 20px;
                            }
                            .academy-header .ar-name {
                                font-size: 18pt;
                                font-weight: bold;
                                color: #1a5276;
                            }
                            .academy-header .en-name {
                                font-size: 12pt;
                                color: #555;
                                direction: ltr;
                            }
                            .section-title {
                                background-color: #1a5276;
                                color: #fff;
                                padding: 6px 14px;
                                font-size: 12pt;
                                font-weight: bold;
                                margin: 18px 0 10px 0;
                                border-radius: 3px;
                            }
                            .section-title .en {
                                font-weight: normal;
                                font-size: 10pt;
                                margin-right: 10px;
                                direction: ltr;
                                display: inline;
                            }
                            .fin-table {
                                width: 100%;
                                border-collapse: collapse;
                                margin-bottom: 14px;
                            }
                            .fin-table th,
                            .fin-table td {
                                border: 1px solid #ccc;
                                padding: 6px 10px;
                                vertical-align: middle;
                            }
                            .fin-table thead th {
                                background-color: #1a5276;
                                color: #fff;
                                font-weight: bold;
                                text-align: center;
                            }
                            .fin-table tbody td {
                                text-align: center;
                            }
                            .fin-table tbody tr:nth-child(even) {
                                background-color: #f7f9fb;
                            }
                            .fin-table tfoot td {
                                background-color: #eaf2f8;
                                font-weight: bold;
                            }
                            .amount {
                                direction: ltr;
                                text-align: left;
                                font-family: 'Courier New', monospace;
                                white-space: nowrap;
                            }
                            .summary-cards {
                                display: flex;
                                gap: 10px;
                                margin-bottom: 16px;
                            }
                            .s-card {
                                flex: 1;
                                border: 1px solid #ccc;
                                border-radius: 4px;
                                padding: 12px;
                                text-align: center;
                            }
                            .s-card .val {
                                font-size: 16pt;
                                font-weight: bold;
                            }
                            .s-card .lbl {
                                font-size: 8pt;
                                color: #666;
                                margin-top: 4px;
                            }
                            .green { color: #27ae60; }
                            .red { color: #e74c3c; }
                            .blue { color: #1a5276; }
                            .orange { color: #e67e22; }
                            .filter-box {
                                background-color: #f0f4f8;
                                border: 1px solid #d5dce4;
                                border-radius: 4px;
                                padding: 8px 14px;
                                margin-bottom: 16px;
                                font-size: 10pt;
                            }
                            .overdue-row {
                                background-color: #fdecea !important;
                            }
                            @media print {
                                .page { page-break-after: always; }
                                .section-title,
                                .fin-table thead th,
                                .fin-table tfoot td {
                                    -webkit-print-color-adjust: exact;
                                    print-color-adjust: exact;
                                }
                            }
                        </style>

                        <!-- ===== Header ===== -->
                        <div class="academy-header">
                            <div class="ar-name">&#1583;&#1575;&#1585; &#1575;&#1604;&#1571;&#1606;&#1608;&#1575;&#1585; &#1575;&#1604;&#1571;&#1603;&#1575;&#1583;&#1610;&#1605;&#1610;&#1577;</div>
                            <div class="en-name">Dar Al-Anwar Academy</div>
                        </div>

                        <h3 style="text-align:center; margin-bottom:4px;">
                            &#1575;&#1604;&#1578;&#1602;&#1585;&#1610;&#1585; &#1575;&#1604;&#1605;&#1575;&#1604;&#1610; &#1575;&#1604;&#1588;&#1575;&#1605;&#1604;
                        </h3>
                        <p style="text-align:center; font-size:10pt; color:#555; direction:ltr; margin-bottom:16px;">
                            Comprehensive Financial Report
                        </p>

                        <!-- ===== Filter Info ===== -->
                        <div class="filter-box">
                            <strong>&#1575;&#1604;&#1601;&#1578;&#1585;&#1577; / Period:</strong>
                            <t t-if="doc.date_from">
                                &#1605;&#1606;: <t t-esc="doc.date_from" t-options="{'widget': 'date'}"/>
                            </t>
                            <t t-if="doc.date_to">
                                &#1573;&#1604;&#1609;: <t t-esc="doc.date_to" t-options="{'widget': 'date'}"/>
                            </t>
                        </div>

                        <!-- ===== Treasury Summary ===== -->
                        <div class="section-title">
                            &#1605;&#1604;&#1582;&#1589; &#1575;&#1604;&#1582;&#1586;&#1610;&#1606;&#1577;
                            <span class="en">Treasury Summary</span>
                        </div>
                        <table class="fin-table">
                            <thead>
                                <tr>
                                    <th>#</th>
                                    <th>&#1575;&#1604;&#1581;&#1587;&#1575;&#1576; / Account</th>
                                    <th>&#1575;&#1604;&#1606;&#1608;&#1593; / Type</th>
                                    <th>&#1575;&#1604;&#1585;&#1589;&#1610;&#1583; / Balance</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="doc.treasury_lines" t-as="tl">
                                    <tr>
                                        <td><t t-esc="tl_index + 1"/></td>
                                        <td style="text-align:right;"><t t-esc="tl.account_name or '-'"/></td>
                                        <td><t t-esc="tl.account_type or '-'"/></td>
                                        <td class="amount">
                                            <t t-esc="'%.2f' % (tl.balance or 0)"/>
                                            <t t-esc="doc.currency_symbol or ''"/>
                                        </td>
                                    </tr>
                                </t>
                            </tbody>
                            <tfoot>
                                <tr>
                                    <td colspan="3" style="text-align:right; font-weight:bold;">
                                        &#1575;&#1604;&#1573;&#1580;&#1605;&#1575;&#1604;&#1610; / Total
                                    </td>
                                    <td class="amount" style="font-weight:bold;">
                                        <t t-esc="'%.2f' % (doc.total_treasury_balance or 0)"/>
                                        <t t-esc="doc.currency_symbol or ''"/>
                                    </td>
                                </tr>
                            </tfoot>
                        </table>

                        <!-- ===== Revenue Summary ===== -->
                        <div class="section-title">
                            &#1605;&#1604;&#1582;&#1589; &#1575;&#1604;&#1573;&#1610;&#1585;&#1575;&#1583;&#1575;&#1578;
                            <span class="en">Revenue Summary</span>
                        </div>
                        <div class="summary-cards">
                            <div class="s-card">
                                <div class="val blue">
                                    <t t-esc="'%.2f' % (doc.total_subscriptions_amount or 0)"/>
                                </div>
                                <div class="lbl">&#1573;&#1580;&#1605;&#1575;&#1604;&#1610; &#1575;&#1604;&#1575;&#1588;&#1578;&#1585;&#1575;&#1603;&#1575;&#1578;<br/>Total Subscriptions</div>
                            </div>
                            <div class="s-card">
                                <div class="val green">
                                    <t t-esc="'%.2f' % (doc.total_paid or 0)"/>
                                </div>
                                <div class="lbl">&#1575;&#1604;&#1605;&#1581;&#1589;&#1604;<br/>Paid</div>
                            </div>
                            <div class="s-card">
                                <div class="val red">
                                    <t t-esc="'%.2f' % (doc.total_pending or 0)"/>
                                </div>
                                <div class="lbl">&#1575;&#1604;&#1605;&#1578;&#1576;&#1602;&#1610;<br/>Pending</div>
                            </div>
                        </div>

                        <!-- ===== Expense Summary by Category ===== -->
                        <div class="section-title">
                            &#1605;&#1604;&#1582;&#1589; &#1575;&#1604;&#1605;&#1589;&#1585;&#1608;&#1601;&#1575;&#1578; &#1581;&#1587;&#1576; &#1575;&#1604;&#1601;&#1574;&#1577;
                            <span class="en">Expense Summary by Category</span>
                        </div>
                        <table class="fin-table">
                            <thead>
                                <tr>
                                    <th>#</th>
                                    <th>&#1575;&#1604;&#1601;&#1574;&#1577; / Category</th>
                                    <th>&#1593;&#1583;&#1583; &#1575;&#1604;&#1593;&#1605;&#1604;&#1610;&#1575;&#1578; / Transactions</th>
                                    <th>&#1575;&#1604;&#1605;&#1576;&#1604;&#1594; / Amount</th>
                                    <th>&#1575;&#1604;&#1606;&#1587;&#1576;&#1577; / Percentage</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="doc.expense_lines" t-as="el">
                                    <tr>
                                        <td><t t-esc="el_index + 1"/></td>
                                        <td style="text-align:right;"><t t-esc="el.category_name or '-'"/></td>
                                        <td><t t-esc="el.transaction_count or 0"/></td>
                                        <td class="amount">
                                            <t t-esc="'%.2f' % (el.amount or 0)"/>
                                            <t t-esc="doc.currency_symbol or ''"/>
                                        </td>
                                        <td><t t-esc="'%.1f%%' % (el.percentage or 0)"/></td>
                                    </tr>
                                </t>
                            </tbody>
                            <tfoot>
                                <tr>
                                    <td colspan="3" style="text-align:right; font-weight:bold;">
                                        &#1573;&#1580;&#1605;&#1575;&#1604;&#1610; &#1575;&#1604;&#1605;&#1589;&#1585;&#1608;&#1601;&#1575;&#1578; / Total Expenses
                                    </td>
                                    <td class="amount" style="font-weight:bold; color:#e74c3c;">
                                        <t t-esc="'%.2f' % (doc.total_expenses or 0)"/>
                                        <t t-esc="doc.currency_symbol or ''"/>
                                    </td>
                                    <td>100%</td>
                                </tr>
                            </tfoot>
                        </table>

                        <!-- ===== Installment Status ===== -->
                        <div class="section-title">
                            &#1581;&#1575;&#1604;&#1577; &#1575;&#1604;&#1571;&#1602;&#1587;&#1575;&#1591;
                            <span class="en">Installment Status</span>
                        </div>
                        <div class="summary-cards">
                            <div class="s-card">
                                <div class="val green">
                                    <t t-esc="doc.installments_paid_count or 0"/>
                                </div>
                                <div class="lbl">&#1605;&#1583;&#1601;&#1608;&#1593;&#1577;<br/>Paid</div>
                            </div>
                            <div class="s-card">
                                <div class="val orange">
                                    <t t-esc="doc.installments_upcoming_count or 0"/>
                                </div>
                                <div class="lbl">&#1602;&#1575;&#1583;&#1605;&#1577;<br/>Upcoming</div>
                            </div>
                            <div class="s-card">
                                <div class="val red">
                                    <t t-esc="doc.installments_overdue_count or 0"/>
                                </div>
                                <div class="lbl">&#1605;&#1578;&#1571;&#1582;&#1585;&#1577;<br/>Overdue</div>
                            </div>
                        </div>

                        <table class="fin-table">
                            <thead>
                                <tr>
                                    <th>#</th>
                                    <th>&#1575;&#1604;&#1591;&#1575;&#1604;&#1576; / Student</th>
                                    <th>&#1585;&#1602;&#1605; &#1575;&#1604;&#1602;&#1587;&#1591; / Installment #</th>
                                    <th>&#1578;&#1575;&#1585;&#1610;&#1582; &#1575;&#1604;&#1575;&#1587;&#1578;&#1581;&#1602;&#1575;&#1602; / Due Date</th>
                                    <th>&#1575;&#1604;&#1605;&#1576;&#1604;&#1594; / Amount</th>
                                    <th>&#1575;&#1604;&#1581;&#1575;&#1604;&#1577; / Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="doc.installment_lines" t-as="il">
                                    <tr t-attf-class="{{ 'overdue-row' if il.is_overdue else '' }}">
                                        <td><t t-esc="il_index + 1"/></td>
                                        <td style="text-align:right;"><t t-esc="il.student_name or '-'"/></td>
                                        <td><t t-esc="il.installment_number or '-'"/></td>
                                        <td><t t-esc="il.due_date" t-options="{'widget': 'date'}"/></td>
                                        <td class="amount">
                                            <t t-esc="'%.2f' % (il.amount or 0)"/>
                                            <t t-esc="doc.currency_symbol or ''"/>
                                        </td>
                                        <td>
                                            <t t-if="il.state == 'paid'">
                                                <span class="green">&#1605;&#1583;&#1601;&#1608;&#1593; / Paid</span>
                                            </t>
                                            <t t-if="il.state == 'upcoming'">
                                                <span class="orange">&#1602;&#1575;&#1583;&#1605; / Upcoming</span>
                                            </t>
                                            <t t-if="il.state == 'overdue'">
                                                <span class="red">&#1605;&#1578;&#1571;&#1582;&#1585; / Overdue</span>
                                            </t>
                                        </td>
                                    </tr>
                                </t>
                            </tbody>
                        </table>

                        <!-- ===== Footer ===== -->
                        <div style="margin-top:20px; text-align:center; font-size:8pt; color:#999; border-top:1px solid #ddd; padding-top:8px;">
                            &#1578;&#1605; &#1573;&#1606;&#1588;&#1575;&#1569; &#1607;&#1584;&#1575; &#1575;&#1604;&#1578;&#1602;&#1585;&#1610;&#1585; &#1570;&#1604;&#1610;&#1575;&#1611; &#1576;&#1608;&#1575;&#1587;&#1591;&#1577; &#1606;&#1592;&#1575;&#1605; &#1583;&#1575;&#1585; &#1575;&#1604;&#1571;&#1606;&#1608;&#1575;&#1585;
                            |
                            <span style="direction:ltr;">Auto-generated by Dar Al-Anwar System</span>
                        </div>

                    </div>
                </t>
            </t>
        </t>
    </template>

</odoo>
