<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================ -->
    <!--  Attendance Report - Dar Al-Anwar Academy                    -->
    <!--  Bilingual Arabic + English | RTL-Aware                      -->
    <!-- ============================================================ -->

    <template id="report_attendance_document">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="web.external_layout">
                    <div class="page" dir="rtl" style="font-family: 'Arial', 'Tahoma', sans-serif;">

                        <!-- ===== CSS ===== -->
                        <style>
                            .page {
                                direction: rtl;
                                text-align: right;
                                font-size: 10pt;
                                color: #333;
                            }
                            .academy-header {
                                text-align: center;
                                border-bottom: 3px solid #1a5276;
                                padding-bottom: 12px;
                                margin-bottom: 20px;
                            }
                            .academy-header .ar-name {
                                font-size: 18pt;
                                font-weight: bold;
                                color: #1a5276;
                            }
                            .academy-header .en-name {
                                font-size: 12pt;
                                color: #555;
                                direction: ltr;
                            }
                            .section-title {
                                background-color: #1a5276;
                                color: #fff;
                                padding: 6px 14px;
                                font-size: 12pt;
                                font-weight: bold;
                                margin: 18px 0 10px 0;
                                border-radius: 3px;
                            }
                            .section-title .en {
                                font-weight: normal;
                                font-size: 10pt;
                                margin-right: 10px;
                                direction: ltr;
                                display: inline;
                            }
                            .att-table {
                                width: 100%;
                                border-collapse: collapse;
                                margin-bottom: 14px;
                            }
                            .att-table th,
                            .att-table td {
                                border: 1px solid #ccc;
                                padding: 5px 8px;
                                vertical-align: middle;
                            }
                            .att-table thead th {
                                background-color: #1a5276;
                                color: #fff;
                                font-weight: bold;
                                text-align: center;
                            }
                            .att-table tbody td {
                                text-align: center;
                            }
                            .att-table tbody tr:nth-child(even) {
                                background-color: #f7f9fb;
                            }
                            .filter-box {
                                background-color: #f0f4f8;
                                border: 1px solid #d5dce4;
                                border-radius: 4px;
                                padding: 8px 14px;
                                margin-bottom: 16px;
                                font-size: 10pt;
                            }
                            .summary-cards {
                                display: flex;
                                gap: 10px;
                                margin-bottom: 16px;
                            }
                            .s-card {
                                flex: 1;
                                border: 1px solid #ccc;
                                border-radius: 4px;
                                padding: 10px;
                                text-align: center;
                            }
                            .s-card .val {
                                font-size: 18pt;
                                font-weight: bold;
                                color: #1a5276;
                            }
                            .s-card .lbl {
                                font-size: 8pt;
                                color: #666;
                                margin-top: 4px;
                            }
                            .status-present { color: #27ae60; font-weight: bold; }
                            .status-absent { color: #e74c3c; font-weight: bold; }
                            .status-late { color: #e67e22; font-weight: bold; }
                            .status-excused { color: #2980b9; font-weight: bold; }
                            @media print {
                                .page { page-break-after: always; }
                                .section-title,
                                .att-table thead th {
                                    -webkit-print-color-adjust: exact;
                                    print-color-adjust: exact;
                                }
                            }
                        </style>

                        <!-- ===== Header ===== -->
                        <div class="academy-header">
                            <div class="ar-name">&#1583;&#1575;&#1585; &#1575;&#1604;&#1571;&#1606;&#1608;&#1575;&#1585; &#1575;&#1604;&#1571;&#1603;&#1575;&#1583;&#1610;&#1605;&#1610;&#1577;</div>
                            <div class="en-name">Dar Al-Anwar Academy</div>
                        </div>

                        <h3 style="text-align:center; margin-bottom:4px;">
                            &#1578;&#1602;&#1585;&#1610;&#1585; &#1575;&#1604;&#1581;&#1590;&#1608;&#1585; &#1608;&#1575;&#1604;&#1594;&#1610;&#1575;&#1576;
                        </h3>
                        <p style="text-align:center; font-size:10pt; color:#555; direction:ltr; margin-bottom:16px;">
                            Attendance Report
                        </p>

                        <!-- ===== Filter Info ===== -->
                        <div class="filter-box">
                            <strong>&#1575;&#1604;&#1601;&#1604;&#1575;&#1578;&#1585; / Filters:</strong>
                            <t t-if="doc.date_from">
                                &#1605;&#1606;: <t t-esc="doc.date_from" t-options="{'widget': 'date'}"/> |
                            </t>
                            <t t-if="doc.date_to">
                                &#1573;&#1604;&#1609;: <t t-esc="doc.date_to" t-options="{'widget': 'date'}"/> |
                            </t>
                            <t t-if="doc.department_id">
                                &#1575;&#1604;&#1602;&#1587;&#1605;: <t t-esc="doc.department_id.name"/> |
                            </t>
                            <t t-if="doc.class_id">
                                &#1575;&#1604;&#1601;&#1589;&#1604;: <t t-esc="doc.class_id.name"/>
                            </t>
                        </div>

                        <!-- ===== Summary Cards ===== -->
                        <div class="section-title">
                            &#1605;&#1604;&#1582;&#1589; &#1575;&#1604;&#1581;&#1590;&#1608;&#1585;
                            <span class="en">Attendance Summary</span>
                        </div>
                        <div class="summary-cards">
                            <div class="s-card">
                                <div class="val"><t t-esc="doc.total_days or 0"/></div>
                                <div class="lbl">&#1573;&#1580;&#1605;&#1575;&#1604;&#1610; &#1575;&#1604;&#1571;&#1610;&#1575;&#1605;<br/>Total Days</div>
                            </div>
                            <div class="s-card">
                                <div class="val status-present"><t t-esc="doc.present_count or 0"/></div>
                                <div class="lbl">&#1581;&#1590;&#1608;&#1585;<br/>Present</div>
                            </div>
                            <div class="s-card">
                                <div class="val status-absent"><t t-esc="doc.absent_count or 0"/></div>
                                <div class="lbl">&#1594;&#1610;&#1575;&#1576;<br/>Absent</div>
                            </div>
                            <div class="s-card">
                                <div class="val status-late"><t t-esc="doc.late_count or 0"/></div>
                                <div class="lbl">&#1578;&#1571;&#1582;&#1585;<br/>Late</div>
                            </div>
                            <div class="s-card">
                                <div class="val status-excused"><t t-esc="doc.excused_count or 0"/></div>
                                <div class="lbl">&#1593;&#1584;&#1585;<br/>Excused</div>
                            </div>
                        </div>

                        <!-- ===== Detailed Attendance List ===== -->
                        <div class="section-title">
                            &#1587;&#1580;&#1604; &#1575;&#1604;&#1581;&#1590;&#1608;&#1585; &#1575;&#1604;&#1578;&#1601;&#1589;&#1610;&#1604;&#1610;
                            <span class="en">Detailed Attendance Log</span>
                        </div>
                        <table class="att-table">
                            <thead>
                                <tr>
                                    <th>#</th>
                                    <th>&#1575;&#1587;&#1605; &#1575;&#1604;&#1591;&#1575;&#1604;&#1576; / Student</th>
                                    <th>&#1575;&#1604;&#1578;&#1575;&#1585;&#1610;&#1582; / Date</th>
                                    <th>&#1575;&#1604;&#1581;&#1575;&#1604;&#1577; / Status</th>
                                    <th>&#1608;&#1602;&#1578; &#1575;&#1604;&#1583;&#1582;&#1608;&#1604; / Check In</th>
                                    <th>&#1608;&#1602;&#1578; &#1575;&#1604;&#1582;&#1585;&#1608;&#1580; / Check Out</th>
                                    <th>&#1605;&#1604;&#1575;&#1581;&#1592;&#1575;&#1578; / Notes</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="doc.attendance_lines" t-as="att">
                                    <tr>
                                        <td><t t-esc="att_index + 1"/></td>
                                        <td style="text-align:right;"><t t-esc="att.student_name or '-'"/></td>
                                        <td><t t-esc="att.date" t-options="{'widget': 'date'}"/></td>
                                        <td>
                                            <span t-attf-class="status-{{ att.status or 'present' }}">
                                                <t t-if="att.status == 'present'">&#1581;&#1575;&#1590;&#1585; / Present</t>
                                                <t t-if="att.status == 'absent'">&#1594;&#1575;&#1574;&#1576; / Absent</t>
                                                <t t-if="att.status == 'late'">&#1605;&#1578;&#1571;&#1582;&#1585; / Late</t>
                                                <t t-if="att.status == 'excused'">&#1593;&#1584;&#1585; / Excused</t>
                                            </span>
                                        </td>
                                        <td style="direction:ltr;">
                                            <t t-esc="att.check_in or '-'"/>
                                        </td>
                                        <td style="direction:ltr;">
                                            <t t-esc="att.check_out or '-'"/>
                                        </td>
                                        <td style="text-align:right; font-size:9pt;">
                                            <t t-esc="att.notes or ''"/>
                                        </td>
                                    </tr>
                                </t>
                            </tbody>
                        </table>

                        <!-- ===== Per-Student Attendance Rate ===== -->
                        <div class="section-title">
                            &#1606;&#1587;&#1576;&#1577; &#1575;&#1604;&#1581;&#1590;&#1608;&#1585; &#1604;&#1603;&#1604; &#1591;&#1575;&#1604;&#1576;
                            <span class="en">Attendance Rate per Student</span>
                        </div>
                        <table class="att-table">
                            <thead>
                                <tr>
                                    <th>#</th>
                                    <th>&#1575;&#1587;&#1605; &#1575;&#1604;&#1591;&#1575;&#1604;&#1576; / Student</th>
                                    <th>&#1575;&#1604;&#1601;&#1589;&#1604; / Class</th>
                                    <th>&#1571;&#1610;&#1575;&#1605; &#1575;&#1604;&#1581;&#1590;&#1608;&#1585; / Present</th>
                                    <th>&#1571;&#1610;&#1575;&#1605; &#1575;&#1604;&#1594;&#1610;&#1575;&#1576; / Absent</th>
                                    <th>&#1606;&#1587;&#1576;&#1577; &#1575;&#1604;&#1581;&#1590;&#1608;&#1585; / Rate</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="doc.student_rate_lines" t-as="sr">
                                    <tr>
                                        <td><t t-esc="sr_index + 1"/></td>
                                        <td style="text-align:right;"><t t-esc="sr.student_name or '-'"/></td>
                                        <td style="text-align:right;"><t t-esc="sr.class_name or '-'"/></td>
                                        <td class="status-present"><t t-esc="sr.present_days or 0"/></td>
                                        <td class="status-absent"><t t-esc="sr.absent_days or 0"/></td>
                                        <td>
                                            <strong t-attf-style="color: {{ '#27ae60' if (sr.rate or 0) >= 75 else '#e74c3c' }};">
                                                <t t-esc="'%.1f%%' % (sr.rate or 0)"/>
                                            </strong>
                                        </td>
                                    </tr>
                                </t>
                            </tbody>
                        </table>

                        <!-- ===== Footer ===== -->
                        <div style="margin-top:20px; text-align:center; font-size:8pt; color:#999; border-top:1px solid #ddd; padding-top:8px;">
                            &#1578;&#1605; &#1573;&#1606;&#1588;&#1575;&#1569; &#1607;&#1584;&#1575; &#1575;&#1604;&#1578;&#1602;&#1585;&#1610;&#1585; &#1570;&#1604;&#1610;&#1575;&#1611; &#1576;&#1608;&#1575;&#1587;&#1591;&#1577; &#1606;&#1592;&#1575;&#1605; &#1583;&#1575;&#1585; &#1575;&#1604;&#1571;&#1606;&#1608;&#1575;&#1585;
                            |
                            <span style="direction:ltr;">Auto-generated by Dar Al-Anwar System</span>
                        </div>

                    </div>
                </t>
            </t>
        </t>
    </template>

</odoo>
