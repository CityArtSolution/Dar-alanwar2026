<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================ -->
    <!--  Goals & Evaluation Report - Dar Al-Anwar Academy            -->
    <!--  Bilingual Arabic + English | RTL-Aware                      -->
    <!-- ============================================================ -->

    <template id="report_goals_document">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="web.external_layout">
                    <div class="page" dir="rtl" style="font-family: 'Arial', 'Tahoma', sans-serif;">

                        <!-- ===== CSS ===== -->
                        <style>
                            .page {
                                direction: rtl;
                                text-align: right;
                                font-size: 10pt;
                                color: #333;
                            }
                            .academy-header {
                                text-align: center;
                                border-bottom: 3px solid #1a5276;
                                padding-bottom: 12px;
                                margin-bottom: 20px;
                            }
                            .academy-header .ar-name {
                                font-size: 18pt;
                                font-weight: bold;
                                color: #1a5276;
                            }
                            .academy-header .en-name {
                                font-size: 12pt;
                                color: #555;
                                direction: ltr;
                            }
                            .section-title {
                                background-color: #1a5276;
                                color: #fff;
                                padding: 6px 14px;
                                font-size: 12pt;
                                font-weight: bold;
                                margin: 18px 0 10px 0;
                                border-radius: 3px;
                            }
                            .section-title .en {
                                font-weight: normal;
                                font-size: 10pt;
                                margin-right: 10px;
                                direction: ltr;
                                display: inline;
                            }
                            .goal-table {
                                width: 100%;
                                border-collapse: collapse;
                                margin-bottom: 14px;
                            }
                            .goal-table th,
                            .goal-table td {
                                border: 1px solid #ccc;
                                padding: 6px 10px;
                                vertical-align: middle;
                            }
                            .goal-table thead th {
                                background-color: #1a5276;
                                color: #fff;
                                font-weight: bold;
                                text-align: center;
                            }
                            .goal-table tbody td {
                                text-align: center;
                            }
                            .goal-table tbody tr:nth-child(even) {
                                background-color: #f7f9fb;
                            }
                            .summary-cards {
                                display: flex;
                                gap: 10px;
                                margin-bottom: 16px;
                            }
                            .s-card {
                                flex: 1;
                                border: 1px solid #ccc;
                                border-radius: 4px;
                                padding: 12px;
                                text-align: center;
                            }
                            .s-card .val {
                                font-size: 18pt;
                                font-weight: bold;
                            }
                            .s-card .lbl {
                                font-size: 8pt;
                                color: #666;
                                margin-top: 4px;
                            }
                            .progress-bar-bg {
                                background-color: #eee;
                                border-radius: 4px;
                                overflow: hidden;
                                height: 16px;
                                width: 100%;
                                display: inline-block;
                            }
                            .progress-bar-fill {
                                height: 100%;
                                border-radius: 4px;
                            }
                            .green { color: #27ae60; }
                            .blue { color: #1a5276; }
                            .orange { color: #e67e22; }
                            .red { color: #e74c3c; }
                            .rating-stars {
                                color: #f39c12;
                                font-size: 12pt;
                                letter-spacing: 2px;
                            }
                            @media print {
                                .page { page-break-after: always; }
                                .section-title,
                                .goal-table thead th {
                                    -webkit-print-color-adjust: exact;
                                    print-color-adjust: exact;
                                }
                            }
                        </style>

                        <!-- ===== Header ===== -->
                        <div class="academy-header">
                            <div class="ar-name">&#1583;&#1575;&#1585; &#1575;&#1604;&#1571;&#1606;&#1608;&#1575;&#1585; &#1575;&#1604;&#1571;&#1603;&#1575;&#1583;&#1610;&#1605;&#1610;&#1577;</div>
                            <div class="en-name">Dar Al-Anwar Academy</div>
                        </div>

                        <h3 style="text-align:center; margin-bottom:4px;">
                            &#1578;&#1602;&#1585;&#1610;&#1585; &#1575;&#1604;&#1571;&#1607;&#1583;&#1575;&#1601; &#1608;&#1575;&#1604;&#1578;&#1602;&#1610;&#1610;&#1605;
                        </h3>
                        <p style="text-align:center; font-size:10pt; color:#555; direction:ltr; margin-bottom:16px;">
                            Goals &amp; Evaluation Report
                        </p>

                        <!-- ===== Goals Summary Cards ===== -->
                        <div class="section-title">
                            &#1605;&#1604;&#1582;&#1589; &#1575;&#1604;&#1571;&#1607;&#1583;&#1575;&#1601;
                            <span class="en">Goals Summary</span>
                        </div>
                        <div class="summary-cards">
                            <div class="s-card">
                                <div class="val blue"><t t-esc="doc.total_goals or 0"/></div>
                                <div class="lbl">&#1573;&#1580;&#1605;&#1575;&#1604;&#1610; &#1575;&#1604;&#1571;&#1607;&#1583;&#1575;&#1601;<br/>Total Goals</div>
                            </div>
                            <div class="s-card">
                                <div class="val green"><t t-esc="doc.completed_goals or 0"/></div>
                                <div class="lbl">&#1605;&#1603;&#1578;&#1605;&#1604;&#1577;<br/>Completed</div>
                            </div>
                            <div class="s-card">
                                <div class="val orange"><t t-esc="doc.in_progress_goals or 0"/></div>
                                <div class="lbl">&#1602;&#1610;&#1583; &#1575;&#1604;&#1578;&#1606;&#1601;&#1610;&#1584;<br/>In Progress</div>
                            </div>
                            <div class="s-card">
                                <div class="val red"><t t-esc="doc.not_started_goals or 0"/></div>
                                <div class="lbl">&#1604;&#1605; &#1578;&#1576;&#1583;&#1571;<br/>Not Started</div>
                            </div>
                        </div>

                        <!-- Overall Completion Rate -->
                        <div style="text-align:center; margin-bottom:18px;">
                            <span style="font-size:10pt; color:#555;">
                                &#1606;&#1587;&#1576;&#1577; &#1575;&#1604;&#1573;&#1606;&#1580;&#1575;&#1586; &#1575;&#1604;&#1603;&#1604;&#1610;&#1577; / Overall Completion Rate:
                            </span>
                            <strong style="font-size:14pt; color:#1a5276;">
                                <t t-esc="'%.1f%%' % (doc.overall_completion_rate or 0)"/>
                            </strong>
                        </div>

                        <!-- ===== Per-Class Completion Rates ===== -->
                        <div class="section-title">
                            &#1606;&#1587;&#1576; &#1575;&#1604;&#1573;&#1606;&#1580;&#1575;&#1586; &#1581;&#1587;&#1576; &#1575;&#1604;&#1601;&#1589;&#1604;
                            <span class="en">Completion Rates by Class</span>
                        </div>
                        <table class="goal-table">
                            <thead>
                                <tr>
                                    <th>#</th>
                                    <th>&#1575;&#1604;&#1601;&#1589;&#1604; / Class</th>
                                    <th>&#1573;&#1580;&#1605;&#1575;&#1604;&#1610; &#1575;&#1604;&#1571;&#1607;&#1583;&#1575;&#1601; / Total</th>
                                    <th>&#1605;&#1603;&#1578;&#1605;&#1604;&#1577; / Completed</th>
                                    <th>&#1606;&#1587;&#1576;&#1577; &#1575;&#1604;&#1573;&#1606;&#1580;&#1575;&#1586; / Completion %</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="doc.class_goal_lines" t-as="cg">
                                    <tr>
                                        <td><t t-esc="cg_index + 1"/></td>
                                        <td style="text-align:right;"><t t-esc="cg.class_name or '-'"/></td>
                                        <td><t t-esc="cg.total_goals or 0"/></td>
                                        <td class="green"><t t-esc="cg.completed or 0"/></td>
                                        <td>
                                            <div class="progress-bar-bg" style="width:80%; margin:0 auto;">
                                                <div class="progress-bar-fill"
                                                     t-attf-style="width: {{ '%.0f' % (cg.completion_rate or 0) }}%;
                                                                    background-color: {{ '#27ae60' if (cg.completion_rate or 0) >= 75 else ('#e67e22' if (cg.completion_rate or 0) >= 50 else '#e74c3c') }};"/>
                                            </div>
                                            <span style="font-size:9pt;">
                                                <t t-esc="'%.1f%%' % (cg.completion_rate or 0)"/>
                                            </span>
                                        </td>
                                    </tr>
                                </t>
                            </tbody>
                        </table>

                        <!-- ===== Per-Teacher Goal Tracking ===== -->
                        <div class="section-title">
                            &#1605;&#1578;&#1575;&#1576;&#1593;&#1577; &#1575;&#1604;&#1571;&#1607;&#1583;&#1575;&#1601; &#1581;&#1587;&#1576; &#1575;&#1604;&#1605;&#1593;&#1604;&#1605;
                            <span class="en">Goal Tracking by Teacher</span>
                        </div>
                        <table class="goal-table">
                            <thead>
                                <tr>
                                    <th>#</th>
                                    <th>&#1575;&#1604;&#1605;&#1593;&#1604;&#1605; / Teacher</th>
                                    <th>&#1575;&#1604;&#1571;&#1607;&#1583;&#1575;&#1601; &#1575;&#1604;&#1605;&#1587;&#1606;&#1583;&#1577; / Assigned</th>
                                    <th>&#1605;&#1603;&#1578;&#1605;&#1604;&#1577; / Completed</th>
                                    <th>&#1602;&#1610;&#1583; &#1575;&#1604;&#1578;&#1606;&#1601;&#1610;&#1584; / In Progress</th>
                                    <th>&#1606;&#1587;&#1576;&#1577; &#1575;&#1604;&#1573;&#1606;&#1580;&#1575;&#1586; / Rate</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="doc.teacher_goal_lines" t-as="tg">
                                    <tr>
                                        <td><t t-esc="tg_index + 1"/></td>
                                        <td style="text-align:right;"><t t-esc="tg.teacher_name or '-'"/></td>
                                        <td><t t-esc="tg.assigned_count or 0"/></td>
                                        <td class="green"><t t-esc="tg.completed_count or 0"/></td>
                                        <td class="orange"><t t-esc="tg.in_progress_count or 0"/></td>
                                        <td>
                                            <strong t-attf-style="color: {{ '#27ae60' if (tg.completion_rate or 0) >= 75 else '#e74c3c' }};">
                                                <t t-esc="'%.1f%%' % (tg.completion_rate or 0)"/>
                                            </strong>
                                        </td>
                                    </tr>
                                </t>
                            </tbody>
                        </table>

                        <!-- ===== Student Evaluation Averages ===== -->
                        <div class="section-title">
                            &#1605;&#1578;&#1608;&#1587;&#1591;&#1575;&#1578; &#1578;&#1602;&#1610;&#1610;&#1605; &#1575;&#1604;&#1591;&#1604;&#1575;&#1576;
                            <span class="en">Student Evaluation Averages</span>
                        </div>
                        <table class="goal-table">
                            <thead>
                                <tr>
                                    <th>#</th>
                                    <th>&#1575;&#1604;&#1601;&#1589;&#1604; / Class</th>
                                    <th>&#1593;&#1583;&#1583; &#1575;&#1604;&#1591;&#1604;&#1575;&#1576; / Students</th>
                                    <th>&#1605;&#1578;&#1608;&#1587;&#1591; &#1575;&#1604;&#1578;&#1602;&#1610;&#1610;&#1605; / Avg. Evaluation</th>
                                    <th>&#1571;&#1593;&#1604;&#1609; &#1578;&#1602;&#1610;&#1610;&#1605; / Highest</th>
                                    <th>&#1571;&#1583;&#1606;&#1609; &#1578;&#1602;&#1610;&#1610;&#1605; / Lowest</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="doc.evaluation_lines" t-as="ev">
                                    <tr>
                                        <td><t t-esc="ev_index + 1"/></td>
                                        <td style="text-align:right;"><t t-esc="ev.class_name or '-'"/></td>
                                        <td><t t-esc="ev.student_count or 0"/></td>
                                        <td>
                                            <strong style="color:#1a5276;">
                                                <t t-esc="'%.1f' % (ev.avg_score or 0)"/>
                                            </strong>
                                            <span style="color:#999;"> / <t t-esc="ev.max_possible or 100"/></span>
                                        </td>
                                        <td class="green"><t t-esc="'%.1f' % (ev.highest_score or 0)"/></td>
                                        <td class="red"><t t-esc="'%.1f' % (ev.lowest_score or 0)"/></td>
                                    </tr>
                                </t>
                            </tbody>
                        </table>

                        <!-- ===== Footer ===== -->
                        <div style="margin-top:20px; text-align:center; font-size:8pt; color:#999; border-top:1px solid #ddd; padding-top:8px;">
                            &#1578;&#1605; &#1573;&#1606;&#1588;&#1575;&#1569; &#1607;&#1584;&#1575; &#1575;&#1604;&#1578;&#1602;&#1585;&#1610;&#1585; &#1570;&#1604;&#1610;&#1575;&#1611; &#1576;&#1608;&#1575;&#1587;&#1591;&#1577; &#1606;&#1592;&#1575;&#1605; &#1583;&#1575;&#1585; &#1575;&#1604;&#1571;&#1606;&#1608;&#1575;&#1585;
                            |
                            <span style="direction:ltr;">Auto-generated by Dar Al-Anwar System</span>
                        </div>

                    </div>
                </t>
            </t>
        </t>
    </template>

</odoo>
