<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================ -->
    <!--               BATCH PAYROLL WIZARD FORM VIEW                 -->
    <!-- ============================================================ -->

    <record id="view_batch_payroll_wizard_form" model="ir.ui.view">
        <field name="name">education.batch.payroll.wizard.form</field>
        <field name="model">education.batch.payroll.wizard</field>
        <field name="arch" type="xml">
            <form string="Batch Payroll Generation">
                <group>
                    <group string="Period">
                        <field name="month"/>
                        <field name="year"/>
                    </group>
                    <group string="Scope">
                        <field name="branch_id"/>
                        <field name="department_id"/>
                    </group>
                </group>
                <group string="Employees">
                    <field name="employee_ids" widget="many2many_tags"
                           options="{'no_create': True}"/>
                </group>
                <footer>
                    <button name="action_generate_payroll" type="object"
                            string="Generate Payroll" class="oe_highlight"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- ============================================================ -->
    <!--               BATCH PAYROLL WIZARD ACTION                    -->
    <!-- ============================================================ -->

    <record id="action_batch_payroll_wizard" model="ir.actions.act_window">
        <field name="name">Batch Payroll</field>
        <field name="res_model">education.batch.payroll.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

</odoo>
