<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Attendance Tree View -->
    <record id="view_education_attendance_tree" model="ir.ui.view">
        <field name="name">education.attendance.tree</field>
        <field name="model">education.attendance</field>
        <field name="arch" type="xml">
            <list decoration-success="state == 'confirmed'" decoration-info="state == 'draft'">
                <field name="date"/>
                <field name="department_id"/>
                <field name="class_id"/>
                <field name="present_count"/>
                <field name="absent_count"/>
                <field name="total_count"/>
                <field name="recorded_by"/>
                <field name="state" widget="badge"/>
            </list>
        </field>
    </record>

    <!-- Attendance Form View -->
    <record id="view_education_attendance_form" model="ir.ui.view">
        <field name="name">education.attendance.form</field>
        <field name="model">education.attendance</field>
        <field name="arch" type="xml">
            <form string="Attendance">
                <header>
                    <button name="action_confirm" string="Confirm" type="object" class="btn-primary" invisible="state != 'draft'"/>
                    <button name="action_reset" string="Reset to Draft" type="object" invisible="state != 'confirmed'"/>
                    <button name="action_mark_all_present" string="Mark All Present" type="object" class="btn-secondary" invisible="state != 'draft'"/>
                    <button name="action_mark_all_absent" string="Mark All Absent" type="object" class="btn-secondary" invisible="state != 'draft'"/>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_class" type="object" class="oe_stat_button" icon="fa-users">
                            <span class="o_stat_text">Class</span>
                        </button>
                        <button name="action_view_present" type="object" class="oe_stat_button" icon="fa-check-circle">
                            <field name="present_count" widget="statinfo" string="Present"/>
                        </button>
                        <button name="action_view_absent" type="object" class="oe_stat_button" icon="fa-times-circle">
                            <field name="absent_count" widget="statinfo" string="Absent"/>
                        </button>
                    </div>
                    <group>
                        <group>
                            <field name="date"/>
                            <field name="department_id"/>
                            <field name="class_id"/>
                        </group>
                        <group>
                            <field name="recorded_by"/>
                            <field name="present_count"/>
                            <field name="absent_count"/>
                            <field name="total_count"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Attendance Lines" name="lines">
                            <field name="line_ids">
                                <list editable="bottom">
                                    <field name="student_id"/>
                                    <field name="status"/>
                                    <field name="notes"/>
                                </list>
                            </field>
                        </page>
                        <page string="Notes" name="notes">
                            <field name="notes" placeholder="Add any notes about today's attendance..."/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Attendance Search View -->
    <record id="view_education_attendance_search" model="ir.ui.view">
        <field name="name">education.attendance.search</field>
        <field name="model">education.attendance</field>
        <field name="arch" type="xml">
            <search string="Search Attendance">
                <field name="date"/>
                <field name="department_id"/>
                <field name="class_id"/>
                <field name="recorded_by"/>
                <filter string="Today" name="today" domain="[('date', '=', context_today().strftime('%Y-%m-%d'))]"/>
                <filter string="This Week" name="this_week" domain="[('date', '&gt;=', (context_today() - relativedelta(days=context_today().weekday())).strftime('%Y-%m-%d'))]"/>
                <filter string="Draft" name="draft" domain="[('state', '=', 'draft')]"/>
                <filter string="Confirmed" name="confirmed" domain="[('state', '=', 'confirmed')]"/>
                <separator/>
                <group>
                    <filter string="Date" name="group_date" context="{'group_by': 'date'}"/>
                    <filter string="Department" name="group_department" context="{'group_by': 'department_id'}"/>
                    <filter string="Class" name="group_class" context="{'group_by': 'class_id'}"/>
                    <filter string="Status" name="group_state" context="{'group_by': 'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Attendance Calendar View -->
    <record id="view_education_attendance_calendar" model="ir.ui.view">
        <field name="name">education.attendance.calendar</field>
        <field name="model">education.attendance</field>
        <field name="arch" type="xml">
            <calendar string="Attendance Calendar" date_start="date" color="class_id" quick_create="0">
                <field name="class_id"/>
                <field name="present_count"/>
                <field name="absent_count"/>
            </calendar>
        </field>
    </record>

    <!-- Attendance Action -->
    <record id="action_education_attendance" model="ir.actions.act_window">
        <field name="name">Attendance</field>
        <field name="res_model">education.attendance</field>
        <field name="view_mode">list,form,calendar</field>
        <field name="context">{'search_default_today': 1}</field>
    </record>

    <!-- Attendance Line Tree View (for standalone view) -->
    <record id="view_education_attendance_line_tree" model="ir.ui.view">
        <field name="name">education.attendance.line.tree</field>
        <field name="model">education.attendance.line</field>
        <field name="arch" type="xml">
            <list decoration-success="status == 'present'" decoration-danger="status == 'absent'" decoration-warning="status == 'late'" decoration-muted="status == 'excused'">
                <field name="attendance_id"/>
                <field name="student_id"/>
                <field name="status" widget="badge"/>
                <field name="notes"/>
            </list>
        </field>
    </record>

    <!-- Attendance Line Search View -->
    <record id="view_education_attendance_line_search" model="ir.ui.view">
        <field name="name">education.attendance.line.search</field>
        <field name="model">education.attendance.line</field>
        <field name="arch" type="xml">
            <search string="Search Attendance Lines">
                <field name="student_id"/>
                <field name="attendance_id"/>
                <filter string="Present" name="present" domain="[('status', '=', 'present')]"/>
                <filter string="Absent" name="absent" domain="[('status', '=', 'absent')]"/>
                <filter string="Late" name="late" domain="[('status', '=', 'late')]"/>
                <filter string="Excused" name="excused" domain="[('status', '=', 'excused')]"/>
                <group>
                    <filter string="Student" name="group_student" context="{'group_by': 'student_id'}"/>
                    <filter string="Status" name="group_status" context="{'group_by': 'status'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Attendance Lines Action (for viewing all lines) -->
    <record id="action_education_attendance_line" model="ir.actions.act_window">
        <field name="name">Attendance Records</field>
        <field name="res_model">education.attendance.line</field>
        <field name="view_mode">list</field>
    </record>

</odoo>
