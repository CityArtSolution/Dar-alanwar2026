<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Payment Plan Views -->
    <record id="view_education_payment_plan_tree" model="ir.ui.view">
        <field name="name">education.payment.plan.tree</field>
        <field name="model">education.payment.plan</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="installment_count"/>
                <field name="interval_months"/>
            </list>
        </field>
    </record>

    <record id="action_education_payment_plan" model="ir.actions.act_window">
        <field name="name">Payment Plans</field>
        <field name="res_model">education.payment.plan</field>
        <field name="view_mode">list</field>
    </record>

    <!-- Subscription Type Views -->
    <record id="view_education_subscription_type_tree" model="ir.ui.view">
        <field name="name">education.subscription.type.tree</field>
        <field name="model">education.subscription.type</field>
        <field name="arch" type="xml">
            <list>
                <field name="code"/>
                <field name="name"/>
                <field name="department_id"/>
                <field name="amount"/>
                <field name="payment_plan_id"/>
            </list>
        </field>
    </record>

    <record id="view_education_subscription_type_form" model="ir.ui.view">
        <field name="name">education.subscription.type.form</field>
        <field name="model">education.subscription.type</field>
        <field name="arch" type="xml">
            <form string="Subscription Type">
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_subscriptions" type="object" class="oe_stat_button" icon="fa-credit-card">
                            <field name="subscription_count" widget="statinfo" string="Subscriptions"/>
                        </button>
                        <button name="action_view_students" type="object" class="oe_stat_button" icon="fa-graduation-cap">
                            <field name="student_count" widget="statinfo" string="Students"/>
                        </button>
                    </div>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="code"/>
                            <field name="department_id"/>
                        </group>
                        <group>
                            <field name="amount"/>
                            <field name="payment_plan_id"/>
                        </group>
                    </group>
                    <group>
                        <field name="description"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_education_subscription_type" model="ir.actions.act_window">
        <field name="name">Subscription Types</field>
        <field name="res_model">education.subscription.type</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Student Subscription Views -->
    <record id="view_education_student_subscription_tree" model="ir.ui.view">
        <field name="name">education.student.subscription.tree</field>
        <field name="model">education.student.subscription</field>
        <field name="arch" type="xml">
            <list decoration-success="status == 'active'" decoration-muted="status in ['expired', 'cancelled']">
                <field name="student_id"/>
                <field name="subscription_type_id"/>
                <field name="start_date"/>
                <field name="net_amount"/>
                <field name="paid_amount"/>
                <field name="remaining_amount"/>
                <field name="status" widget="badge"/>
            </list>
        </field>
    </record>

    <record id="view_education_student_subscription_form" model="ir.ui.view">
        <field name="name">education.student.subscription.form</field>
        <field name="model">education.student.subscription</field>
        <field name="arch" type="xml">
            <form string="Student Subscription">
                <header>
                    <button name="action_generate_installments" string="Generate Installments" type="object" class="btn-primary" invisible="status != 'draft'"/>
                    <button name="action_cancel" string="Cancel" type="object" invisible="status not in ['draft', 'active']"/>
                    <field name="status" widget="statusbar"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_student" type="object" class="oe_stat_button" icon="fa-user">
                            <span class="o_stat_text">Student</span>
                        </button>
                        <button name="action_view_installments" type="object" class="oe_stat_button" icon="fa-list">
                            <field name="installment_count" widget="statinfo" string="Installments"/>
                        </button>
                        <button name="action_view_payments" type="object" class="oe_stat_button" icon="fa-money">
                            <field name="payment_count" widget="statinfo" string="Payments"/>
                        </button>
                    </div>
                    <group>
                        <group>
                            <field name="student_id"/>
                            <field name="subscription_type_id"/>
                            <field name="payment_plan_id"/>
                        </group>
                        <group>
                            <field name="start_date"/>
                            <field name="end_date"/>
                        </group>
                    </group>
                    <group>
                        <group>
                            <field name="total_amount"/>
                            <field name="discount"/>
                            <field name="net_amount"/>
                        </group>
                        <group>
                            <field name="paid_amount"/>
                            <field name="remaining_amount"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Installments" name="installments">
                            <field name="installment_ids">
                                <list>
                                    <field name="sequence"/>
                                    <field name="due_date"/>
                                    <field name="amount"/>
                                    <field name="paid_amount"/>
                                    <field name="remaining_amount"/>
                                    <field name="is_paid" widget="boolean_toggle"/>
                                </list>
                            </field>
                        </page>
                        <page string="Notes" name="notes">
                            <field name="notes"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_education_student_subscription" model="ir.actions.act_window">
        <field name="name">Subscriptions</field>
        <field name="res_model">education.student.subscription</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Installment Views -->
    <record id="view_education_installment_tree" model="ir.ui.view">
        <field name="name">education.installment.tree</field>
        <field name="model">education.installment</field>
        <field name="arch" type="xml">
            <list decoration-success="is_paid" decoration-danger="not is_paid and due_date &lt; current_date">
                <field name="student_id"/>
                <field name="sequence"/>
                <field name="due_date"/>
                <field name="amount"/>
                <field name="paid_amount"/>
                <field name="remaining_amount"/>
                <field name="is_paid"/>
            </list>
        </field>
    </record>

    <record id="view_education_installment_form" model="ir.ui.view">
        <field name="name">education.installment.form</field>
        <field name="model">education.installment</field>
        <field name="arch" type="xml">
            <form string="Installment">
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_subscription" type="object" class="oe_stat_button" icon="fa-credit-card">
                            <span class="o_stat_text">Subscription</span>
                        </button>
                        <button name="action_view_student" type="object" class="oe_stat_button" icon="fa-user">
                            <span class="o_stat_text">Student</span>
                        </button>
                        <button name="action_view_payments" type="object" class="oe_stat_button" icon="fa-money">
                            <field name="payment_count" widget="statinfo" string="Payments"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <h1>
                            Installment #<field name="sequence" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="subscription_id"/>
                            <field name="student_id"/>
                            <field name="due_date"/>
                        </group>
                        <group>
                            <field name="amount"/>
                            <field name="paid_amount"/>
                            <field name="remaining_amount"/>
                            <field name="is_paid"/>
                            <field name="paid_date" invisible="not is_paid"/>
                        </group>
                    </group>
                    <group>
                        <field name="notes"/>
                    </group>
                    <notebook>
                        <page string="Payments" name="payments">
                            <field name="payment_ids">
                                <list>
                                    <field name="date"/>
                                    <field name="amount"/>
                                    <field name="payment_method"/>
                                    <field name="received_by"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_education_installment" model="ir.actions.act_window">
        <field name="name">Installments</field>
        <field name="res_model">education.installment</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Payment Views -->
    <record id="view_education_payment_tree" model="ir.ui.view">
        <field name="name">education.payment.tree</field>
        <field name="model">education.payment</field>
        <field name="arch" type="xml">
            <list>
                <field name="date"/>
                <field name="student_id"/>
                <field name="installment_id"/>
                <field name="amount"/>
                <field name="payment_method"/>
                <field name="received_by"/>
            </list>
        </field>
    </record>

    <record id="view_education_payment_form" model="ir.ui.view">
        <field name="name">education.payment.form</field>
        <field name="model">education.payment</field>
        <field name="arch" type="xml">
            <form string="Payment">
                <sheet>
                    <group>
                        <group>
                            <field name="installment_id"/>
                            <field name="student_id"/>
                            <field name="date"/>
                        </group>
                        <group>
                            <field name="amount"/>
                            <field name="payment_method"/>
                            <field name="received_by"/>
                        </group>
                    </group>
                    <group>
                        <field name="notes"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_education_payment" model="ir.actions.act_window">
        <field name="name">Payments</field>
        <field name="res_model">education.payment</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Receipt Views -->
    <record id="view_education_payment_receipt_tree" model="ir.ui.view">
        <field name="name">education.payment.receipt.tree</field>
        <field name="model">education.payment.receipt</field>
        <field name="arch" type="xml">
            <list>
                <field name="receipt_number"/>
                <field name="date"/>
                <field name="student_id"/>
                <field name="total_amount"/>
                <field name="issued_by"/>
            </list>
        </field>
    </record>

    <record id="view_education_payment_receipt_form" model="ir.ui.view">
        <field name="name">education.payment.receipt.form</field>
        <field name="model">education.payment.receipt</field>
        <field name="arch" type="xml">
            <form string="Payment Receipt">
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_payments" type="object" class="oe_stat_button" icon="fa-money">
                            <field name="payment_count" widget="statinfo" string="Payments"/>
                        </button>
                        <button name="action_view_installments" type="object" class="oe_stat_button" icon="fa-list">
                            <field name="installment_count" widget="statinfo" string="Installments"/>
                        </button>
                        <button name="action_view_subscriptions" type="object" class="oe_stat_button" icon="fa-credit-card">
                            <field name="subscription_count" widget="statinfo" string="Subscriptions"/>
                        </button>
                        <button name="action_view_student" type="object" class="oe_stat_button" icon="fa-graduation-cap">
                            <span class="o_stat_text">Student</span>
                        </button>
                    </div>
                    <div class="oe_title">
                        <label for="receipt_number"/>
                        <h1>
                            <field name="receipt_number"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="student_id"/>
                            <field name="date"/>
                        </group>
                        <group>
                            <field name="total_amount"/>
                            <field name="issued_by"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Payments" name="payments">
                            <field name="payment_ids">
                                <list>
                                    <field name="date"/>
                                    <field name="installment_id"/>
                                    <field name="amount"/>
                                    <field name="payment_method"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_education_payment_receipt" model="ir.actions.act_window">
        <field name="name">Receipts</field>
        <field name="res_model">education.payment.receipt</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- ============================================================ -->
    <!-- Financial Plan Views                                        -->
    <!-- ============================================================ -->

    <record id="view_education_financial_plan_form" model="ir.ui.view">
        <field name="name">education.financial.plan.form</field>
        <field name="model">education.financial.plan</field>
        <field name="arch" type="xml">
            <form string="Financial Plan">
                <header>
                    <button name="action_generate_invoices"
                            string="Generate Invoices"
                            type="object"
                            class="btn-primary"
                            invisible="status != 'active'"/>
                    <field name="status" widget="statusbar"
                           statusbar_visible="draft,active,paid"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="student_id"/>
                            <field name="subscription_id"/>
                        </group>
                        <group>
                            <field name="start_date"/>
                            <field name="end_date"/>
                            <field name="total_amount"/>
                        </group>
                    </group>
                    <group>
                        <group>
                            <field name="paid_amount"/>
                            <field name="remaining_amount"/>
                            <field name="installment_count"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Installment Lines" name="lines">
                            <field name="line_ids" widget="one2many" mode="list">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="due_date"/>
                                    <field name="amount"/>
                                    <field name="discount_id"/>
                                    <field name="discounted_amount"/>
                                    <field name="is_paid" widget="boolean_toggle"/>
                                    <field name="payment_date"/>
                                    <field name="invoice_id" readonly="1"/>
                                    <field name="invoice_state" widget="badge"
                                           decoration-info="invoice_state == 'draft'"
                                           decoration-success="invoice_state == 'posted'"
                                           decoration-muted="invoice_state == 'cancel'"
                                           optional="show"/>
                                </list>
                            </field>
                        </page>
                        <page string="Notes" name="notes">
                            <field name="notes"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_education_financial_plan_tree" model="ir.ui.view">
        <field name="name">education.financial.plan.tree</field>
        <field name="model">education.financial.plan</field>
        <field name="arch" type="xml">
            <list decoration-success="status == 'active'"
                  decoration-info="status == 'draft'"
                  decoration-muted="status == 'cancelled'"
                  decoration-danger="status == 'overdue'">
                <field name="name"/>
                <field name="student_id"/>
                <field name="start_date"/>
                <field name="end_date"/>
                <field name="total_amount"/>
                <field name="paid_amount"/>
                <field name="remaining_amount"/>
                <field name="status" widget="badge"
                       decoration-success="status in ('active', 'paid')"
                       decoration-info="status == 'draft'"
                       decoration-danger="status == 'overdue'"
                       decoration-muted="status == 'cancelled'"/>
            </list>
        </field>
    </record>

    <record id="action_education_financial_plan" model="ir.actions.act_window">
        <field name="name">Financial Plans</field>
        <field name="res_model">education.financial.plan</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a new financial plan
            </p>
            <p>
                Manage installment plans and auto-generate draft invoices.
            </p>
        </field>
    </record>

    <!-- Subscription form inherit: add discount fields -->
    <record id="view_education_student_subscription_form_inherit_discount" model="ir.ui.view">
        <field name="name">education.student.subscription.form.inherit.discount</field>
        <field name="model">education.student.subscription</field>
        <field name="inherit_id" ref="view_education_student_subscription_form"/>
        <field name="arch" type="xml">
            <field name="discount" position="after">
                <field name="discount_id"/>
                <field name="discount_amount"/>
            </field>
        </field>
    </record>

</odoo>
