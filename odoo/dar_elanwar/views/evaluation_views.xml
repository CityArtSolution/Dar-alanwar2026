<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ========================== -->
    <!-- EVALUATION TEMPLATE VIEWS -->
    <!-- ========================== -->

    <record id="view_education_evaluation_template_tree" model="ir.ui.view">
        <field name="name">education.evaluation.template.tree</field>
        <field name="model">education.evaluation.template</field>
        <field name="arch" type="xml">
            <list>
                <field name="code"/>
                <field name="name"/>
                <field name="department_id"/>
                <field name="subject_id"/>
                <field name="question_count"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_education_evaluation_template_form" model="ir.ui.view">
        <field name="name">education.evaluation.template.form</field>
        <field name="model">education.evaluation.template</field>
        <field name="arch" type="xml">
            <form string="Evaluation Template">
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_questions" type="object" class="oe_stat_button" icon="fa-question-circle">
                            <field name="question_count" widget="statinfo" string="Questions"/>
                        </button>
                        <button name="action_view_evaluations" type="object" class="oe_stat_button" icon="fa-star">
                            <field name="evaluation_count" widget="statinfo" string="Evaluations"/>
                        </button>
                        <button name="toggle_active" type="object" class="oe_stat_button" icon="fa-archive">
                            <field name="active" widget="boolean_button" options='{"terminology": "archive"}'/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" placeholder="Template Name"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="code"/>
                            <field name="department_id"/>
                            <field name="subject_id"/>
                        </group>
                        <group>
                            <field name="question_count"/>
                        </group>
                    </group>
                    <group>
                        <field name="description" placeholder="Template description..."/>
                    </group>
                    <notebook>
                        <page string="Questions" name="questions">
                            <field name="question_ids">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="question"/>
                                    <field name="scale_id"/>
                                    <field name="is_required"/>
                                    <field name="description"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_education_evaluation_template_search" model="ir.ui.view">
        <field name="name">education.evaluation.template.search</field>
        <field name="model">education.evaluation.template</field>
        <field name="arch" type="xml">
            <search string="Search Templates">
                <field name="name"/>
                <field name="code"/>
                <field name="department_id"/>
                <field name="subject_id"/>
                <filter string="Active" name="active" domain="[('active', '=', True)]"/>
                <filter string="Archived" name="archived" domain="[('active', '=', False)]"/>
                <group>
                    <filter string="Department" name="group_department" context="{'group_by': 'department_id'}"/>
                    <filter string="Subject" name="group_subject" context="{'group_by': 'subject_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_education_evaluation_template" model="ir.actions.act_window">
        <field name="name">Evaluation Templates</field>
        <field name="res_model">education.evaluation.template</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_active': 1}</field>
    </record>

    <!-- ========================== -->
    <!-- EVALUATION GOAL VIEWS -->
    <!-- ========================== -->

    <record id="view_education_evaluation_goal_tree" model="ir.ui.view">
        <field name="name">education.evaluation.goal.tree</field>
        <field name="model">education.evaluation.goal</field>
        <field name="arch" type="xml">
            <list decoration-success="state == 'completed'" decoration-info="state == 'active'" decoration-muted="state == 'cancelled'">
                <field name="date"/>
                <field name="name"/>
                <field name="template_id"/>
                <field name="class_id"/>
                <field name="teacher_id"/>
                <field name="evaluation_count"/>
                <field name="completed_count"/>
                <field name="progress" widget="progressbar"/>
                <field name="state" widget="badge"/>
            </list>
        </field>
    </record>

    <record id="view_education_evaluation_goal_form" model="ir.ui.view">
        <field name="name">education.evaluation.goal.form</field>
        <field name="model">education.evaluation.goal</field>
        <field name="arch" type="xml">
            <form string="Evaluation Goal">
                <header>
                    <button name="action_activate" string="Activate" type="object" class="btn-primary" invisible="state != 'draft'"/>
                    <button name="action_complete" string="Complete" type="object" class="btn-success" invisible="state != 'active'"/>
                    <button name="action_cancel" string="Cancel" type="object" invisible="state not in ['draft', 'active']"/>
                    <button name="action_reset" string="Reset to Draft" type="object" invisible="state not in ['completed', 'cancelled']"/>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" placeholder="Goal Name"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="date"/>
                            <field name="template_id"/>
                            <field name="department_id"/>
                            <field name="class_id"/>
                        </group>
                        <group>
                            <field name="teacher_id"/>
                            <field name="is_shared"/>
                            <field name="evaluation_count"/>
                            <field name="completed_count"/>
                            <field name="progress" widget="progressbar"/>
                        </group>
                    </group>
                    <group>
                        <field name="description" placeholder="Goal description..."/>
                    </group>
                    <notebook>
                        <page string="Student Evaluations" name="evaluations">
                            <field name="evaluation_ids">
                                <list>
                                    <field name="student_id"/>
                                    <field name="evaluator_id"/>
                                    <field name="date"/>
                                    <field name="answer_count"/>
                                    <field name="question_count"/>
                                    <field name="completion_rate" widget="progressbar"/>
                                    <field name="is_completed" widget="boolean_toggle"/>
                                </list>
                            </field>
                        </page>
                        <page string="Notes" name="notes">
                            <field name="notes" placeholder="Additional notes..."/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_education_evaluation_goal_search" model="ir.ui.view">
        <field name="name">education.evaluation.goal.search</field>
        <field name="model">education.evaluation.goal</field>
        <field name="arch" type="xml">
            <search string="Search Goals">
                <field name="name"/>
                <field name="template_id"/>
                <field name="class_id"/>
                <field name="teacher_id"/>
                <filter string="Draft" name="draft" domain="[('state', '=', 'draft')]"/>
                <filter string="Active" name="active" domain="[('state', '=', 'active')]"/>
                <filter string="Completed" name="completed" domain="[('state', '=', 'completed')]"/>
                <separator/>
                <filter string="Shared with Parents" name="shared" domain="[('is_shared', '=', True)]"/>
                <separator/>
                <group>
                    <filter string="Date" name="group_date" context="{'group_by': 'date'}"/>
                    <filter string="Template" name="group_template" context="{'group_by': 'template_id'}"/>
                    <filter string="Class" name="group_class" context="{'group_by': 'class_id'}"/>
                    <filter string="Department" name="group_department" context="{'group_by': 'department_id'}"/>
                    <filter string="Status" name="group_state" context="{'group_by': 'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="view_education_evaluation_goal_kanban" model="ir.ui.view">
        <field name="name">education.evaluation.goal.kanban</field>
        <field name="model">education.evaluation.goal</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state" class="o_kanban_mobile">
                <field name="name"/>
                <field name="date"/>
                <field name="template_id"/>
                <field name="class_id"/>
                <field name="teacher_id"/>
                <field name="state"/>
                <field name="progress"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_global_click">
                            <div class="oe_kanban_content">
                                <div class="o_kanban_record_title">
                                    <strong><field name="name"/></strong>
                                </div>
                                <div class="o_kanban_record_subtitle">
                                    <field name="template_id"/>
                                </div>
                                <div>
                                    <field name="class_id"/> - <field name="date"/>
                                </div>
                                <div class="o_kanban_record_bottom">
                                    <div class="oe_kanban_bottom_left">
                                        <field name="teacher_id" widget="many2one_avatar_user"/>
                                    </div>
                                    <div class="oe_kanban_bottom_right">
                                        <field name="progress" widget="progressbar"/>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="action_education_evaluation_goal" model="ir.actions.act_window">
        <field name="name">Evaluation Goals</field>
        <field name="res_model">education.evaluation.goal</field>
        <field name="view_mode">list,kanban,form</field>
    </record>

    <!-- ========================== -->
    <!-- STUDENT EVALUATION VIEWS -->
    <!-- ========================== -->

    <record id="view_education_student_evaluation_tree" model="ir.ui.view">
        <field name="name">education.student.evaluation.tree</field>
        <field name="model">education.student.evaluation</field>
        <field name="arch" type="xml">
            <list decoration-success="is_completed">
                <field name="goal_id"/>
                <field name="student_id"/>
                <field name="class_id"/>
                <field name="evaluator_id"/>
                <field name="date"/>
                <field name="answer_count"/>
                <field name="question_count"/>
                <field name="completion_rate" widget="progressbar"/>
                <field name="is_completed" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <record id="view_education_student_evaluation_form" model="ir.ui.view">
        <field name="name">education.student.evaluation.form</field>
        <field name="model">education.student.evaluation</field>
        <field name="arch" type="xml">
            <form string="Student Evaluation">
                <header>
                    <button name="action_load_questions" string="Load Questions" type="object" class="btn-secondary" invisible="is_completed"/>
                    <button name="action_complete" string="Mark Complete" type="object" class="btn-success" invisible="is_completed"/>
                    <button name="action_reset" string="Reopen" type="object" invisible="not is_completed"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="student_id" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="goal_id"/>
                            <field name="template_id"/>
                            <field name="class_id"/>
                        </group>
                        <group>
                            <field name="evaluator_id"/>
                            <field name="date"/>
                            <field name="is_completed"/>
                            <field name="completed_date" invisible="not is_completed"/>
                        </group>
                    </group>
                    <group>
                        <group>
                            <field name="answer_count"/>
                            <field name="question_count"/>
                        </group>
                        <group>
                            <field name="completion_rate" widget="progressbar"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Answers" name="answers">
                            <field name="answer_ids">
                                <list editable="bottom">
                                    <field name="sequence" readonly="1"/>
                                    <field name="question_text" readonly="1"/>
                                    <field name="scale_id" column_invisible="1"/>
                                    <field name="answer_value_id"/>
                                    <field name="notes"/>
                                </list>
                            </field>
                        </page>
                        <page string="Summary" name="summary">
                            <field name="summary" placeholder="Overall summary of the evaluation..."/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_education_student_evaluation_search" model="ir.ui.view">
        <field name="name">education.student.evaluation.search</field>
        <field name="model">education.student.evaluation</field>
        <field name="arch" type="xml">
            <search string="Search Evaluations">
                <field name="student_id"/>
                <field name="goal_id"/>
                <field name="class_id"/>
                <field name="evaluator_id"/>
                <filter string="Completed" name="completed" domain="[('is_completed', '=', True)]"/>
                <filter string="Pending" name="pending" domain="[('is_completed', '=', False)]"/>
                <separator/>
                <group>
                    <filter string="Student" name="group_student" context="{'group_by': 'student_id'}"/>
                    <filter string="Goal" name="group_goal" context="{'group_by': 'goal_id'}"/>
                    <filter string="Class" name="group_class" context="{'group_by': 'class_id'}"/>
                    <filter string="Evaluator" name="group_evaluator" context="{'group_by': 'evaluator_id'}"/>
                    <filter string="Date" name="group_date" context="{'group_by': 'date'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_education_student_evaluation" model="ir.actions.act_window">
        <field name="name">Student Evaluations</field>
        <field name="res_model">education.student.evaluation</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- ========================== -->
    <!-- EVALUATION QUESTION VIEWS -->
    <!-- ========================== -->

    <record id="view_education_evaluation_question_tree" model="ir.ui.view">
        <field name="name">education.evaluation.question.tree</field>
        <field name="model">education.evaluation.question</field>
        <field name="arch" type="xml">
            <list>
                <field name="sequence" widget="handle"/>
                <field name="template_id"/>
                <field name="question"/>
                <field name="scale_id"/>
                <field name="is_required"/>
            </list>
        </field>
    </record>

    <record id="action_education_evaluation_question" model="ir.actions.act_window">
        <field name="name">Evaluation Questions</field>
        <field name="res_model">education.evaluation.question</field>
        <field name="view_mode">list</field>
    </record>

</odoo>
