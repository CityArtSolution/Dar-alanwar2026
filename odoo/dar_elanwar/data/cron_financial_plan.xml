<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- Cron Job: Auto-generate Financial Plan Invoices -->
        <record id="cron_auto_generate_plan_invoices" model="ir.cron">
            <field name="name">Education: Auto-generate Financial Plan Invoices</field>
            <field name="model_id" ref="dar_elanwar.model_education_financial_plan"/>
            <field name="state">code</field>
            <field name="code">model._cron_auto_generate_plan_invoices()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="active" eval="True"/>
        </record>

    </data>
</odoo>
